# Copy to `.env` in this same directory (repo root). Docker Compose loads only this path.

# --- Option A: Your own HTTPS on Duck DNS (needs router WAN → this machine TCP 443 + 80) ---
COMPOSE_PROFILES=caddy
DUCKDNS_API_TOKEN=
IRONDOME_PUBLIC_URL=https://irondome-playground.duckdns.org

# --- Option B: No inbound ports — use Quick Tunnel instead ---
# 1) Leave COMPOSE_PROFILES empty (or delete the line). Do NOT set COMPOSE_PROFILES=caddy.
# 2) Run:  docker compose --profile tunnel up -d
# 3) Run:  docker compose logs cloudflared | grep trycloudflare
# 4) Copy the https://….trycloudflare.com URL into IRONDOME_PUBLIC_URL below, then:
#    docker compose restart irondome-web

# Host port for direct HTTP to textual-serve (optional; default 8000)
# IRONDOME_WEB_PORT=8000
