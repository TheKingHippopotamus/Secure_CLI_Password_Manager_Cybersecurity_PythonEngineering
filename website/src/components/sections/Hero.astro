<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('copy-install');
    const cmd = document.getElementById('install-cmd');
    if (!btn || !cmd) return;

    btn.addEventListener('click', async () => {
      const text = cmd.textContent || '';
      try {
        await navigator.clipboard.writeText(text.trim());
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text.trim();
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
      const copyIcon = btn.querySelector('.copy-icon') as HTMLElement;
      const checkIcon = btn.querySelector('.check-icon') as HTMLElement;
      if (copyIcon && checkIcon) {
        copyIcon.style.display = 'none';
        checkIcon.style.display = 'block';
        setTimeout(() => {
          copyIcon.style.display = 'block';
          checkIcon.style.display = 'none';
        }, 2000);
      }
    });
  });
</script>

<style>
  /* ============================================
     HERO SECTION — THE HOOK
     ============================================ */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0A0D06;
    overflow: hidden;
    padding: 6rem 1.5rem 4rem;
  }

  /* ---- Hero Content ---- */
  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 760px;
    gap: 1.5rem;
  }

  /* ---- Classified Badge ---- */
  .classified-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #00FF41;
    border: 1px solid rgba(0, 255, 65, 0.25);
    padding: 0.45rem 1.2rem;
    border-radius: 2px;
    background: rgba(0, 255, 65, 0.04);
    text-shadow: 0 0 8px rgba(0, 255, 65, 0.4);
    animation: badge-flicker 4s ease-in-out infinite;
  }

  .badge-dash {
    font-size: 0.5rem;
    opacity: 0.4;
    color: #00FF41;
  }

  @keyframes badge-flicker {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.85; }
    52%      { opacity: 1; }
    54%      { opacity: 0.9; }
    56%      { opacity: 1; }
  }

  /* ---- Logo ---- */
  .logo-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 240px;
    height: 240px;
  }

  .logo-glow {
    position: absolute;
    inset: -20px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(139, 154, 70, 0.25) 0%, transparent 70%);
    animation: pulse-glow 3s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes pulse-glow {
    0%, 100% {
      transform: scale(1);
      opacity: 0.6;
    }
    50% {
      transform: scale(1.2);
      opacity: 1;
    }
  }

  .hero-logo {
    position: relative;
    width: 240px;
    height: 240px;
    opacity: 0.7;
    filter: drop-shadow(0 0 20px rgba(139, 154, 70, 0.4));
    animation: logo-breathe 3s ease-in-out infinite;
  }

  @keyframes logo-breathe {
    0%, 100% {
      filter: drop-shadow(0 0 20px rgba(139, 154, 70, 0.4));
    }
    50% {
      filter: drop-shadow(0 0 35px rgba(139, 154, 70, 0.7));
    }
  }

  /* ---- Tagline ---- */
  .tagline {
    font-family: 'Impact', 'Arial Narrow', Arial, sans-serif;
    font-size: clamp(2rem, 5.5vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #C8D4B0;
    margin: 0;
  }

  .tagline-accent {
    color: #8B9A46;
    text-shadow: 0 0 20px rgba(139, 154, 70, 0.5);
  }

  /* ---- Subtitle ---- */
  .subtitle {
    font-size: clamp(0.9rem, 2vw, 1.05rem);
    line-height: 1.7;
    color: #7A8B6A;
    max-width: 600px;
    margin: 0;
  }

  /* ---- Install Box ---- */
  .install-box {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid rgba(92, 122, 41, 0.5);
    border-radius: 6px;
    background: rgba(10, 13, 6, 0.8);
    overflow: hidden;
    max-width: 360px;
    width: 100%;
  }

  .install-box code {
    flex: 1;
    padding: 0.75rem 1.2rem;
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.95rem;
    color: #00FF41;
    background: transparent;
    letter-spacing: 0.03em;
    white-space: nowrap;
    user-select: all;
  }

  .copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: rgba(92, 122, 41, 0.15);
    border: none;
    border-left: 1px solid rgba(92, 122, 41, 0.3);
    color: #8B9A46;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    flex-shrink: 0;
  }

  .copy-btn:hover {
    background: rgba(92, 122, 41, 0.3);
    color: #00FF41;
  }

  /* ---- CTA Buttons ---- */
  .cta-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.6rem;
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.25s ease;
    cursor: pointer;
  }

  .cta-outline {
    color: #8B9A46;
    border: 2px solid rgba(139, 154, 70, 0.5);
    background: transparent;
  }

  .cta-outline:hover {
    border-color: #8B9A46;
    background: rgba(139, 154, 70, 0.08);
    box-shadow: 0 0 20px rgba(139, 154, 70, 0.15);
  }

  .cta-solid {
    color: #0A0D06;
    background: linear-gradient(135deg, #8B9A46, #5C7A29);
    border: 2px solid transparent;
  }

  .cta-solid:hover {
    background: linear-gradient(135deg, #9dae52, #6d8e33);
    box-shadow: 0 0 25px rgba(139, 154, 70, 0.3);
  }

  /* ---- Social Icons ---- */
  .social-row {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid rgba(139, 154, 70, 0.25);
    background: rgba(10, 13, 6, 0.6);
    color: #7A8B6A;
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .social-icon:hover {
    border-color: #8B9A46;
    color: #00FF41;
    background: rgba(139, 154, 70, 0.1);
    box-shadow: 0 0 14px rgba(139, 154, 70, 0.2);
    transform: translateY(-2px);
  }

  /* ---- Responsive ---- */
  @media (max-width: 600px) {
    .hero {
      padding: 5rem 1rem 3rem;
    }

    .cta-row {
      flex-direction: column;
      width: 100%;
      max-width: 320px;
    }

    .cta-btn {
      justify-content: center;
      width: 100%;
    }


    .ring-4, .ring-5 {
      display: none;
    }

    .logo-wrap {
      width: 180px;
      height: 180px;
    }

    .hero-logo {
      width: 180px;
      height: 180px;
    }

    .classified-badge {
      font-size: 0.55rem;
      padding: 0.35rem 0.8rem;
    }
  }
</style>
