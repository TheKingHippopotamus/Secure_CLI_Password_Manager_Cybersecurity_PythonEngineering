---
// Hero.astro — Split-screen command center. Left: content column. Right: terminal mockup.
---

<section id="hero" class="hero">
  <!-- Subtle CSS grid background -->
  <div class="hero-grid-bg" aria-hidden="true"></div>

  <div class="hero-inner">

    <!-- ================================================
         LEFT COLUMN — identity + content
         ================================================ -->
    <div class="hero-left">

      <!-- Classification badge -->
      <div class="classified-badge" aria-label="Classification level">
        CLASSIFIED &mdash; ZERO KNOWLEDGE ARCHITECTURE &mdash; AES-128-CBC
      </div>

      <!-- Logo -->
      <div class="logo-wrap">
        <img
          src="/iron_dome_dark.svg"
          alt="IronDome Bunker"
          class="hero-logo"
          width="72"
          height="72"
        />
      </div>

      <!-- Headline -->
      <h1 class="hero-headline">
        MISSION-GRADE PASSWORD SECURITY.<br />
        ZERO TRUST. ZERO CLOUD.
      </h1>

      <!-- Subtitle -->
      <p class="hero-subtitle">
        Your vault lives on your machine. AES-128-CBC encrypted. Biometric-locked.
        No servers. No sync. No breach surface.
      </p>

      <!-- Install box -->
      <div class="install-box">
        <code id="install-cmd">pip install IronDome</code>
        <button id="copy-install" class="copy-btn" aria-label="Copy install command">
          <!-- Copy icon -->
          <svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <!-- Check icon (shown after copy) -->
          <svg class="icon-check" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
      </div>

      <!-- CTA row -->
      <div class="cta-row">
        <a
          href="https://github.com/TheKingHippopotamus/IronDome-Bunker"
          target="_blank"
          rel="noopener noreferrer"
          class="cta-btn cta-outline"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
        <a
          href="https://colab.research.google.com/github/TheKingHippopotamus/IronDome-Bunker/blob/main/demo.ipynb"
          target="_blank"
          rel="noopener noreferrer"
          class="cta-btn cta-solid"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <polygon points="5 3 19 12 5 21 5 3"></polygon>
          </svg>
          Run Demo
        </a>
      </div>

      <!-- Trust badges -->
      <div class="trust-badges">
        <span class="badge">PyPI v3.1.0</span>
        <span class="badge-sep" aria-hidden="true">|</span>
        <span class="badge">AES-128-CBC</span>
        <span class="badge-sep" aria-hidden="true">|</span>
        <span class="badge">100% Local</span>
      </div>

    </div>

    <!-- ================================================
         RIGHT COLUMN — terminal mockup
         ================================================ -->
    <div class="hero-right" aria-hidden="true">
      <div class="terminal-window">

        <!-- Terminal chrome -->
        <div class="terminal-chrome">
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="terminal-title">irondome &mdash; v3.1.0</span>
        </div>

        <!-- Terminal body -->
        <div class="terminal-body">
          <div class="term-line term-line-1">
            <span class="term-phosphor">&#x25CF; IRONDOME BUNKER</span>
          </div>
          <div class="term-divider term-line-2"></div>
          <div class="term-cols term-line-3">
            <span class="term-col-label">VAULT ENTRIES</span>
            <span class="term-col-label">AIRSPACE</span>
            <span class="term-col-label">SESSION</span>
          </div>
          <div class="term-cols term-line-4">
            <span class="term-col-value"><span class="term-phosphor">&#x25CF;</span> 12</span>
            <span class="term-col-value term-warning">&#x25B2; OPEN (28m)</span>
            <span class="term-col-value term-muted">operator</span>
          </div>
          <div class="term-spacer term-line-5"></div>
          <div class="term-nav term-line-6">
            <span class="term-key">[1]</span><span class="term-nav-label"> Vault</span>
            <span class="term-key">[2]</span><span class="term-nav-label"> Generator</span>
            <span class="term-key">[3]</span><span class="term-nav-label"> New Entry</span>
          </div>
          <div class="term-nav term-line-7">
            <span class="term-key">[4]</span><span class="term-nav-label"> Fortify</span>
            <span class="term-key">[5]</span><span class="term-nav-label"> Settings</span>
          </div>
          <div class="term-spacer term-line-8"></div>
          <div class="term-section-label term-line-9">RECENT ACTIVITY</div>
          <div class="term-line term-line-10">
            <span class="term-muted">14:32</span>
            <span class="term-activity"> Opened: <span class="term-phosphor">github.com</span></span>
          </div>
          <div class="term-line term-line-11">
            <span class="term-muted">14:28</span>
            <span class="term-activity"> Generated password <span class="term-dim">(20 chars)</span></span>
          </div>
          <div class="term-prompt-line term-line-12">
            <span class="term-prompt">&#x25B6;</span>
            <span class="term-cursor" aria-hidden="true"></span>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('copy-install');
    const cmd = document.getElementById('install-cmd');
    if (!btn || !cmd) return;

    btn.addEventListener('click', async () => {
      const text = cmd.textContent || '';
      try {
        await navigator.clipboard.writeText(text.trim());
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text.trim();
        ta.style.cssText = 'position:fixed;opacity:0;pointer-events:none;';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
      const iconCopy  = btn.querySelector('.icon-copy')  as HTMLElement | null;
      const iconCheck = btn.querySelector('.icon-check') as HTMLElement | null;
      if (iconCopy && iconCheck) {
        iconCopy.style.display  = 'none';
        iconCheck.style.display = 'block';
        setTimeout(() => {
          iconCopy.style.display  = 'block';
          iconCheck.style.display = 'none';
        }, 2000);
      }
    });
  });
</script>

<style>
  /* =====================================================
     HERO — split-screen command center
     ===================================================== */

  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: var(--color-bg-base, #080B10);
    overflow: hidden;
    padding: 6rem 2rem 5rem;
  }

  /* Subtle CSS grid background at 3% opacity — no radar, no particles */
  .hero-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(107, 127, 46, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(107, 127, 46, 0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* Two-column inner wrapper */
  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 45fr 55fr;
    gap: 3rem;
    align-items: center;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* -----------------------------------------------
     LEFT COLUMN
  ----------------------------------------------- */
  .hero-left {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Classification badge — single flicker on load, then static */
  .classified-badge {
    display: inline-block;
    width: fit-content;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: var(--text-xs, 0.7rem);
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-olive-bright, #8FA63A);
    border: 1px solid var(--color-olive-border, rgba(107, 127, 46, 0.28));
    background: var(--color-olive-muted, rgba(107, 127, 46, 0.10));
    padding: 0.4rem 1rem;
    border-radius: var(--radius-base, 2px);
    animation: badge-flicker 0.6s steps(1) forwards;
  }

  @keyframes badge-flicker {
    0%   { opacity: 0; }
    20%  { opacity: 1; }
    35%  { opacity: 0; }
    50%  { opacity: 1; }
    65%  { opacity: 0; }
    80%  { opacity: 1; }
    100% { opacity: 1; }
  }

  /* Logo */
  .logo-wrap {
    display: flex;
    align-items: center;
  }

  .hero-logo {
    width: 72px;
    height: 72px;
    display: block;
    filter: drop-shadow(0 0 12px var(--color-olive-glow, rgba(143, 166, 58, 0.22)));
  }

  /* Headline */
  .hero-headline {
    font-family: var(--font-heading, 'Rajdhani', sans-serif);
    font-size: var(--text-display, clamp(2.25rem, 5vw, 3.5rem));
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-text-primary, #E2E8F0);
    margin: 0;
  }

  /* Subtitle */
  .hero-subtitle {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: var(--text-base, 1rem);
    line-height: 1.7;
    color: var(--color-text-secondary, #94A3B8);
    max-width: 480px;
    margin: 0;
  }

  /* Install box */
  .install-box {
    display: flex;
    align-items: stretch;
    width: fit-content;
    max-width: 100%;
    border: 1px solid var(--color-olive-border, rgba(107, 127, 46, 0.28));
    border-radius: var(--radius-md, 4px);
    background: var(--color-term-bg, #060910);
    overflow: hidden;
  }

  .install-box code {
    flex: 1;
    padding: 0.7rem 1.25rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: var(--text-sm, 0.875rem);
    color: var(--color-phosphor, #39D353);
    background: transparent;
    letter-spacing: 0.04em;
    white-space: nowrap;
    user-select: all;
    display: block;
  }

  .copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    flex-shrink: 0;
    background: var(--color-olive-muted, rgba(107, 127, 46, 0.10));
    border: none;
    border-left: 1px solid var(--color-olive-border, rgba(107, 127, 46, 0.28));
    color: var(--color-olive-bright, #8FA63A);
    cursor: pointer;
    transition: background var(--duration-base, 250ms), color var(--duration-base, 250ms);
  }

  .copy-btn:hover {
    background: rgba(107, 127, 46, 0.22);
    color: var(--color-phosphor, #39D353);
  }

  .icon-check {
    display: none;
  }

  /* CTA row */
  .cta-row {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.4rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: var(--text-sm, 0.875rem);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: var(--radius-md, 4px);
    transition:
      background var(--duration-base, 250ms),
      border-color var(--duration-base, 250ms),
      box-shadow var(--duration-base, 250ms);
    white-space: nowrap;
  }

  .cta-outline {
    color: var(--color-olive-bright, #8FA63A);
    border: 1px solid var(--color-olive-border, rgba(107, 127, 46, 0.28));
    background: transparent;
  }

  .cta-outline:hover {
    border-color: var(--color-olive-bright, #8FA63A);
    background: var(--color-olive-muted, rgba(107, 127, 46, 0.10));
    box-shadow: 0 0 18px var(--color-olive-glow, rgba(143, 166, 58, 0.22));
  }

  .cta-solid {
    color: #0A0D06;
    background: var(--color-olive, #6B7F2E);
    border: 1px solid transparent;
  }

  .cta-solid:hover {
    background: var(--color-olive-bright, #8FA63A);
    box-shadow: 0 0 22px var(--color-olive-glow, rgba(143, 166, 58, 0.22));
  }

  /* Trust badges */
  .trust-badges {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .badge {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: var(--text-xs, 0.7rem);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-olive-bright, #8FA63A);
    background: var(--color-olive-muted, rgba(107, 127, 46, 0.10));
    border: 1px solid var(--color-olive-border, rgba(107, 127, 46, 0.28));
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-base, 2px);
  }

  .badge-sep {
    color: var(--color-text-disabled, #2D3748);
    font-size: var(--text-xs, 0.7rem);
    user-select: none;
  }

  /* -----------------------------------------------
     RIGHT COLUMN — terminal window
  ----------------------------------------------- */
  .hero-right {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .terminal-window {
    width: 100%;
    max-width: 520px;
    border: 1px solid var(--color-olive-border, rgba(107, 127, 46, 0.28));
    border-radius: 6px;
    background: var(--color-term-bg, #060910);
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.6),
      0 24px 60px rgba(0, 0, 0, 0.5),
      0 0 40px rgba(57, 211, 83, 0.04);
    overflow: hidden;
  }

  /* Chrome bar */
  .terminal-chrome {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid var(--color-olive-border, rgba(107, 127, 46, 0.28));
  }

  /* Dimmed gray dots — tactical, not colorful */
  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    display: inline-block;
  }

  .terminal-title {
    flex: 1;
    text-align: center;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: var(--text-xs, 0.7rem);
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--color-text-muted, #4B5563);
    text-transform: lowercase;
    /* offset left slightly to visually center under the full bar width (dots eat ~54px) */
    margin-right: 54px;
  }

  /* Terminal body */
  .terminal-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.8rem;
    line-height: 1.6;
  }

  /* Typewriter reveal — staggered lines, runs once */
  .term-line-1,
  .term-line-2,
  .term-line-3,
  .term-line-4,
  .term-line-5,
  .term-line-6,
  .term-line-7,
  .term-line-8,
  .term-line-9,
  .term-line-10,
  .term-line-11,
  .term-line-12 {
    opacity: 0;
    animation: term-reveal 0.01s steps(1) forwards;
  }

  .term-line-1  { animation-delay: 0.3s; }
  .term-line-2  { animation-delay: 0.7s; }
  .term-line-3  { animation-delay: 1.1s; }
  .term-line-4  { animation-delay: 1.5s; }
  .term-line-5  { animation-delay: 1.7s; }
  .term-line-6  { animation-delay: 2.1s; }
  .term-line-7  { animation-delay: 2.5s; }
  .term-line-8  { animation-delay: 2.7s; }
  .term-line-9  { animation-delay: 3.1s; }
  .term-line-10 { animation-delay: 3.5s; }
  .term-line-11 { animation-delay: 3.9s; }
  .term-line-12 { animation-delay: 4.3s; }

  @keyframes term-reveal {
    to { opacity: 1; }
  }

  /* Individual terminal content classes */
  .term-line {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    color: var(--color-text-secondary, #94A3B8);
  }

  .term-divider {
    height: 1px;
    background: var(--color-olive-border, rgba(107, 127, 46, 0.28));
    margin: 0.4rem 0;
  }

  .term-cols {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0.5rem;
  }

  .term-col-label {
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted, #4B5563);
  }

  .term-col-value {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-text-primary, #E2E8F0);
  }

  .term-spacer {
    height: 0.5rem;
  }

  .term-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-wrap: wrap;
    color: var(--color-text-secondary, #94A3B8);
    font-size: 0.78rem;
    margin-bottom: 0.15rem;
  }

  .term-key {
    color: var(--color-olive-bright, #8FA63A);
    font-weight: 600;
  }

  .term-nav-label {
    margin-right: 0.75rem;
  }

  .term-section-label {
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted, #4B5563);
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--color-border-subtle, rgba(255, 255, 255, 0.06));
    margin-bottom: 0.25rem;
  }

  .term-muted {
    color: var(--color-text-muted, #4B5563);
    font-size: 0.72rem;
    flex-shrink: 0;
  }

  .term-activity {
    color: var(--color-text-secondary, #94A3B8);
    font-size: 0.78rem;
  }

  .term-dim {
    color: var(--color-text-muted, #4B5563);
  }

  .term-phosphor {
    color: var(--color-phosphor, #39D353);
  }

  .term-warning {
    color: var(--color-warning, #F59E0B);
  }

  /* Prompt line + blinking cursor */
  .term-prompt-line {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.35rem;
  }

  .term-prompt {
    color: var(--color-olive-bright, #8FA63A);
    font-size: 0.75rem;
  }

  .term-cursor {
    display: inline-block;
    width: 8px;
    height: 1rem;
    background: var(--color-phosphor, #39D353);
    border-radius: 1px;
    animation: cursor-blink 1s step-start infinite;
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* -----------------------------------------------
     RESPONSIVE
  ----------------------------------------------- */

  /* Tablet: tighten columns */
  @media (max-width: 960px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero-left {
      align-items: flex-start;
    }

    .hero-right {
      order: 2;
    }

    .hero-left {
      order: 1;
    }

    .trust-badges {
      order: 3;
    }

    .terminal-window {
      max-width: 100%;
    }
  }

  /* Mobile: stack cleanly, content → terminal → badges */
  @media (max-width: 600px) {
    .hero {
      padding: 5rem 1.25rem 3.5rem;
    }

    .hero-inner {
      gap: 2.5rem;
    }

    .hero-headline {
      font-size: clamp(1.75rem, 7vw, 2.5rem);
    }

    .hero-subtitle {
      font-size: var(--text-sm, 0.875rem);
    }

    .classified-badge {
      font-size: 0.58rem;
      letter-spacing: 0.14em;
      padding: 0.35rem 0.75rem;
      /* allow wrapping on very narrow viewports */
      white-space: normal;
      word-break: break-word;
    }

    .cta-row {
      flex-direction: column;
      width: 100%;
      max-width: 320px;
    }

    .cta-btn {
      justify-content: center;
    }

    .terminal-body {
      padding: 1rem 1.1rem 1.25rem;
      font-size: 0.73rem;
    }
  }
</style>
