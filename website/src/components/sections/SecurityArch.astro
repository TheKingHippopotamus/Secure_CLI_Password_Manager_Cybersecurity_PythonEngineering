---
/**
 * SecurityArch.astro
 * Architecture overview section with ASCII diagram in a terminal window.
 * Shows the full security stack from user input to encrypted vault.
 * Builds deep trust by exposing every engineered layer.
 */
---

<section class="security-arch" id="security" aria-label="Architecture overview">
  <div class="security-arch__inner">
    <!-- Section label -->
    <span class="security-arch__label">ARCHITECTURE OVERVIEW</span>

    <!-- Heading -->
    <h2 class="security-arch__heading">The Full Security Stack</h2>

    <!-- Subtitle -->
    <p class="security-arch__subtitle">
      Every component of IronDome's security model, from user input to encrypted vault. No gaps. No shortcuts.
    </p>

    <!-- Terminal window -->
    <div class="terminal">
      <!-- Title bar -->
      <div class="terminal__bar">
        <div class="terminal__dots">
          <span class="terminal__dot terminal__dot--red"></span>
          <span class="terminal__dot terminal__dot--yellow"></span>
          <span class="terminal__dot terminal__dot--green"></span>
        </div>
        <span class="terminal__title">irondome-arch.diagram</span>
        <span class="terminal__status">
          <span class="terminal__status-dot" aria-hidden="true"></span>
          LIVE
        </span>
      </div>

      <!-- Diagram body -->
      <div class="terminal__body">
        <pre class="terminal__diagram" aria-label="IronDome security architecture diagram"><code
>&#x250C;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2510;
