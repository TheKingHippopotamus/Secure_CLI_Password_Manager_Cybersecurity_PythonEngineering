            <span class="fg-platform-item__name">Linux</span>
            <span class="fg-platform-item__status">ACTIVE</span>
          </div>

        </div>

        <div class="fg-card__status">
          <span class="fg-status-dot" aria-hidden="true"></span>
          <span class="fg-status-text">3 / 3 PLATFORMS ACTIVE</span>
        </div>
      </div>
    </article>

  </div><!-- /fg-layout -->
</section>

<style>
  /* ═══════════════════════════════════════════════
     SECTION SHELL
  ═══════════════════════════════════════════════ */
  .fg-section {
    position: relative;
    padding: var(--space-20) var(--space-6);
    overflow: hidden;
  }

  .fg-section__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-3);
    margin-bottom: var(--space-12);
    max-width: 1120px;
    margin-inline: auto;
    margin-bottom: 3.5rem;
  }

  .fg-section__title {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
  }

  .fg-section__subtitle {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.65;
    max-width: 520px;
    margin: 0;
  }

  /* ═══════════════════════════════════════════════
     LAYOUT GRID
  ═══════════════════════════════════════════════ */
  .fg-layout {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.125rem;
    max-width: 1120px;
    margin-inline: auto;
  }

  /* ═══════════════════════════════════════════════
     CARD — BASE
  ═══════════════════════════════════════════════ */
  .fg-card {
    position: relative;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-olive-border);
    border-radius: var(--radius-base);
    overflow: hidden;
    display: flex;
    flex-direction: row;
    align-items: stretch;
    transition:
      background-color var(--duration-base) var(--ease-tactical),
      border-color var(--duration-base) var(--ease-tactical),
      box-shadow var(--duration-base) var(--ease-tactical);
  }

  .fg-card:hover {
    background-color: var(--color-bg-raised);
    border-color: rgba(143, 166, 58, 0.42);
    box-shadow:
      0 0 0 1px rgba(143, 166, 58, 0.08),
      0 8px 40px rgba(0, 0, 0, 0.5);
  }

  /* SPAN variants */
  .fg-card--full  { grid-column: span 6; }
  .fg-card--half  { grid-column: span 3; }
  .fg-card--third { grid-column: span 2; }

  /* Card body (text side) */
  .fg-card__body {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: 1.5rem 1.375rem;
    position: relative;
    z-index: 1;
  }

  /* Visual side — only on full-width cards */
  .fg-card__visual {
    flex: 0 0 auto;
    width: clamp(260px, 38%, 420px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem;
    border-left: 1px solid var(--color-olive-border);
    background-color: var(--color-term-bg);
    position: relative;
    z-index: 1;
  }

  /* Half/third cards: stack visuals below body */
  .fg-card--half .fg-card__body,
  .fg-card--third .fg-card__body {
    padding-bottom: 1.25rem;
  }

  /* ═══════════════════════════════════════════════
     MILITARY GRID OVERLAY — 2% opacity
  ═══════════════════════════════════════════════ */
  .fg-card__grid-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.02;
    background-image:
      linear-gradient(var(--color-olive-bright) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-olive-bright) 1px, transparent 1px);
    background-size: 24px 24px;
  }

  /* ═══════════════════════════════════════════════
     TACTICAL CORNER DECORATIONS — 8px
  ═══════════════════════════════════════════════ */
  .fg-card__corner {
    position: absolute;
    width: 8px;
    height: 8px;
    border-color: rgba(143, 166, 58, 0.25);
    border-style: solid;
    pointer-events: none;
    z-index: 2;
    transition: border-color var(--duration-base) var(--ease-tactical);
  }

  .fg-card:hover .fg-card__corner {
    border-color: rgba(143, 166, 58, 0.65);
  }

  .fg-card__corner--tl { top: 0; left: 0;    border-width: 1px 0 0 1px; }
  .fg-card__corner--tr { top: 0; right: 0;   border-width: 1px 1px 0 0; }
  .fg-card__corner--bl { bottom: 0; left: 0; border-width: 0 0 1px 1px; }
  .fg-card__corner--br { bottom: 0; right: 0;border-width: 0 1px 1px 0; }

  /* ═══════════════════════════════════════════════
     CARD META ROW
  ═══════════════════════════════════════════════ */
  .fg-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .fg-seq {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  /* ═══════════════════════════════════════════════
     CLASSIFICATION BADGES (inline, not the component)
  ═══════════════════════════════════════════════ */
  .fg-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }

  .fg-badge--top-secret {
    background-color: rgba(255, 215, 0, 0.08);
    border: 1px solid rgba(255, 215, 0, 0.45);
    color: #FFD700;
  }

  .fg-badge--classified {
    background-color: rgba(143, 166, 58, 0.08);
    border: 1px solid var(--color-olive-border);
    color: var(--color-olive-bright);
  }

  .fg-badge--restricted {
    background-color: transparent;
    border: 1px solid rgba(120, 144, 156, 0.3);
    color: var(--color-text-secondary);
  }

  /* ═══════════════════════════════════════════════
     CARD TITLE
  ═══════════════════════════════════════════════ */
  .fg-card__title {
    font-family: var(--font-heading);
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    line-height: 1.2;
    margin: 0;
  }

  .fg-card--full .fg-card__title {
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
  }

  /* ═══════════════════════════════════════════════
     CARD DESCRIPTION
  ═══════════════════════════════════════════════ */
  .fg-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    flex: 1 1 auto;
  }

  /* ═══════════════════════════════════════════════
     STATUS BAR
  ═══════════════════════════════════════════════ */
  .fg-card__status {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border-subtle);
  }

  .fg-status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-phosphor);
    box-shadow: 0 0 6px var(--color-phosphor-glow);
    flex-shrink: 0;
    animation: fg-pulse 2.4s ease-in-out infinite;
  }

  .fg-status-dot--red {
    background-color: var(--color-error);
    box-shadow: 0 0 6px rgba(239, 68, 68, 0.45);
  }

  @keyframes fg-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.45; }
  }

  .fg-status-text {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-phosphor);
    text-transform: uppercase;
  }

  .fg-status-sep {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.625rem;
  }

  /* ═══════════════════════════════════════════════
     CODE BLOCK (KDF visual)
  ═══════════════════════════════════════════════ */
  .fg-code-block {
    width: 100%;
    border: 1px solid var(--color-olive-border);
    border-radius: var(--radius-base);
    overflow: hidden;
    background-color: var(--color-term-bg);
  }

  .fg-code-block__bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.45rem 0.75rem;
    background-color: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid var(--color-olive-border);
  }

  .fg-code-block__dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .fg-code-block__dot--red    { background-color: #FF5F57; }
  .fg-code-block__dot--yellow { background-color: #FEBC2E; }
  .fg-code-block__dot--green  { background-color: #28C840; }

  .fg-code-block__label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-text-muted);
    margin-left: var(--space-1);
    letter-spacing: 0.06em;
  }

  .fg-code-block__pre {
    padding: 1rem 1.125rem;
    margin: 0;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    white-space: pre;
  }

  /* Syntax tokens */
  .fg-tok-kw     { color: var(--color-olive-bright); font-weight: 600; }
  .fg-tok-fn     { color: var(--color-info); }
  .fg-tok-param  { color: var(--color-text-secondary); }
  .fg-tok-str    { color: var(--color-term-string); }
  .fg-tok-num    { color: var(--color-term-number); }

  /* ═══════════════════════════════════════════════
     WIFI / SERVER VISUALS
  ═══════════════════════════════════════════════ */
  .fg-visual-wifi,
  .fg-visual-server {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background-color: rgba(239, 68, 68, 0.05);
    border: 1px solid rgba(239, 68, 68, 0.15);
    border-radius: var(--radius-base);
  }

  .fg-wifi-icon,
  .fg-server-icon {
    width: 40px;
    height: 40px;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .fg-wifi-label,
  .fg-server-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--color-error);
    text-transform: uppercase;
  }

  /* ═══════════════════════════════════════════════
     BIOMETRIC DIAGRAM
  ═══════════════════════════════════════════════ */
  .fg-card__visual--bio {
    width: clamp(220px, 34%, 360px);
  }

  .fg-bio-diagram {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    width: 100%;
  }

  .fg-bio-platforms {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    width: 100%;
  }

  .fg-bio-platform {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    position: relative;
  }

  .fg-bio-platform__icon {
    width: 32px;
    height: 32px;
    color: var(--color-olive-bright);
    opacity: 0.8;
  }

  .fg-bio-platform__icon svg {
    width: 100%;
    height: 100%;
  }

  .fg-bio-platform__name {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    text-align: center;
    line-height: 1.4;
    text-transform: uppercase;
  }

  /* Connector lines between platforms and fingerprint */
  .fg-bio-connector {
    position: absolute;
    right: -1rem;
    top: 14px;
    width: 1rem;
    height: 1px;
    background: linear-gradient(90deg, var(--color-olive-border), var(--color-olive-bright));
  }

  .fg-bio-connector--right {
    position: absolute;
    left: -1rem;
    top: 14px;
    width: 1rem;
    height: 1px;
    background: linear-gradient(270deg, var(--color-olive-border), var(--color-olive-bright));
    right: auto;
  }

  .fg-bio-fp {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .fg-bio-fp__icon {
    width: 52px;
    height: 52px;
    color: var(--color-olive-bright);
    filter: drop-shadow(0 0 8px var(--color-olive-glow));
  }

  .fg-bio-fp__label {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 0.18em;
    color: var(--color-phosphor);
    text-align: center;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .fg-bio-linux-row {
    display: flex;
    justify-content: center;
  }

  .fg-bio-platform--linux .fg-bio-platform__icon {
    color: var(--color-text-secondary);
    opacity: 0.65;
  }

  /* ═══════════════════════════════════════════════
     ASCII TUI MOCKUP
  ═══════════════════════════════════════════════ */
  .fg-ascii-tui {
    width: 100%;
    border: 1px solid var(--color-olive-border);
    border-radius: var(--radius-base);
    overflow: hidden;
    background-color: var(--color-term-bg);
  }

  .fg-ascii-tui__bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.45rem 0.75rem;
    background-color: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid var(--color-olive-border);
  }

  .fg-ascii-tui__title {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-text-muted);
    margin-left: var(--space-1);
    letter-spacing: 0.06em;
    flex: 1;
    text-align: center;
  }

  .fg-ascii-tui__body {
    padding: 0.875rem 1rem;
    margin: 0;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    white-space: pre;
  }

  /* TUI syntax tokens */
  .fg-tui-border { color: var(--color-olive-dim); }
  .fg-tui-label  { color: var(--color-text-muted); font-size: 0.65rem; letter-spacing: 0.1em; }
  .fg-tui-active { color: var(--color-phosphor); font-weight: 600; }
  .fg-tui-item   { color: var(--color-text-secondary); }
  .fg-tui-num    { color: var(--color-term-number); }
  .fg-tui-dim    { color: var(--color-text-muted); }
  .fg-tui-hint   { color: var(--color-olive-bright); font-size: 0.65rem; }

  /* ═══════════════════════════════════════════════
     COMMAND PALETTE VISUAL
  ═══════════════════════════════════════════════ */
  .fg-cmd-palette {
    margin-top: var(--space-2);
    border: 1px solid var(--color-olive-border);
    border-radius: var(--radius-base);
    overflow: hidden;
    background-color: var(--color-term-bg);
  }

  .fg-cmd-palette__input {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.45rem 0.75rem;
    border-bottom: 1px solid var(--color-olive-border);
    background-color: rgba(255, 255, 255, 0.02);
  }

  .fg-cmd-palette__prompt {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-olive-bright);
    font-weight: 600;
  }

  .fg-cmd-palette__cursor {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-phosphor);
    animation: fg-blink 1s step-end infinite;
  }

  @keyframes fg-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .fg-cmd-palette__list {
    list-style: none;
    margin: 0;
    padding: 0.25rem 0;
  }

  .fg-cmd-palette__item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 0.3rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.675rem;
    transition: background-color var(--duration-fast) ease;
  }

  .fg-cmd-palette__item--active {
    background-color: rgba(57, 211, 83, 0.08);
  }

  .fg-cmd-key {
    color: var(--color-phosphor);
    font-weight: 600;
    min-width: 50px;
    letter-spacing: 0.05em;
  }

  .fg-cmd-desc {
    color: var(--color-text-muted);
    font-size: 0.625rem;
  }

  /* ═══════════════════════════════════════════════
     CROSS-PLATFORM GRID VISUAL
  ═══════════════════════════════════════════════ */
  .fg-platform-grid {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .fg-platform-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-2);
    background-color: var(--color-term-bg);
    border: 1px solid var(--color-olive-border);
    border-radius: var(--radius-base);
  }

  .fg-platform-item__icon {
    width: 28px;
    height: 28px;
    color: var(--color-olive-bright);
    opacity: 0.85;
  }

  .fg-platform-item__icon svg {
    width: 100%;
    height: 100%;
  }

  .fg-platform-item__name {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    text-align: center;
  }

  .fg-platform-item__status {
    font-family: var(--font-mono);
    font-size: 0.5rem;
