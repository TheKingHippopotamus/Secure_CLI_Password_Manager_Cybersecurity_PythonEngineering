        <h3 class="fg-card__title">CROSS-PLATFORM</h3>
        <p class="fg-card__desc">
          macOS, Windows, Linux. One codebase, three deployment targets, zero platform-specific compromises.
        </p>

        <!-- Visual: three OS icons with ACTIVE status -->
        <div class="fg-platform-grid" aria-hidden="true">

          <div class="fg-platform-item">
            <div class="fg-platform-item__icon">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M16.08 1.02c-1.85.1-4 1.2-5.27 2.7-.89 1.04-1.63 2.66-1.36 4.22 2.04.06 4.13-1.03 5.35-2.54.84-1.04 1.53-2.62 1.28-4.38zM20.4 8.26c-.25-.1-2.5-1.03-2.52-3.64-.02-2.16 1.77-3.24 1.96-3.35-1.07-1.57-2.73-1.74-3.32-1.77-1.42-.14-2.77.84-3.49.84-.72 0-1.83-.8-3.02-.78-1.55.02-2.99.9-3.79 2.28C4.51 4.67 4 7.33 5.01 9.83c.68 1.74 2.57 5.93 4.53 5.87.87-.02 1.49-.59 2.8-.59 1.3 0 1.87.59 2.87.57 1.98-.03 3.68-3.87 4.35-5.61-.02-.01-2.14-.82-2.16-3.81z" fill="currentColor"/>
              </svg>
            </div>
            <span class="fg-platform-item__name">macOS</span>
            <span class="fg-platform-item__status">ACTIVE</span>
