---
import ClassificationBadge from '../ClassificationBadge.astro';
---

<section class="fg-section" id="features" aria-labelledby="fg-heading">

  <!-- ── Section header ── -->
  <div class="fg-section__header">
    <ClassificationBadge text="TACTICAL CAPABILITIES" level="classified" />
    <h2 class="fg-section__title" id="fg-heading">Full Feature Set</h2>
    <p class="fg-section__subtitle">
      Four defence layers. Ten battle-tested capabilities. Zero compromises.
    </p>
  </div>

  <!-- ═══════════════════════════════════════════════════
       CATEGORY 01 — CRYPTOGRAPHIC CORE
  ═══════════════════════════════════════════════════ -->
  <div class="fg-layout">

    <!-- FULL-WIDTH: AES-128-CBC ENCRYPTION -->
    <article class="fg-card fg-card--full fg-card--crypto" aria-label="AES-128-CBC Encryption">
      <div class="fg-card__grid-overlay" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tr" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--bl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--br" aria-hidden="true"></div>

      <div class="fg-card__body">
        <div class="fg-card__meta">
          <span class="fg-badge fg-badge--top-secret">TOP SECRET // CRYPTO</span>
          <span class="fg-seq">01</span>
        </div>

        <h3 class="fg-card__title">AES-128-CBC ENCRYPTION</h3>
        <p class="fg-card__desc">
          Fernet symmetric encryption backed by PBKDF2-HMAC-SHA256 at 600,000 iterations.
          Every credential encrypted with a unique key. Brute-force cost: thermodynamically hostile.
        </p>

        <div class="fg-card__status">
          <span class="fg-status-dot" aria-hidden="true"></span>
          <span class="fg-status-text">CIPHER ACTIVE</span>
          <span class="fg-status-sep" aria-hidden="true">|</span>
          <span class="fg-status-text">AES-128-CBC + HMAC-SHA256</span>
        </div>
      </div>

      <!-- Visual: KDF code snippet -->
      <div class="fg-card__visual" aria-hidden="true">
        <div class="fg-code-block">
          <div class="fg-code-block__bar">
            <span class="fg-code-block__dot fg-code-block__dot--red"></span>
            <span class="fg-code-block__dot fg-code-block__dot--yellow"></span>
            <span class="fg-code-block__dot fg-code-block__dot--green"></span>
            <span class="fg-code-block__label">kdf.py</span>
          </div>
          <pre class="fg-code-block__pre"><code><span class="fg-tok-kw">key</span> = <span class="fg-tok-fn">PBKDF2HMAC</span>(
  <span class="fg-tok-param">algorithm</span>=<span class="fg-tok-str">SHA256()</span>,
  <span class="fg-tok-param">length</span>=<span class="fg-tok-num">32</span>,
  <span class="fg-tok-param">salt</span>=<span class="fg-tok-str">os.urandom(16)</span>,
  <span class="fg-tok-param">iterations</span>=<span class="fg-tok-num">600_000</span>,
).derive(<span class="fg-tok-str">password</span>)
<span class="fg-tok-kw">fernet</span> = <span class="fg-tok-fn">Fernet</span>(<span class="fg-tok-fn">base64.urlsafe_b64encode</span>(key))</code></pre>
        </div>
      </div>
    </article>

    <!-- ═══════════════════════════════════════════════════
         CATEGORY 02 — NETWORK & DATA POSTURE
    ═══════════════════════════════════════════════════ -->

    <!-- HALF-WIDTH: OFFLINE. ALWAYS. -->
    <article class="fg-card fg-card--half" aria-label="Offline, always">
      <div class="fg-card__grid-overlay" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tr" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--bl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--br" aria-hidden="true"></div>

      <div class="fg-card__body">
        <div class="fg-card__meta">
          <span class="fg-badge fg-badge--classified">CLASSIFIED // NETWORK</span>
          <span class="fg-seq">02</span>
        </div>

        <h3 class="fg-card__title">OFFLINE. ALWAYS.</h3>
        <p class="fg-card__desc">
          Zero network stack. Zero cloud. Zero attack surface. If it cannot phone home, it cannot be breached remotely.
        </p>

        <!-- Visual: crossed-out wifi -->
        <div class="fg-visual-wifi" aria-hidden="true">
          <svg class="fg-wifi-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- wifi arcs -->
            <path d="M6 18C12.6 11.4 21 8 24 8s11.4 3.4 18 10" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            <path d="M11 23c3.6-3.6 7.8-5.5 13-5.5s9.4 1.9 13 5.5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            <path d="M16 28c2.2-2.2 4.8-3.5 8-3.5s5.8 1.3 8 3.5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            <circle cx="24" cy="35" r="2.5" fill="currentColor"/>
            <!-- X strike-through -->
            <line x1="6" y1="6" x2="42" y2="42" stroke="var(--color-error)" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          <span class="fg-wifi-label">NO NETWORK CALLS</span>
        </div>

        <div class="fg-card__status">
          <span class="fg-status-dot fg-status-dot--red" aria-hidden="true"></span>
          <span class="fg-status-text">AIRGAPPED</span>
        </div>
      </div>
    </article>

    <!-- HALF-WIDTH: ZERO KNOWLEDGE -->
    <article class="fg-card fg-card--half" aria-label="Zero knowledge architecture">
      <div class="fg-card__grid-overlay" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tr" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--bl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--br" aria-hidden="true"></div>

      <div class="fg-card__body">
        <div class="fg-card__meta">
          <span class="fg-badge fg-badge--classified">CLASSIFIED // PRIVACY</span>
          <span class="fg-seq">03</span>
        </div>

        <h3 class="fg-card__title">ZERO KNOWLEDGE</h3>
        <p class="fg-card__desc">
          No telemetry. No accounts. No servers. We cannot see your vault because there is no "we" between you and your data.
        </p>

        <!-- Visual: empty server with X -->
        <div class="fg-visual-server" aria-hidden="true">
          <svg class="fg-server-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="6" y="8" width="36" height="10" rx="1" stroke="currentColor" stroke-width="2"/>
            <circle cx="38" cy="13" r="2" fill="currentColor"/>
            <rect x="6" y="22" width="36" height="10" rx="1" stroke="currentColor" stroke-width="2"/>
            <circle cx="38" cy="27" r="2" fill="currentColor"/>
            <rect x="6" y="36" width="36" height="6" rx="1" stroke="currentColor" stroke-width="2"/>
            <!-- X overlay -->
            <line x1="14" y1="14" x2="34" y2="34" stroke="var(--color-error)" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="34" y1="14" x2="14" y2="34" stroke="var(--color-error)" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          <span class="fg-server-label">NO SERVERS INVOLVED</span>
        </div>

        <div class="fg-card__status">
          <span class="fg-status-dot" aria-hidden="true"></span>
          <span class="fg-status-text">LOCAL ONLY</span>
        </div>
      </div>
    </article>

    <!-- ═══════════════════════════════════════════════════
         CATEGORY 03 — AUTHENTICATION LAYER
    ═══════════════════════════════════════════════════ -->

    <!-- FULL-WIDTH: BIOMETRIC AUTHENTICATION -->
    <article class="fg-card fg-card--full fg-card--bio" aria-label="Biometric authentication">
      <div class="fg-card__grid-overlay" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tr" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--bl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--br" aria-hidden="true"></div>

      <div class="fg-card__body">
        <div class="fg-card__meta">
          <span class="fg-badge fg-badge--top-secret">TOP SECRET // AUTH</span>
          <span class="fg-seq">04</span>
        </div>

        <h3 class="fg-card__title">BIOMETRIC AUTHENTICATION</h3>
        <p class="fg-card__desc">
          Touch ID, Windows Hello, and fprintd. Hardware-attested biometric gate before every vault session.
          Your face and your fingerprint are your credentials.
        </p>

        <div class="fg-card__status">
          <span class="fg-status-dot" aria-hidden="true"></span>
          <span class="fg-status-text">IRONDOME v2.0</span>
          <span class="fg-status-sep" aria-hidden="true">|</span>
          <span class="fg-status-text">MULTI-PLATFORM</span>
        </div>
      </div>

      <!-- Visual: three platform icons connected to fingerprint -->
      <div class="fg-card__visual fg-card__visual--bio" aria-hidden="true">
        <div class="fg-bio-diagram">
          <div class="fg-bio-platforms">

            <!-- macOS -->
            <div class="fg-bio-platform">
              <div class="fg-bio-platform__icon">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M16.08 1.02c-1.85.1-4 1.2-5.27 2.7-.89 1.04-1.63 2.66-1.36 4.22 2.04.06 4.13-1.03 5.35-2.54.84-1.04 1.53-2.62 1.28-4.38zM20.4 8.26c-.25-.1-2.5-1.03-2.52-3.64-.02-2.16 1.77-3.24 1.96-3.35-1.07-1.57-2.73-1.74-3.32-1.77-1.42-.14-2.77.84-3.49.84-.72 0-1.83-.8-3.02-.78-1.55.02-2.99.9-3.79 2.28C4.51 4.67 4 7.33 5.01 9.83c.68 1.74 2.57 5.93 4.53 5.87.87-.02 1.49-.59 2.8-.59 1.3 0 1.87.59 2.87.57 1.98-.03 3.68-3.87 4.35-5.61-.02-.01-2.14-.82-2.16-3.81z" fill="currentColor"/>
                </svg>
              </div>
              <span class="fg-bio-platform__name">macOS<br/>Touch ID</span>
              <div class="fg-bio-connector" aria-hidden="true"></div>
            </div>

            <!-- Fingerprint glyph -->
            <div class="fg-bio-fp">
              <svg class="fg-bio-fp__icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M24 8C15.16 8 8 15.16 8 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                <path d="M24 8C32.84 8 40 15.16 40 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                <path d="M14 24c0-5.52 4.48-10 10-10s10 4.48 10 10c0 4.2-2.6 7.8-6.3 9.3" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                <path d="M24 18c3.31 0 6 2.69 6 6 0 5.5-2 10.5-6 14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                <path d="M24 18c-3.31 0-6 2.69-6 6 0 3 .5 6.5 2 9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                <circle cx="24" cy="24" r="2" fill="currentColor"/>
              </svg>
              <span class="fg-bio-fp__label">BIOMETRIC<br/>GATE</span>
            </div>

            <!-- Windows -->
            <div class="fg-bio-platform">
              <div class="fg-bio-connector fg-bio-connector--right" aria-hidden="true"></div>
              <div class="fg-bio-platform__icon">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M3 5.557L10.5 4.5V11.5H3V5.557zM21 3L11.5 4.444V11.5H21V3zM11.5 12.5V19.556L21 21V12.5H11.5zM3 12.5V18.443L10.5 19.5V12.5H3z" fill="currentColor"/>
                </svg>
              </div>
              <span class="fg-bio-platform__name">Windows<br/>Hello</span>
            </div>

          </div>

          <!-- Linux row -->
          <div class="fg-bio-linux-row">
            <div class="fg-bio-platform fg-bio-platform--linux">
              <div class="fg-bio-platform__icon">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M8 14s1.5 2 4 2 4-2 4-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <circle cx="9" cy="10" r="1" fill="currentColor"/>
                  <circle cx="15" cy="10" r="1" fill="currentColor"/>
                  <path d="M7 7c.5-1.5 2-2 2-2M17 7c-.5-1.5-2-2-2-2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
              </div>
              <span class="fg-bio-platform__name">Linux<br/>fprintd</span>
            </div>
          </div>
        </div>
      </div>
    </article>

    <!-- ═══════════════════════════════════════════════════
         CATEGORY 04 — SESSION & RUNTIME SECURITY
    ═══════════════════════════════════════════════════ -->

    <!-- THIRD-WIDTH: MACHINE-SPECIFIC KEYS -->
    <article class="fg-card fg-card--third" aria-label="Machine-specific keys">
      <div class="fg-card__grid-overlay" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tr" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--bl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--br" aria-hidden="true"></div>

      <div class="fg-card__body">
        <div class="fg-card__meta">
          <span class="fg-badge fg-badge--restricted">RESTRICTED // HW</span>
          <span class="fg-seq">05</span>
        </div>

        <h3 class="fg-card__title">MACHINE-SPECIFIC KEYS</h3>
        <p class="fg-card__desc">
          Keys derived from CPU serial, motherboard UUID, and hostname.
          Copy the vault file — it is useless without the exact hardware that created it.
        </p>

        <div class="fg-card__status">
          <span class="fg-status-dot" aria-hidden="true"></span>
          <span class="fg-status-text">HW-BOUND</span>
        </div>
      </div>
    </article>

    <!-- THIRD-WIDTH: SESSION INTEGRITY -->
    <article class="fg-card fg-card--third" aria-label="Session integrity">
      <div class="fg-card__grid-overlay" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tr" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--bl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--br" aria-hidden="true"></div>

      <div class="fg-card__body">
        <div class="fg-card__meta">
          <span class="fg-badge fg-badge--restricted">RESTRICTED // SESSION</span>
          <span class="fg-seq">06</span>
        </div>

        <h3 class="fg-card__title">SESSION INTEGRITY</h3>
        <p class="fg-card__desc">
          Configurable inactivity timeout with hard-lock on expiry. Session token chmod 0600.
          No session survives a reboot.
        </p>

        <div class="fg-card__status">
          <span class="fg-status-dot" aria-hidden="true"></span>
          <span class="fg-status-text">30 MIN DEFAULT</span>
        </div>
      </div>
    </article>

    <!-- THIRD-WIDTH: CLIPBOARD AUTO-CLEAR -->
    <article class="fg-card fg-card--third" aria-label="Clipboard auto-clear">
      <div class="fg-card__grid-overlay" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tr" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--bl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--br" aria-hidden="true"></div>

      <div class="fg-card__body">
        <div class="fg-card__meta">
          <span class="fg-badge fg-badge--restricted">RESTRICTED // CLIPBOARD</span>
          <span class="fg-seq">07</span>
        </div>

        <h3 class="fg-card__title">CLIPBOARD AUTO-CLEAR</h3>
        <p class="fg-card__desc">
          Copied credentials self-destruct from clipboard after 30 seconds.
          No lingering plaintext. No accidental paste into the wrong window.
        </p>

        <div class="fg-card__status">
          <span class="fg-status-dot" aria-hidden="true"></span>
          <span class="fg-status-text">TTL: 30s</span>
        </div>
      </div>
    </article>

    <!-- ═══════════════════════════════════════════════════
         CATEGORY 05 — TERMINAL INTERFACE
    ═══════════════════════════════════════════════════ -->

    <!-- FULL-WIDTH: FULL TERMINAL COMMAND CENTER -->
    <article class="fg-card fg-card--full fg-card--tui" aria-label="Full terminal command center">
      <div class="fg-card__grid-overlay" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tr" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--bl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--br" aria-hidden="true"></div>

      <div class="fg-card__body">
        <div class="fg-card__meta">
          <span class="fg-badge fg-badge--top-secret">TOP SECRET // INTERFACE</span>
          <span class="fg-seq">08</span>
        </div>

        <h3 class="fg-card__title">FULL TERMINAL COMMAND CENTER</h3>
        <p class="fg-card__desc">
          A 12-screen TUI built on Rich. Vault list, credential inspector, audit log, settings panel,
          backup manager — all keyboard-driven, all without leaving your terminal.
        </p>

        <div class="fg-card__status">
          <span class="fg-status-dot" aria-hidden="true"></span>
          <span class="fg-status-text">12 SCREENS</span>
          <span class="fg-status-sep" aria-hidden="true">|</span>
          <span class="fg-status-text">RICH TUI</span>
          <span class="fg-status-sep" aria-hidden="true">|</span>
          <span class="fg-status-text">KEYBOARD NATIVE</span>
        </div>
      </div>

      <!-- Visual: ASCII vault list mockup -->
      <div class="fg-card__visual" aria-hidden="true">
        <div class="fg-ascii-tui">
          <div class="fg-ascii-tui__bar">
            <span class="fg-code-block__dot fg-code-block__dot--red"></span>
            <span class="fg-code-block__dot fg-code-block__dot--yellow"></span>
            <span class="fg-code-block__dot fg-code-block__dot--green"></span>
            <span class="fg-ascii-tui__title">IronDome — Vault List</span>
          </div>
          <pre class="fg-ascii-tui__body"><code><span class="fg-tui-border">┌─────────────────────────────────────────┐</span>
<span class="fg-tui-border">│</span> <span class="fg-tui-label">VAULT</span>                    <span class="fg-tui-dim">ENTRIES  UPDATED</span>  <span class="fg-tui-border">│</span>
<span class="fg-tui-border">├─────────────────────────────────────────┤</span>
<span class="fg-tui-border">│</span> <span class="fg-tui-active">&gt; Work Accounts</span>            <span class="fg-tui-num">  42</span>  <span class="fg-tui-dim">2h ago</span>  <span class="fg-tui-border">│</span>
<span class="fg-tui-border">│</span>   <span class="fg-tui-item">Personal</span>                  <span class="fg-tui-num">  18</span>  <span class="fg-tui-dim">1d ago</span>  <span class="fg-tui-border">│</span>
<span class="fg-tui-border">│</span>   <span class="fg-tui-item">Infrastructure</span>            <span class="fg-tui-num">   9</span>  <span class="fg-tui-dim">3d ago</span>  <span class="fg-tui-border">│</span>
<span class="fg-tui-border">│</span>   <span class="fg-tui-item">API Keys</span>                  <span class="fg-tui-num">  31</span>  <span class="fg-tui-dim">6h ago</span>  <span class="fg-tui-border">│</span>
<span class="fg-tui-border">└─────────────────────────────────────────┘</span>
<span class="fg-tui-hint">  [n]ew  [d]elete  [/]search  [Ctrl+P] cmd</span></code></pre>
        </div>
      </div>
    </article>

    <!-- HALF-WIDTH: Ctrl+P COMMAND PALETTE -->
    <article class="fg-card fg-card--half" aria-label="Command palette">
      <div class="fg-card__grid-overlay" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tr" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--bl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--br" aria-hidden="true"></div>

      <div class="fg-card__body">
        <div class="fg-card__meta">
          <span class="fg-badge fg-badge--classified">CLASSIFIED // UX</span>
          <span class="fg-seq">09</span>
        </div>

        <h3 class="fg-card__title">Ctrl+P COMMAND PALETTE</h3>
        <p class="fg-card__desc">
          Every action, one keypress away. Fuzzy search across all commands. No menu navigation, no mouse required.
        </p>

        <!-- Visual: command list -->
        <div class="fg-cmd-palette" aria-hidden="true">
          <div class="fg-cmd-palette__input">
            <span class="fg-cmd-palette__prompt">&gt;</span>
            <span class="fg-cmd-palette__cursor">|</span>
          </div>
          <ul class="fg-cmd-palette__list">
            <li class="fg-cmd-palette__item fg-cmd-palette__item--active">
              <span class="fg-cmd-key">add</span>
              <span class="fg-cmd-desc">Add new credential</span>
            </li>
            <li class="fg-cmd-palette__item">
              <span class="fg-cmd-key">copy</span>
              <span class="fg-cmd-desc">Copy password to clipboard</span>
            </li>
            <li class="fg-cmd-palette__item">
              <span class="fg-cmd-key">search</span>
              <span class="fg-cmd-desc">Fuzzy search vault</span>
            </li>
            <li class="fg-cmd-palette__item">
              <span class="fg-cmd-key">lock</span>
              <span class="fg-cmd-desc">Hard-lock session now</span>
            </li>
          </ul>
        </div>

        <div class="fg-card__status">
          <span class="fg-status-dot" aria-hidden="true"></span>
          <span class="fg-status-text">PALETTE READY</span>
        </div>
      </div>
    </article>

    <!-- HALF-WIDTH: CROSS-PLATFORM -->
    <article class="fg-card fg-card--half" aria-label="Cross-platform support">
      <div class="fg-card__grid-overlay" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--tr" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--bl" aria-hidden="true"></div>
      <div class="fg-card__corner fg-card__corner--br" aria-hidden="true"></div>

      <div class="fg-card__body">
        <div class="fg-card__meta">
