---
interface Props {
  title?: string;
  showDots?: boolean;
}

const { title = "IRONDOME TERMINAL", showDots = true } = Astro.props;
---

<div class="terminal-window tactical-corners">
  <div class="terminal-titlebar">
    {showDots && (
      <div class="terminal-dots" aria-hidden="true">
        <span class="dot dot--red"></span>
        <span class="dot dot--yellow"></span>
        <span class="dot dot--green"></span>
      </div>
    )}
    <span class="terminal-title">{title}</span>
    <div class="terminal-corner-tl" aria-hidden="true"></div>
    <div class="terminal-corner-tr" aria-hidden="true"></div>
  </div>
  <div class="terminal-body">
    <slot />
  </div>
  <div class="terminal-corner-bl" aria-hidden="true"></div>
  <div class="terminal-corner-br" aria-hidden="true"></div>
</div>

<style>
  .terminal-window {
    background-color: #0d1117;
    border: 1px solid rgba(255, 215, 0, 0.12);
    border-radius: 2px;
    overflow: hidden;
    position: relative;
    font-family: ui-monospace, "Cascadia Code", "Fira Code", "JetBrains Mono", Menlo, Monaco, "Courier New", monospace;
  }

  /* Tactical corner decorations — CSS drawn, no SVG */
  .terminal-window::before,
  .terminal-window::after {
    content: "";
    position: absolute;
    width: 10px;
    height: 10px;
    border-color: rgba(255, 215, 0, 0.35);
    border-style: solid;
    pointer-events: none;
    z-index: 2;
  }

  .terminal-window::before {
    top: 0;
    left: 0;
    border-width: 1px 0 0 1px;
  }

  .terminal-window::after {
    bottom: 0;
    right: 0;
    border-width: 0 1px 1px 0;
  }

  .terminal-corner-tl,
  .terminal-corner-tr,
  .terminal-corner-bl,
  .terminal-corner-br {
    position: absolute;
    width: 10px;
    height: 10px;
    border-color: rgba(255, 215, 0, 0.35);
    border-style: solid;
    pointer-events: none;
    z-index: 2;
  }

  .terminal-corner-tl {
    top: 0;
    right: 0;
    border-width: 1px 1px 0 0;
  }

  .terminal-corner-tr {
    /* handled by ::before on titlebar — visual only */
    display: none;
  }

  .terminal-corner-bl {
    bottom: 0;
    left: 0;
    border-width: 0 0 1px 1px;
  }

  .terminal-corner-br {
    /* handled by ::after — visual only */
    display: none;
  }

  /* Title bar */
  .terminal-titlebar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.875rem;
    background-color: rgba(0, 0, 0, 0.4);
    border-bottom: 1px solid rgba(255, 215, 0, 0.08);
    position: relative;
  }

  /* Traffic light dots */
  .terminal-dots {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-shrink: 0;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: block;
  }

  .dot--red    { background-color: #ff5f57; }
  .dot--yellow { background-color: #ffbd2e; }
  .dot--green  { background-color: #28c840; }

  /* Title text */
  .terminal-title {
    flex: 1;
    text-align: center;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #546E7A;
    font-family: ui-monospace, "Cascadia Code", "Fira Code", "JetBrains Mono", Menlo, Monaco, "Courier New", monospace;
    user-select: none;
  }

  /* Body — monospace inside */
  .terminal-body {
    padding: 1.25rem 1.5rem;
    font-family: ui-monospace, "Cascadia Code", "Fira Code", "JetBrains Mono", Menlo, Monaco, "Courier New", monospace;
    font-size: 0.875rem;
    line-height: 1.7;
    color: #e2e8f0;
    position: relative;
    z-index: 1;
  }

  /* Subtle scan-line texture over the body */
  .terminal-body::after {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.04) 2px,
      rgba(0, 0, 0, 0.04) 4px
    );
    pointer-events: none;
    z-index: 0;
  }
</style>
