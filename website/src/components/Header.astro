---
const navLinks = [
  { href: '#hero',     label: 'Home'     },
  { href: '#docs',     label: 'Docs'     },
  { href: '#security', label: 'Security' },
  { href: '#features', label: 'Features' },
  { href: '#about',    label: 'About'    },
];

const githubUrl = 'https://github.com/TheKingHippopotamus/IronDome-Bunker';
---

<header class="site-header" role="banner">

  <!-- Brand -->
  <a href="/IronDome-Bunker/" class="brand" aria-label="IronDome — Home">
    <div class="brand-icon-wrap" aria-hidden="true">
      <img
        src="/IronDome-Bunker/irondome-favicon.svg"
        alt=""
        width="26"
        height="26"
        class="brand-icon"
        aria-hidden="true"
      />
      <span class="brand-corner brand-corner--tl" aria-hidden="true"></span>
      <span class="brand-corner brand-corner--tr" aria-hidden="true"></span>
      <span class="brand-corner brand-corner--bl" aria-hidden="true"></span>
      <span class="brand-corner brand-corner--br" aria-hidden="true"></span>
    </div>
    <div class="brand-text-wrap">
      <span class="brand-name">IRONDOME</span>
      <span class="brand-sub">BUNKER v2.1</span>
    </div>
  </a>

  <!-- Desktop navigation -->
  <nav class="desktop-nav" role="navigation" aria-label="Main navigation">
    <ul class="nav-list" role="list">
      {navLinks.map(link => (
        <li class="nav-item">
          <a href={link.href} class="nav-link">{link.label}</a>
        </li>
      ))}
      <li class="nav-item">
        <a
          href={githubUrl}
          class="nav-link nav-link--github"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub repository"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          GitHub
        </a>
      </li>
    </ul>
  </nav>

  <!-- Right cluster: SYSTEMS ONLINE + hamburger -->
  <div class="header-right">

    <!-- SYSTEMS ONLINE indicator -->
    <div class="systems-status" aria-label="Systems online">
      <span class="status-indicator status-online" aria-hidden="true"></span>
      <span class="systems-status-text">SYSTEMS ONLINE</span>
    </div>

    <!-- Hamburger — aria-expanded toggle, animates to X -->
    <button
      class="nav-hamburger"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="nav-mobile"
      type="button"
    >
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>

  </div>

</header>

<!-- Mobile navigation drawer — slides in from right -->
<nav
  id="nav-mobile"
  class="nav-mobile"
  role="navigation"
  aria-label="Mobile navigation"
>
  <div class="nav-mobile-header" aria-hidden="true">
    <span class="nav-mobile-label">NAVIGATION</span>
    <span class="nav-mobile-divider"></span>
  </div>

  <ul class="nav-mobile-list" role="list">
    {navLinks.map(link => (
      <li>
        <a href={link.href} class="nav-mobile-link drawer-link">{link.label}<span class="nav-mobile-arrow" aria-hidden="true">&rsaquo;</span></a>
      </li>
    ))}
    <li>
      <a
        href={githubUrl}
        class="nav-mobile-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
        <svg class="ext-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/>
        </svg>
      </a>
    </li>
  </ul>

  <div class="nav-mobile-footer" aria-hidden="true">
    <span class="status-indicator status-online"></span>
    <span class="nav-mobile-footer-text">SECURE CONNECTION // ENCRYPTED</span>
  </div>
</nav>

<!-- Overlay — closes drawer on outside click -->
<div class="nav-overlay" aria-hidden="true"></div>

<script>
  const btn = document.querySelector('.nav-hamburger');
  const drawer = document.querySelector('.nav-mobile');
  btn?.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    drawer?.classList.toggle('is-open', !open);
  });

  // Close drawer when a link is clicked
  document.querySelectorAll('.drawer-link').forEach(link => {
    link.addEventListener('click', () => {
      btn?.setAttribute('aria-expanded', 'false');
      drawer?.classList.remove('is-open');
    });
  });

  // Close drawer when overlay is clicked
  document.querySelector('.nav-overlay')?.addEventListener('click', () => {
    btn?.setAttribute('aria-expanded', 'false');
    drawer?.classList.remove('is-open');
  });

  // Update hamburger aria-label for screen readers
  btn?.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
  });
</script>

<style>
  /* ============================================================
     IRONDOME HEADER — v3.0
     Design tokens from global.css design system.
     Military ops feel. 60px height. Sticky.
     ============================================================ */

  /* ── Header shell ──────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 60px;
    padding-inline: clamp(0.75rem, 4vw, 2rem);
    max-width: 100%;
    background: rgba(8, 11, 16, 0.96);
    backdrop-filter: blur(16px) saturate(160%);
    -webkit-backdrop-filter: blur(16px) saturate(160%);
    border-bottom: 1px solid var(--color-olive-border);
    box-shadow: 0 1px 0 rgba(107, 127, 46, 0.06), 0 4px 24px rgba(0, 0, 0, 0.4);
  }

  /* ── Brand ─────────────────────────────────────────────────── */
  .brand {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    flex-shrink: 0;
    color: inherit;
    transition: opacity var(--duration-fast) ease;
  }

  .brand:hover { opacity: 0.82; }

  .brand-icon-wrap {
    position: relative;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(
      135deg,
      var(--color-olive-muted),
      rgba(107, 127, 46, 0.06)
    );
    border: 1px solid var(--color-olive-border);
    border-radius: var(--radius-base);
    flex-shrink: 0;
    color: var(--color-olive-bright);
  }

  .brand-icon {
    width: 22px;
    height: 22px;
    object-fit: contain;
    filter: brightness(0.9) sepia(0.3) hue-rotate(50deg) saturate(1.4);
  }

  /* Corner bracket decorations */
  .brand-corner {
    position: absolute;
    width: 5px;
    height: 5px;
    border-color: var(--color-olive);
    border-style: solid;
    border-width: 0;
    opacity: 0.55;
  }
  .brand-corner--tl { top: -2px;    left: -2px;  border-top-width: 1px;    border-left-width: 1px;  }
  .brand-corner--tr { top: -2px;    right: -2px; border-top-width: 1px;    border-right-width: 1px; }
  .brand-corner--bl { bottom: -2px; left: -2px;  border-bottom-width: 1px; border-left-width: 1px;  }
  .brand-corner--br { bottom: -2px; right: -2px; border-bottom-width: 1px; border-right-width: 1px; }

  .brand-text-wrap {
    display: flex;
    flex-direction: column;
    line-height: 1;
    gap: 0.15rem;
  }

  .brand-name {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-text-primary);
  }

  .brand-sub {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: var(--color-olive-bright);
    opacity: 0.75;
  }

  /* ── Desktop navigation ─────────────────────────────────────── */
  .desktop-nav {
    display: none;
    flex: 1;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .desktop-nav { display: flex; }
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 0.125rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-item { display: flex; }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-base);
    border: 1px solid transparent;
    transition:
      color var(--duration-fast) ease,
      background var(--duration-fast) ease,
      border-color var(--duration-fast) ease;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--color-olive-bright);
    background: var(--color-olive-muted);
    border-color: var(--color-olive-border);
  }

  .nav-link--github {
    color: var(--color-text-muted);
    border-color: var(--color-border-subtle);
  }

  .nav-link--github:hover,
  .nav-link--github:focus-visible {
    color: var(--color-text-primary);
    border-color: var(--color-border-base);
    background: var(--color-bg-raised);
  }

  /* ── Header right cluster ───────────────────────────────────── */
  .header-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  /* ── SYSTEMS ONLINE indicator ──────────────────────────────── */
  .systems-status {
    display: none;
    align-items: center;
    gap: 0.45rem;
  }

  @media (min-width: 640px) {
    .systems-status { display: flex; }
  }

  .systems-status-text {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--color-phosphor);
    opacity: 0.85;
  }

  /* ── Hamburger button ───────────────────────────────────────── */
  .nav-hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 4px;
    width: 36px;
    height: 36px;
    padding: 0;
    background: transparent;
    border: 1px solid var(--color-olive-border);
    border-radius: var(--radius-base);
    cursor: pointer;
    flex-shrink: 0;
    transition: border-color var(--duration-fast) ease, background var(--duration-fast) ease;
  }

  .nav-hamburger:hover,
  .nav-hamburger:focus-visible {
    background: var(--color-olive-muted);
    border-color: var(--color-olive);
  }

  @media (min-width: 768px) {
    .nav-hamburger { display: none; }
  }

  /* Three bars — animate middle bar out + top/bottom rotate to X */
  .hamburger-bar {
    display: block;
    width: 16px;
    height: 1.5px;
    background: var(--color-text-secondary);
    border-radius: 1px;
    transform-origin: center;
    transition:
      transform var(--duration-base) var(--ease-tactical),
      opacity   var(--duration-base) var(--ease-tactical),
      background var(--duration-fast) ease;
  }

  .nav-hamburger:hover .hamburger-bar { background: var(--color-olive-bright); }

  /* When aria-expanded="true" → morph to X */
  .nav-hamburger[aria-expanded="true"] .hamburger-bar:nth-child(1) {
    transform: translateY(5.5px) rotate(45deg);
  }
  .nav-hamburger[aria-expanded="true"] .hamburger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav-hamburger[aria-expanded="true"] .hamburger-bar:nth-child(3) {
    transform: translateY(-5.5px) rotate(-45deg);
  }

  /* ── Mobile drawer ──────────────────────────────────────────── */
  .nav-mobile {
    position: fixed;
    top: 60px;
    right: 0;
    bottom: 0;
    width: min(320px, 88vw);
    z-index: 199;
    background: var(--color-bg-surface);
    border-left: 2px solid var(--color-olive);
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 1.5rem 1rem 1rem;
    overflow-y: auto;
    /* Slide in from right */
    transform: translateX(100%);
    transition: transform var(--duration-slow) var(--ease-tactical);
    /* Hide from AT when closed */
    visibility: hidden;
  }

  .nav-mobile.is-open {
    transform: translateX(0);
    visibility: visible;
  }

  @media (min-width: 768px) {
    /* Drawer is purely mobile; on desktop it never renders visually */
    .nav-mobile { display: none; }
  }

  .nav-mobile-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
  }

  .nav-mobile-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    color: var(--color-olive-bright);
    flex-shrink: 0;
  }

  .nav-mobile-divider {
    flex: 1;
    height: 1px;
    background: var(--color-olive-border);
  }

  .nav-mobile-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .nav-mobile-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-base);
    border: 1px solid transparent;
    transition:
      color var(--duration-fast) ease,
      background var(--duration-fast) ease,
      border-color var(--duration-fast) ease;
  }

  .nav-mobile-link:hover,
  .nav-mobile-link:focus-visible {
    color: var(--color-olive-bright);
    background: var(--color-olive-muted);
    border-color: var(--color-olive-border);
  }

  .nav-mobile-arrow {
    margin-left: auto;
    color: var(--color-olive-border);
    font-size: 1rem;
    line-height: 1;
  }

  .ext-icon {
    flex-shrink: 0;
    opacity: 0.5;
    margin-left: auto;
  }

  .nav-mobile-footer {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--color-olive-border);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-mobile-footer-text {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  /* ── Overlay ────────────────────────────────────────────────── */
  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 198;
    background: rgba(8, 11, 16, 0.6);
    backdrop-filter: blur(2px);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-slow) ease;
  }

  /* Show overlay when drawer is open — JS adds is-open to .nav-mobile;
     we can't CSS-select a sibling from .nav-mobile easily, so JS also
     toggles the overlay directly (see script below). */
</style>

<script>
  /* Overlay sync — runs after the hamburger listener above */
  (() => {
    const overlay = document.querySelector('.nav-overlay') as HTMLElement | null;
    const drawer  = document.querySelector('.nav-mobile')    as HTMLElement | null;

    function syncOverlay() {
      if (!overlay || !drawer) return;
      const open = drawer.classList.contains('is-open');
      overlay.style.opacity        = open ? '1' : '0';
      overlay.style.pointerEvents  = open ? 'auto' : 'none';
    }

    /* Watch for class changes on the drawer */
    if (drawer && overlay) {
      new MutationObserver(syncOverlay).observe(drawer, { attributes: true, attributeFilter: ['class'] });
    }
  })();
</script>
