---
interface Props {
  title: string;
  icon: string; // SVG path data (d attribute value)
  description: string;
}

const { title, icon, description } = Astro.props;
---

<article class="feature-card">
  <div class="feature-card__accent" aria-hidden="true"></div>

  <div class="feature-card__icon" aria-hidden="true">
    <svg
      width="36"
      height="36"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d={icon} />
    </svg>
  </div>

  <h3 class="feature-card__title">{title}</h3>
  <p class="feature-card__desc">{description}</p>

  <div class="feature-card__corner-tl" aria-hidden="true"></div>
  <div class="feature-card__corner-br" aria-hidden="true"></div>
</article>

<style>
  .feature-card {
    position: relative;
    background-color: #0d1117;
    border: 1px solid rgba(255, 215, 0, 0.08);
    border-radius: 2px;
    padding: 1.75rem 1.5rem 1.5rem;
    overflow: hidden;
    transition:
      background-color 250ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 250ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 250ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .feature-card:hover {
    background-color: #111827;
    border-color: rgba(255, 215, 0, 0.18);
    box-shadow:
      0 0 0 1px rgba(255, 215, 0, 0.06),
      0 8px 32px rgba(0, 0, 0, 0.45);
  }

  /* Gold left-border accent — animated on hover */
  .feature-card__accent {
    position: absolute;
    top: 0;
    left: 0;
    width: 2px;
    height: 0%;
    background: linear-gradient(
      180deg,
      rgba(255, 215, 0, 0) 0%,
      #FFD700 40%,
      #FFD700 60%,
      rgba(255, 215, 0, 0) 100%
    );
    transition: height 350ms cubic-bezier(0.16, 1, 0.3, 1);
    border-radius: 0 0 0 0;
  }

  .feature-card:hover .feature-card__accent {
    height: 100%;
  }

  /* Tactical corner decorations */
  .feature-card__corner-tl,
  .feature-card__corner-br {
    position: absolute;
    width: 8px;
    height: 8px;
    border-color: rgba(255, 215, 0, 0.2);
    border-style: solid;
    pointer-events: none;
    transition: border-color 250ms ease;
  }

  .feature-card:hover .feature-card__corner-tl,
  .feature-card:hover .feature-card__corner-br {
    border-color: rgba(255, 215, 0, 0.5);
  }

  .feature-card__corner-tl {
    top: 0;
    left: 0;
    border-width: 1px 0 0 1px;
  }

  .feature-card__corner-br {
    bottom: 0;
    right: 0;
    border-width: 0 1px 1px 0;
  }

  /* Icon */
  .feature-card__icon {
    color: rgba(255, 215, 0, 0.7);
    margin-bottom: 1rem;
    transition: color 250ms ease;
    line-height: 0;
  }

  .feature-card:hover .feature-card__icon {
    color: #FFD700;
  }

  /* Title */
  .feature-card__title {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #FFD700;
    font-family: ui-monospace, "Cascadia Code", "Fira Code", "JetBrains Mono", Menlo, Monaco, "Courier New", monospace;
    margin-bottom: 0.625rem;
    line-height: 1.3;
  }

  /* Description */
  .feature-card__desc {
    font-size: 0.85rem;
    color: #78909C;
    line-height: 1.65;
    margin: 0;
  }
</style>
