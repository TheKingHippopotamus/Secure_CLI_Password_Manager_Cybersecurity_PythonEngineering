---
const year = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <!-- Tactical corner marks -->
  <div class="corner-mark corner-tl" aria-hidden="true"></div>
  <div class="corner-mark corner-tr" aria-hidden="true"></div>
  <div class="corner-mark corner-bl" aria-hidden="true"></div>
  <div class="corner-mark corner-br" aria-hidden="true"></div>

  <!-- Army green top border -->
  <div class="footer-border" aria-hidden="true"></div>

  <!-- Grid coordinate bar -->
  <div class="grid-coord-bar" aria-hidden="true">
    <span class="coord">SECTOR 7G</span>
    <span class="coord-line"></span>
    <span class="coord">BASE OPS // FOOTER ARRAY</span>
    <span class="coord-line"></span>
    <span class="coord">GRID REF 4A-5D-23</span>
  </div>

  <div class="footer-inner">

    <!-- Col 1: Brand -->
    <div class="footer-brand-col">
      <a href="/IronDome-Bunker/" class="footer-logo-link" aria-label="IronDome — Home">
        <div class="footer-logo-wrap">
          <img
            src="/IronDome-Bunker/irondome-favicon.svg"
            alt="IronDome logo"
            width="28"
            height="28"
            aria-hidden="true"
          />
        </div>
        <span class="footer-logo-name">IRONDOME</span>
      </a>

      <p class="footer-tagline">
        <span class="tagline-marker" aria-hidden="true">&gt;&gt;</span>
        Built for the paranoid.
      </p>

      <p class="footer-description">
        Zero-knowledge CLI password vault. AES-256 encryption.
        Your credentials never leave your machine. No server. No sync. No breach.
      </p>

      <!-- Install snippet -->
      <div class="footer-install">
        <span class="install-prompt" aria-hidden="true">$</span>
        <code class="install-cmd">pip install IronDome</code>
      </div>

      <!-- Status indicator -->
      <div class="status-block">
        <span class="status-indicator" aria-hidden="true"></span>
        <span class="status-label">ALL SYSTEMS OPERATIONAL</span>
      </div>
    </div>

