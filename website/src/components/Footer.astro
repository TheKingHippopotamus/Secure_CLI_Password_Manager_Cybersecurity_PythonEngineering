<style>
  /* ============================================================
     IRONDOME FOOTER — MILITARY BASE OPERATIONS THEME
     ============================================================ */

  .site-footer {
    position: relative;
    margin-top: auto;
    background-color: #060A04;
    overflow: hidden;
    /* Subtle camo pattern via radial gradients */
    background-image:
      radial-gradient(ellipse 120px 80px at 15% 30%, rgba(74,93,35,0.06) 0%, transparent 100%),
      radial-gradient(ellipse 100px 120px at 75% 60%, rgba(92,122,41,0.05) 0%, transparent 100%),
      radial-gradient(ellipse 160px 60px at 45% 80%, rgba(74,93,35,0.04) 0%, transparent 100%),
      radial-gradient(ellipse 80px 100px at 90% 15%, rgba(139,154,70,0.03) 0%, transparent 100%),
      radial-gradient(ellipse 140px 90px at 30% 70%, rgba(92,122,41,0.04) 0%, transparent 100%);
  }

  /* ── Tactical corner marks ──────────────────────────────────── */
  .corner-mark {
    position: absolute;
    width: 20px;
    height: 20px;
    z-index: 2;
    pointer-events: none;
  }

  .corner-tl {
    top: 8px;
    left: 8px;
    border-top: 2px solid rgba(0,255,65,0.25);
    border-left: 2px solid rgba(0,255,65,0.25);
  }

  .corner-tr {
    top: 8px;
    right: 8px;
    border-top: 2px solid rgba(0,255,65,0.25);
    border-right: 2px solid rgba(0,255,65,0.25);
  }

  .corner-bl {
    bottom: 8px;
    left: 8px;
    border-bottom: 2px solid rgba(0,255,65,0.25);
    border-left: 2px solid rgba(0,255,65,0.25);
  }

  .corner-br {
    bottom: 8px;
    right: 8px;
    border-bottom: 2px solid rgba(0,255,65,0.25);
    border-right: 2px solid rgba(0,255,65,0.25);
  }

  /* ── Army green top border ──────────────────────────────────── */
  .footer-border {
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(74,93,35,0.15) 5%,
      rgba(92,122,41,0.5) 20%,
      rgba(0,255,65,0.6) 40%,
      #00FF41 50%,
      rgba(0,255,65,0.6) 60%,
      rgba(92,122,41,0.5) 80%,
      rgba(74,93,35,0.15) 95%,
      transparent 100%
    );
    box-shadow: 0 0 12px rgba(0,255,65,0.15), 0 0 4px rgba(0,255,65,0.3);
  }

  /* ── Grid coordinate bar ────────────────────────────────────── */
  .grid-coord-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    max-width: 1200px;
    margin-inline: auto;
    padding: 0.5rem clamp(1rem, 4vw, 2rem);
    border-bottom: 1px solid rgba(74,93,35,0.15);
  }

  .coord {
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: 0.5625rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: #5A6B4A;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .coord-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(74,93,35,0.25), rgba(74,93,35,0.05));
  }

  /* ── Main 4-column grid ─────────────────────────────────────── */
  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 0.8fr 0.9fr 0.9fr;
    gap: 2.5rem;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2rem);
    padding-block: 2.5rem 2rem;
  }

  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 540px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* ── Brand column ───────────────────────────────────────────── */
  .footer-brand-col {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .footer-logo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: inherit;
    width: fit-content;
    transition: opacity 150ms ease;
  }

  .footer-logo-link:hover {
    opacity: 0.85;
    color: inherit;
  }

  .footer-logo-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background-color: rgba(74,93,35,0.12);
    border: 1px solid rgba(0,255,65,0.2);
    border-radius: 2px;
    flex-shrink: 0;
    position: relative;
  }

  .footer-logo-wrap::after {
    content: '';
    position: absolute;
    inset: -2px;
    border: 1px solid rgba(0,255,65,0.06);
    border-radius: 3px;
    pointer-events: none;
  }

  .footer-logo-name {
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    color: #00FF41;
    text-shadow: 0 0 10px rgba(0,255,65,0.35), 0 0 20px rgba(0,255,65,0.1);
  }

  .footer-tagline {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: 0.875rem;
    font-weight: 600;
    color: #C8D4B0;
    margin: 0;
    letter-spacing: 0.02em;
  }

  .tagline-marker {
    color: #00FF41;
    font-size: 0.75rem;
    opacity: 0.6;
  }

  .footer-description {
    font-size: 0.8125rem;
    color: #7A8B6A;
    line-height: 1.7;
    max-width: 32ch;
    margin: 0;
  }

  /* Install command */
  .footer-install {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.875rem;
    background-color: rgba(0,0,0,0.5);
    border: 1px solid rgba(74,93,35,0.25);
    border-left: 2px solid #4A5D23;
    border-radius: 1px;
    width: fit-content;
  }

  .install-prompt {
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: 0.75rem;
    color: rgba(0,255,65,0.4);
    user-select: none;
  }

  .install-cmd {
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: 0.8125rem;
    color: #00FF41;
    user-select: all;
    cursor: text;
  }

  /* Status indicator block */
  .status-block {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .status-indicator {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: #00FF41;
    box-shadow: 0 0 6px rgba(0,255,65,0.6), 0 0 12px rgba(0,255,65,0.2);
    animation: pulse-green 2.5s ease-in-out infinite;
    flex-shrink: 0;
  }

  .status-label {
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: rgba(0,255,65,0.5);
    text-transform: uppercase;
  }

  @keyframes pulse-green {
    0%, 100% { box-shadow: 0 0 4px rgba(0,255,65,0.5); }
    50%      { box-shadow: 0 0 10px rgba(0,255,65,1), 0 0 20px rgba(0,255,65,0.3); }
  }

  /* ── Link columns ───────────────────────────────────────────── */
  .footer-col {
    display: flex;
    flex-direction: column;
  }

  .footer-col-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #8B9A46;
    margin-bottom: 1rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid rgba(74,93,35,0.25);
  }

  .col-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 16px;
    font-size: 0.5625rem;
    font-weight: 800;
    letter-spacing: 0;
    color: #5A6B4A;
    background: rgba(74,93,35,0.12);
    border: 1px solid rgba(74,93,35,0.2);
    border-radius: 1px;
  }

  .footer-link-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-link-list a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: #C8D4B0;
    text-decoration: none;
    transition: color 180ms ease, gap 180ms ease;
    font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
  }

  .footer-link-list a:hover {
    color: #00FF41;
    gap: 0.625rem;
  }

  .link-bullet {
    display: inline-block;
    width: 4px;
    height: 4px;
    background: #5A6B4A;
    border-radius: 1px;
    flex-shrink: 0;
    transition: background 180ms ease, box-shadow 180ms ease;
  }

  .footer-link-list a:hover .link-bullet {
    background: #00FF41;
    box-shadow: 0 0 6px rgba(0,255,65,0.5);
  }

  /* ── Bottom bar ─────────────────────────────────────────────── */
  .footer-bottom {
    border-top: 1px solid rgba(74,93,35,0.2);
    background-color: rgba(0,0,0,0.35);
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2rem);
    padding-block: 1rem;
  }

  .footer-copy {
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: 0.6875rem;
    color: #5A6B4A;
    letter-spacing: 0.03em;
  }

  /* Social icon buttons */
  .footer-socials {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(74,93,35,0.1);
    border: 1px solid rgba(74,93,35,0.3);
    color: #C8D4B0;
    text-decoration: none;
    transition: all 200ms ease;
  }

  .social-btn:hover {
    background: rgba(0,255,65,0.08);
    border-color: rgba(0,255,65,0.4);
    color: #00FF41;
    box-shadow: 0 0 10px rgba(0,255,65,0.15);
    transform: translateY(-1px);
  }

  /* Classification badge */
  .classification-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.625rem;
    background: rgba(74,93,35,0.08);
    border: 1px solid rgba(74,93,35,0.25);
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: #8B9A46;
    text-transform: uppercase;
    border-radius: 1px;
    line-height: 1;
  }

  .class-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #5C7A29;
    box-shadow: 0 0 4px rgba(92,122,41,0.5);
    flex-shrink: 0;
  }

  /* ── Responsive: grid coord bar ─────────────────────────────── */
  @media (max-width: 540px) {
    .grid-coord-bar {
      display: none;
    }

    .footer-bottom-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.75rem;
    }
  }

  @media (max-width: 900px) {
    .coord:nth-child(5) {
      display: none;
    }
    .coord-line:nth-child(4) {
      display: none;
    }
  }
</style>
