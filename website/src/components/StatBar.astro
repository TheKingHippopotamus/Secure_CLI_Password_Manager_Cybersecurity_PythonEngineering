---
interface Stat {
  label: string;
  value: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<div class="stat-bar" role="region" aria-label="Statistics">
  <div class="stat-bar__inner">
    {stats.map((stat, i) => (
      <>
        <div class="stat-bar__item">
          <span class="stat-bar__value">{stat.value}</span>
          <span class="stat-bar__label">{stat.label}</span>
        </div>
        {i < stats.length - 1 && (
          <div class="stat-bar__sep" aria-hidden="true">/</div>
        )}
      </>
    ))}
  </div>
</div>

<style>
  .stat-bar {
    width: 100%;
    border-top: 1px solid rgba(255, 215, 0, 0.18);
    border-bottom: 1px solid rgba(255, 215, 0, 0.18);
    background-color: rgba(13, 17, 23, 0.8);
    padding: 0.75rem 0;
  }

  .stat-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.25rem 0;
    padding-inline: clamp(1rem, 4vw, 2rem);
    max-width: 1200px;
    margin-inline: auto;
  }

  /* Individual stat */
  .stat-bar__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
    padding: 0.375rem 1.25rem;
    flex-shrink: 0;
  }

  .stat-bar__value {
    font-family: ui-monospace, "Cascadia Code", "Fira Code", "JetBrains Mono", Menlo, Monaco, "Courier New", monospace;
    font-size: 1.125rem;
    font-weight: 700;
    color: #FFD700;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  .stat-bar__label {
    font-family: ui-monospace, "Cascadia Code", "Fira Code", "JetBrains Mono", Menlo, Monaco, "Courier New", monospace;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #78909C;
    white-space: nowrap;
  }

  /* Separator */
  .stat-bar__sep {
    font-family: ui-monospace, "Cascadia Code", "Fira Code", "JetBrains Mono", Menlo, Monaco, "Courier New", monospace;
    font-size: 1rem;
    color: rgba(255, 215, 0, 0.2);
    user-select: none;
    flex-shrink: 0;
  }

  /* Mobile: tighten spacing */
  @media (max-width: 480px) {
    .stat-bar__item {
      padding: 0.375rem 0.75rem;
    }

    .stat-bar__value {
      font-size: 1rem;
    }
  }
</style>
