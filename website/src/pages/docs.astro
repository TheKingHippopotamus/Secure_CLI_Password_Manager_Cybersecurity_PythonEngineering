                      'Your vault will be decrypted and re-encrypted with the new credential',
                    ].map((item, i) => (
                      <li style="display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.8125rem; color: var(--color-text-secondary);">
                        <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--color-gold); margin-top: 0.2rem; flex-shrink: 0; width: 1rem;">{i + 1}.</span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </details>

            <!-- Issue 4 -->
            <details class="tactical-card" style="padding: 0; overflow: hidden; cursor: pointer;">
              <summary style="display: flex; align-items: center; gap: 1rem; padding: 1.125rem 1.25rem; cursor: pointer; list-style: none; user-select: none;">
                <span style="width: 1.5rem; height: 1.5rem; background: rgba(255,215,0,0.08); border: 1px solid rgba(255,215,0,0.2); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                  <span style="font-family: var(--font-mono); font-size: 0.6875rem; color: var(--color-gold); font-weight: 700;">?</span>
                </span>
                <span style="font-family: var(--font-mono); font-size: 0.875rem; color: var(--color-text-primary); font-weight: 600; flex: 1;">irondome command not found</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#78909C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;" class="chevron">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </summary>
              <div style="padding: 0 1.25rem 1.25rem; border-top: 1px solid var(--color-gold-border);">
                <div style="padding-top: 1rem; display: flex; flex-direction: column; gap: 0.75rem;">
                  <p style="font-size: 0.8125rem; color: var(--color-text-secondary); line-height: 1.6; margin: 0;">The pip-installed scripts directory may not be in your PATH. Solutions:</p>
                  <div class="code-block" style="font-size: 0.8125rem; white-space: pre; line-height: 1.8;"><span style="color: var(--color-text-muted);"># Verify install location</span>
<span style="color: var(--color-gold-dim);">$ </span>python -m pip show IronDome

<span style="color: var(--color-text-muted);"># Run directly via module</span>
<span style="color: var(--color-gold-dim);">$ </span>python -m irondome create bunker

<span style="color: var(--color-text-muted);"># Add pip scripts to PATH (macOS/Linux)</span>
<span style="color: var(--color-gold-dim);">$ </span>export PATH="$HOME/.local/bin:$PATH"</div>
                </div>
              </div>
            </details>

          </div>
        </div>
      </section>

</Layout>

<!-- Expand/collapse animation for details chevrons -->
<style>
