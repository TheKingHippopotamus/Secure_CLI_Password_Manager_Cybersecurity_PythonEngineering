    [style*="grid-template-columns: repeat(auto-fit"] {
      grid-template-columns: 1fr !important;
    }

    [style*="grid-template-columns: repeat(auto-fill"] {
      grid-template-columns: 1fr !important;
    }

    section { padding-block: 2.5rem !important; }

