---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Field Manual" description="IronDome CLI Password Vault — Field Manual. Full documentation: installation, commands, auth modes, vault structure, and troubleshooting.">

      <!-- ----------------------------------------------------------
           SECTION 1 — PAGE HEADER
           ---------------------------------------------------------- -->
      <section style="padding: 4rem 0 3rem; border-bottom: 1px solid var(--color-gold-border); position: relative; overflow: hidden;">
        <!-- Background grid texture -->
        <div style="position: absolute; inset: 0; background-image: radial-gradient(circle at 20% 50%, rgba(255,215,0,0.03) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(52,211,153,0.025) 0%, transparent 40%); pointer-events: none;"></div>
        <div class="container" style="position: relative; z-index: 1;">
          <div style="margin-bottom: 1rem;">
            <span class="classification-badge">
              <span style="display: inline-block; width: 5px; height: 5px; background: var(--color-gold); border-radius: 50%;"></span>
              Field Manual
            </span>
          </div>
          <h1 class="display-mono" style="font-size: clamp(2.25rem, 5vw, 3.75rem); color: var(--color-text-primary); margin-bottom: 1rem; line-height: 1.05;">
            Documentation
          </h1>
          <p style="font-size: 1.125rem; color: var(--color-text-secondary); max-width: 44rem; line-height: 1.65; margin-bottom: 2rem;">
            Everything you need to deploy IronDome. From first install to daily ops — full command reference, auth modes, vault structure, and troubleshooting protocols.
          </p>
          <!-- Quick jump nav -->
          <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
            {[
              ['#quickstart',   'Quick Start'],
              ['#commands',     'Commands'],
              ['#auth-modes',   'Auth Modes'],
              ['#platforms',    'Platforms'],
              ['#config',       'Config'],
              ['#vault-structure','Vault Files'],
              ['#demo',         'Live Demo'],
              ['#source',       'Source Code'],
              ['#troubleshoot', 'Troubleshooting'],
            ].map(([href, label]) => (
              <a href={href} style="font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-text-secondary); padding: 0.25rem 0.625rem; border: 1px solid var(--color-gold-border); border-radius: var(--radius-sm); transition: color var(--duration-fast) ease, border-color var(--duration-fast) ease;"
                onmouseover="this.style.color='var(--color-gold)';this.style.borderColor='rgba(255,215,0,0.3)'"
                onmouseout="this.style.color='var(--color-text-secondary)';this.style.borderColor='var(--color-gold-border)'">
                {label}
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- ----------------------------------------------------------
           SECTION 2 — QUICK START
           ---------------------------------------------------------- -->
      <section id="quickstart" style="padding: 4rem 0; border-bottom: 1px solid var(--color-gold-border);">
        <div class="container">
          <div style="margin-bottom: 2.5rem;">
            <span class="section-title">01 / Quick Start</span>
            <h2 style="font-size: clamp(1.5rem, 3vw, 2rem); color: var(--color-text-primary); margin-top: 0.5rem;">
              Three Commands to Operational
            </h2>
          </div>

          <!-- Step cards grid -->
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem;">

            <!-- STEP 1 -->
            <div class="tactical-card tactical-corners" style="padding: 1.75rem; position: relative;">
              <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.25rem;">
                <div style="width: 2rem; height: 2rem; background: rgba(255,215,0,0.08); border: 1px solid rgba(255,215,0,0.25); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                  <span style="font-family: var(--font-mono); font-weight: 700; font-size: 0.875rem; color: var(--color-gold);">01</span>
                </div>
                <h3 style="font-size: 1rem; font-weight: 700; color: var(--color-text-primary); letter-spacing: 0.02em;">Install</h3>
              </div>
              <div class="code-block" style="margin-bottom: 1rem;">
                <span style="color: var(--color-gold-dim);">$ </span>pip install IronDome
              </div>
              <p style="font-size: 0.8125rem; color: var(--color-text-secondary); line-height: 1.6;">
                Requires <strong>Python 3.8&ndash;3.13</strong>. That's it. No other dependencies required for core functionality.
              </p>
            </div>

            <!-- STEP 2 -->
            <div class="tactical-card tactical-corners" style="padding: 1.75rem; position: relative;">
              <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.25rem;">
                <div style="width: 2rem; height: 2rem; background: rgba(255,215,0,0.08); border: 1px solid rgba(255,215,0,0.25); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                  <span style="font-family: var(--font-mono); font-weight: 700; font-size: 0.875rem; color: var(--color-gold);">02</span>
                </div>
                <h3 style="font-size: 1rem; font-weight: 700; color: var(--color-text-primary); letter-spacing: 0.02em;">Create Your Bunker</h3>
              </div>
              <div class="code-block" style="margin-bottom: 1rem;">
                <span style="color: var(--color-gold-dim);">$ </span>irondome create bunker
              </div>
              <p style="font-size: 0.8125rem; color: var(--color-text-secondary); line-height: 1.6; margin-bottom: 0.75rem;">
                Follow the prompts to configure your vault:
              </p>
              <ul style="display: flex; flex-direction: column; gap: 0.375rem;">
                {[
                  'Set your master password',
                  'Choose auth mode (biometric, bio+password, password only)',
                  'Generate recovery phrase',
                ].map((item, i) => (
                  <li style="display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.8125rem; color: var(--color-text-secondary);">
                    <span style="color: var(--color-gold); font-family: var(--font-mono); font-size: 0.7rem; margin-top: 0.2rem; flex-shrink: 0;">&gt;</span>
                    <span>{item}{i === 2 ? <span style="color: var(--color-gold); font-family: var(--font-mono); font-size: 0.7rem; margin-left: 0.25rem; font-weight: 700;"> (SAVE THIS!)</span> : ''}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- STEP 3 -->
            <div class="tactical-card tactical-corners" style="padding: 1.75rem; position: relative;">
              <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.25rem;">
                <div style="width: 2rem; height: 2rem; background: rgba(255,215,0,0.08); border: 1px solid rgba(255,215,0,0.25); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                  <span style="font-family: var(--font-mono); font-weight: 700; font-size: 0.875rem; color: var(--color-gold);">03</span>
                </div>
                <h3 style="font-size: 1rem; font-weight: 700; color: var(--color-text-primary); letter-spacing: 0.02em;">Start Using</h3>
              </div>
              <div class="code-block" style="margin-bottom: 1rem; white-space: pre; line-height: 1.8;"><span style="color: var(--color-gold-dim);">$ </span>irondome open airspace    <span style="color: var(--color-text-muted);"># Authenticate</span>
<span style="color: var(--color-gold-dim);">$ </span>bunker create             <span style="color: var(--color-text-muted);"># Add a password</span>
<span style="color: var(--color-gold-dim);">$ </span>bunker open               <span style="color: var(--color-text-muted);"># View passwords</span>
<span style="color: var(--color-gold-dim);">$ </span>bunker fortify            <span style="color: var(--color-text-muted);"># Backup your vault</span></div>
              <p style="font-size: 0.8125rem; color: var(--color-text-secondary); line-height: 1.6;">
                Session persists for <strong>30 minutes</strong>. Re-authenticate anytime with <code style="background: rgba(52,211,153,0.08); color: var(--color-green); padding: 0.1em 0.35em; border-radius: var(--radius-sm); font-size: 0.8em;">irondome open airspace</code>.
              </p>
            </div>

          </div>
        </div>
      </section>

      <!-- ----------------------------------------------------------
           SECTION 3 — COMMAND REFERENCE
           ---------------------------------------------------------- -->
      <section id="commands" style="padding: 4rem 0; border-bottom: 1px solid var(--color-gold-border);">
        <div class="container">
          <div style="margin-bottom: 2.5rem;">
            <span class="section-title">02 / Command Reference</span>
            <h2 style="font-size: clamp(1.5rem, 3vw, 2rem); color: var(--color-text-primary); margin-top: 0.5rem;">
              Full CLI Reference
            </h2>
          </div>

          <!-- System Commands -->
          <div style="margin-bottom: 2.5rem;">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
              <span class="classification-badge--green" style="display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.2rem 0.6rem; background-color: rgba(52,211,153,0.08); border: 1px solid rgba(52,211,153,0.2); color: var(--color-green); font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; border-radius: var(--radius-sm);">System</span>
              <h3 style="font-size: 1rem; color: var(--color-text-primary); font-family: var(--font-mono);">irondome</h3>
            </div>

            <div class="tactical-card" style="overflow: hidden;">
              <!-- Table header -->
              <div style="display: grid; grid-template-columns: 2fr 3fr; gap: 0; border-bottom: 1px solid rgba(255,215,0,0.15); background: rgba(255,215,0,0.04);">
                <div style="padding: 0.625rem 1.25rem; font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-gold);">Command</div>
                <div style="padding: 0.625rem 1.25rem; font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-gold);">Description</div>
              </div>
              <!-- Rows -->
              {[
                ['irondome create bunker', 'First-time vault setup — generates keys, configures auth, saves recovery phrase'],
                ['irondome open airspace',  'Authenticate and start a 30-minute session'],
                ['irondome close airspace', 'Lock everything immediately — terminates session'],
                ['irondome status',         'Display vault health, session state, and configuration info'],
              ].map((row, i) => (
                <div style={`display: grid; grid-template-columns: 2fr 3fr; gap: 0; border-bottom: ${i < 3 ? '1px solid var(--color-gold-border)' : 'none'}; transition: background-color var(--duration-fast) ease;`}
                  onmouseover="this.style.backgroundColor='rgba(255,215,0,0.02)'"
                  onmouseout="this.style.backgroundColor='transparent'">
                  <div style="padding: 0.75rem 1.25rem; font-family: var(--font-mono); font-size: 0.8125rem; color: var(--color-green);">{row[0]}</div>
                  <div style="padding: 0.75rem 1.25rem; font-size: 0.8125rem; color: var(--color-text-secondary);">{row[1]}</div>
                </div>
              ))}
            </div>
          </div>

          <!-- Vault Commands -->
          <div>
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
              <span style="display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.2rem 0.6rem; background-color: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.2); color: #60a5fa; font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; border-radius: var(--radius-sm);">Vault</span>
              <h3 style="font-size: 1rem; color: var(--color-text-primary); font-family: var(--font-mono);">bunker</h3>
            </div>

            <div class="tactical-card" style="overflow: hidden;">
              <!-- Table header -->
              <div style="display: grid; grid-template-columns: 2fr 1.5fr 3fr; gap: 0; border-bottom: 1px solid rgba(255,215,0,0.15); background: rgba(255,215,0,0.04);">
                <div style="padding: 0.625rem 1.25rem; font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-gold);">Command</div>
                <div style="padding: 0.625rem 1.25rem; font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-gold);">Alias</div>
                <div style="padding: 0.625rem 1.25rem; font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-gold);">Description</div>
              </div>
              {[
                ['bunker create',     'bunker -c',     'Add a new password entry to the vault'],
                ['bunker open',       'bunker -o',     'List all stored password entries'],
                ['bunker open [name]','bunker -o [name]','Search for entries matching the given name'],
                ['bunker fortify',    '—',             'Create an encrypted backup of the vault'],
                ['bunker settings',   '—',             'Open preferences — passwords length, timeouts, symbols'],
                ['bunker',            '—',             'Launch interactive 9-option menu'],
              ].map((row, i) => (
                <div style={`display: grid; grid-template-columns: 2fr 1.5fr 3fr; gap: 0; border-bottom: ${i < 5 ? '1px solid var(--color-gold-border)' : 'none'}; transition: background-color var(--duration-fast) ease;`}
                  onmouseover="this.style.backgroundColor='rgba(255,215,0,0.02)'"
                  onmouseout="this.style.backgroundColor='transparent'">
                  <div style="padding: 0.75rem 1.25rem; font-family: var(--font-mono); font-size: 0.8125rem; color: var(--color-green);">{row[0]}</div>
                  <div style="padding: 0.75rem 1.25rem; font-family: var(--font-mono); font-size: 0.8125rem; color: var(--color-text-muted);">{row[1]}</div>
                  <div style="padding: 0.75rem 1.25rem; font-size: 0.8125rem; color: var(--color-text-secondary);">{row[2]}</div>
                </div>
              ))}
            </div>
          </div>

        </div>
      </section>

      <!-- ----------------------------------------------------------
           SECTION 4 — AUTH MODES
           ---------------------------------------------------------- -->
      <section id="auth-modes" style="padding: 4rem 0; border-bottom: 1px solid var(--color-gold-border);">
        <div class="container">
          <div style="margin-bottom: 2.5rem;">
            <span class="section-title">03 / Authentication</span>
            <h2 style="font-size: clamp(1.5rem, 3vw, 2rem); color: var(--color-text-primary); margin-top: 0.5rem;">
              Auth Modes
            </h2>
            <p style="color: var(--color-text-secondary); max-width: 40rem; margin-top: 0.75rem; font-size: 0.9375rem; line-height: 1.65;">
              Choose your authentication posture during setup. You can change it later via <code style="background: rgba(52,211,153,0.08); color: var(--color-green); padding: 0.1em 0.35em; font-size: 0.85em; border-radius: var(--radius-sm);">bunker settings</code>.
            </p>
          </div>

          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(270px, 1fr)); gap: 1.25rem;">

            <!-- Mode 1: Biometric Only -->
            <div class="tactical-card scan-line" style="padding: 1.75rem; position: relative;">
              <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem;">
                <div style="display: flex; align-items: center; gap: 0.625rem;">
                  <div style="width: 2.25rem; height: 2.25rem; border: 1px solid rgba(255,215,0,0.25); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; background: rgba(255,215,0,0.06);">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FFD700" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 2a4 4 0 0 0-4 4v2"/>
                      <path d="M12 2a4 4 0 0 1 4 4v2"/>
                      <path d="M5 10a7 7 0 0 0 14 0"/>
                      <path d="M9 14c.5 1 1.5 2 3 2s2.5-1 3-2"/>
                      <path d="M12 18v3"/>
                      <line x1="8" y1="21" x2="16" y2="21"/>
                    </svg>
                  </div>
                  <span style="font-family: var(--font-mono); font-weight: 700; font-size: 0.8125rem; color: var(--color-text-primary);">Biometric Only</span>
                </div>
                <span style="font-family: var(--font-mono); font-size: 0.625rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted); border: 1px solid var(--color-gold-border); padding: 0.2rem 0.4rem; border-radius: var(--radius-sm);">Mode 1</span>
              </div>
              <ul style="display: flex; flex-direction: column; gap: 0.625rem; margin-bottom: 1.25rem;">
                {[
                  'Cryptographically random vault key stored in OS keychain',
                  'macOS Keychain / Windows Credential Manager / Linux libsecret',
                  'Biometric authentication unlocks the keychain entry',
                  'Fastest login experience — no password to type',
                ].map(item => (
                  <li style="display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.8125rem; color: var(--color-text-secondary); line-height: 1.5;">
                    <span style="color: var(--color-gold); font-family: var(--font-mono); font-size: 0.7rem; margin-top: 0.25rem; flex-shrink: 0;">&gt;</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <div style="padding: 0.625rem 0.875rem; background: rgba(255,215,0,0.04); border: 1px solid rgba(255,215,0,0.1); border-radius: var(--radius-sm);">
                <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-gold-dim); line-height: 1.5;">
                  Recovery requires the 24-word phrase. Store it offline.
                </p>
              </div>
            </div>

            <!-- Mode 2: Biometric + Password -->
            <div class="tactical-card scan-line" style="padding: 1.75rem; position: relative; border-color: rgba(255,215,0,0.15);">
              <!-- Recommended badge -->
              <div style="position: absolute; top: -1px; right: 1rem; background: var(--color-gold); color: #000; font-family: var(--font-mono); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.2rem 0.5rem; border-radius: 0 0 var(--radius-sm) var(--radius-sm);">Recommended</div>
              <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem;">
                <div style="display: flex; align-items: center; gap: 0.625rem;">
                  <div style="width: 2.25rem; height: 2.25rem; border: 1px solid rgba(255,215,0,0.35); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; background: rgba(255,215,0,0.1);">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FFD700" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                      <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                  </div>
                  <span style="font-family: var(--font-mono); font-weight: 700; font-size: 0.8125rem; color: var(--color-text-primary);">Bio + Password</span>
                </div>
                <span style="font-family: var(--font-mono); font-size: 0.625rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-gold); border: 1px solid rgba(255,215,0,0.3); padding: 0.2rem 0.4rem; border-radius: var(--radius-sm);">Mode 2</span>
              </div>
              <ul style="display: flex; flex-direction: column; gap: 0.625rem; margin-bottom: 1.25rem;">
                {[
                  'Biometric is a GATE — you must pass it first',
                  'Password still derives the key via PBKDF2',
                  'Two fully independent factors required',
                  'Most secure configuration available',
                ].map(item => (
                  <li style="display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.8125rem; color: var(--color-text-secondary); line-height: 1.5;">
                    <span style="color: var(--color-gold); font-family: var(--font-mono); font-size: 0.7rem; margin-top: 0.25rem; flex-shrink: 0;">&gt;</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <div style="padding: 0.625rem 0.875rem; background: rgba(52,211,153,0.04); border: 1px solid rgba(52,211,153,0.12); border-radius: var(--radius-sm);">
                <p style="font-family: var(--font-mono); font-size: 0.75rem; color: rgba(52,211,153,0.7); line-height: 1.5;">
                  Compromise of either factor alone is insufficient to unlock.
                </p>
              </div>
            </div>

            <!-- Mode 3: Password Only -->
            <div class="tactical-card scan-line" style="padding: 1.75rem; position: relative;">
              <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem;">
                <div style="display: flex; align-items: center; gap: 0.625rem;">
                  <div style="width: 2.25rem; height: 2.25rem; border: 1px solid rgba(120,144,156,0.3); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; background: rgba(120,144,156,0.06);">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#78909C" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M15 7h3a5 5 0 0 1 5 5 5 5 0 0 1-5 5h-3m-6 0H6a5 5 0 0 1-5-5 5 5 0 0 1 5-5h3"/>
                      <line x1="8" y1="12" x2="16" y2="12"/>
                    </svg>
                  </div>
                  <span style="font-family: var(--font-mono); font-weight: 700; font-size: 0.8125rem; color: var(--color-text-primary);">Password Only</span>
                </div>
                <span style="font-family: var(--font-mono); font-size: 0.625rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted); border: 1px solid var(--color-gold-border); padding: 0.2rem 0.4rem; border-radius: var(--radius-sm);">Mode 3</span>
              </div>
              <ul style="display: flex; flex-direction: column; gap: 0.625rem; margin-bottom: 1.25rem;">
                {[
                  'Traditional approach — master password derives all keys',
                  'Key derivation via PBKDF2 with stored salt',
                  'Works everywhere — no hardware requirements',
                  'Good fallback when biometric hardware unavailable',
                ].map(item => (
                  <li style="display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.8125rem; color: var(--color-text-secondary); line-height: 1.5;">
                    <span style="color: var(--color-text-muted); font-family: var(--font-mono); font-size: 0.7rem; margin-top: 0.25rem; flex-shrink: 0;">&gt;</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <div style="padding: 0.625rem 0.875rem; background: rgba(120,144,156,0.04); border: 1px solid rgba(120,144,156,0.1); border-radius: var(--radius-sm);">
                <p style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-muted); line-height: 1.5;">
                  Security depends entirely on master password strength.
                </p>
              </div>
            </div>

          </div>
        </div>
      </section>

      <!-- ----------------------------------------------------------
           SECTION 5 — PLATFORM SUPPORT
           ---------------------------------------------------------- -->
      <section id="platforms" style="padding: 4rem 0; border-bottom: 1px solid var(--color-gold-border);">
        <div class="container">
          <div style="margin-bottom: 2.5rem;">
            <span class="section-title">04 / Platform Support</span>
            <h2 style="font-size: clamp(1.5rem, 3vw, 2rem); color: var(--color-text-primary); margin-top: 0.5rem;">
              Compatibility Matrix
            </h2>
          </div>

