---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/IronDome-Bunker/irondome-favicon.svg" />
    <link rel="icon" href="/IronDome-Bunker/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/IronDome-Bunker/apple-touch-icon.png" />
    <link rel="manifest" href="/IronDome-Bunker/site.webmanifest" />
    <meta name="theme-color" content="#0A0D06" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Features — IronDome Password Vault</title>
    <meta name="description" content="Every layer of defense, explained. Military-grade AES-256 encryption, zero-knowledge architecture, hardware-bound keys, and biometric authentication." />
    <style>
      :root {
        --bg: #0A0D06;
        --gold: #8B9A46;
        --gold-dim: #6B7A36;
        --card: #0D1208;
        --card-border: #1A2610;
        --text: #e2e8f0;
        --muted: #78909C;
        --green: #34d399;
        --red: #f87171;
        --mono: 'Courier New', 'Lucida Console', monospace;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        background-color: var(--bg);
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        margin: 0;
        padding: 0;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      /* ── Scanline texture overlay ── */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 2px,
          rgba(0, 0, 0, 0.04) 2px,
          rgba(0, 0, 0, 0.04) 4px
        );
        pointer-events: none;
        z-index: 9999;
      }

      /* ── Typography ── */
      .label-gold {
        font-family: var(--mono);
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--gold);
      }

      .label-muted {
        font-family: var(--mono);
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--muted);
      }

      /* ── Section separator ── */
      .sep {
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--gold-dim), transparent);
        margin: 0 auto;
        max-width: 960px;
      }

      /* ── Tactical corner marks ── */
      .corner-mark {
        position: absolute;
        width: 18px;
        height: 18px;
        border-color: var(--gold);
        border-style: solid;
        opacity: 0.55;
      }
      .corner-mark.tl { top: 0; left: 0; border-width: 2px 0 0 2px; }
      .corner-mark.tr { top: 0; right: 0; border-width: 2px 2px 0 0; }
      .corner-mark.bl { bottom: 0; left: 0; border-width: 0 0 2px 2px; }
      .corner-mark.br { bottom: 0; right: 0; border-width: 0 2px 2px 0; }

      /* ── Feature card ── */
      .feat-card {
        background: var(--card);
        border: 1px solid var(--card-border);
        position: relative;
        padding: 2.5rem;
      }

      .feat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, var(--gold), transparent);
      }

      /* ── Terminal block ── */
      .terminal-block {
        background: #060a12;
        border: 1px solid #1A2610;
        border-left: 3px solid var(--gold);
        padding: 1.25rem 1.5rem;
        font-family: var(--mono);
        font-size: 0.8rem;
        line-height: 1.8;
        overflow-x: auto;
        white-space: pre;
        color: var(--green);
      }

      .terminal-block .prompt {
        color: var(--gold);
      }

      .terminal-block .comment {
        color: var(--muted);
      }

      .terminal-block .highlight {
        color: #60a5fa;
      }

      /* ── Biometric grid ── */
      .bio-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-top: 1.5rem;
      }

      .bio-cell {
        background: #060a12;
        border: 1px solid var(--card-border);
        padding: 1.25rem;
        position: relative;
      }

      .bio-cell::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: var(--gold);
        opacity: 0.4;
      }

      .auth-mode-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem;
        margin-top: 1rem;
      }

      .auth-mode-cell {
        background: #060a12;
        border: 1px solid var(--card-border);
        padding: 0.75rem 1rem;
        text-align: center;
        font-family: var(--mono);
        font-size: 0.75rem;
        color: var(--muted);
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      /* ── Comparison table ── */
      .compare-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
      }

      .compare-table th {
        font-family: var(--mono);
        font-size: 0.7rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        padding: 1rem 1.25rem;
        text-align: left;
        border-bottom: 2px solid var(--gold);
        color: var(--gold);
        background: #060a12;
      }

      .compare-table th:nth-child(2) {
        color: var(--green);
        border-bottom-color: var(--green);
      }

      .compare-table th:nth-child(3) {
        color: var(--muted);
        border-bottom-color: var(--muted);
      }

      .compare-table td {
        padding: 0.875rem 1.25rem;
        border-bottom: 1px solid #1A2610;
        color: var(--text);
        vertical-align: middle;
      }

      .compare-table td:first-child {
        font-family: var(--mono);
        font-size: 0.8rem;
        color: var(--muted);
        font-weight: 600;
        letter-spacing: 0.05em;
      }

      .compare-table td:nth-child(2) {
        color: var(--green);
        font-weight: 600;
      }

      .compare-table td:nth-child(3) {
        color: var(--muted);
      }

      .compare-table tr:hover td {
        background: rgba(255, 215, 0, 0.03);
      }

      .compare-table tbody tr:last-child td {
        border-bottom: none;
      }

      /* ── Check / X marks ── */
      .check { color: var(--green); }
      .cross { color: #475569; }
      .warn  { color: #f59e0b; }

      /* ── Install box ── */
      .install-box {
        background: #060a12;
        border: 1px solid var(--gold);
        padding: 1rem 1.5rem;
        font-family: var(--mono);
        font-size: 1rem;
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        max-width: 100%;
      }

      .install-box .pip-prompt {
        color: var(--gold);
        user-select: none;
      }

      .install-box .pip-cmd {
        color: var(--green);
        letter-spacing: 0.02em;
      }

      /* ── Nav ── */
      nav {
        border-bottom: 1px solid #1A2610;
        background: rgba(10, 14, 26, 0.95);
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(8px);
      }

      /* ── Section title ── */
      .section-title {
        font-size: 1.75rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: var(--text);
        margin: 0 0 0.5rem;
      }

      /* ── CTA button ── */
      .btn-primary {
        display: inline-block;
        background: var(--gold);
        color: #0a0e1a;
        font-family: var(--mono);
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        padding: 0.875rem 2rem;
        text-decoration: none;
        clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
        transition: filter 0.15s;
      }

      .btn-primary:hover {
        filter: brightness(1.15);
      }

      .btn-ghost {
        display: inline-block;
        border: 1px solid var(--card-border);
        color: var(--muted);
        font-family: var(--mono);
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding: 0.875rem 2rem;
        text-decoration: none;
        transition: border-color 0.15s, color 0.15s;
      }

      .btn-ghost:hover {
        border-color: var(--gold);
        color: var(--gold);
      }

      /* ── Feature number badge ── */
      .feat-num {
        font-family: var(--mono);
        font-size: 0.65rem;
        letter-spacing: 0.12em;
        color: var(--gold-dim);
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .feat-num::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #1a2332;
      }

      /* ── Responsive layout ── */
      .content-wrap {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      .feat-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0;
      }

      @media (min-width: 768px) {
        .feat-layout-split {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 2rem;
          align-items: start;
        }
      }

      /* ── Scrollbar ── */
      ::-webkit-scrollbar { width: 6px; height: 6px; }
      ::-webkit-scrollbar-track { background: var(--bg); }
      ::-webkit-scrollbar-thumb { background: #1a2332; border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: var(--gold-dim); }
    </style>
  </head>

  <body>

    <!-- ═══════════════════════════════════════════ NAV ═══ -->
    <nav>
      <div class="content-wrap" style="display:flex;align-items:center;justify-content:space-between;padding-top:1rem;padding-bottom:1rem;">
        <a href="/IronDome-Bunker/" style="display:flex;align-items:center;gap:0.75rem;text-decoration:none;">
          <img src="/IronDome-Bunker/irondome-logo.svg" alt="IronDome" height="28" />
          <span style="font-family:var(--mono);font-size:0.85rem;font-weight:700;letter-spacing:0.08em;color:var(--text);">IRONDOME</span>
        </a>
        <div style="display:flex;gap:2rem;align-items:center;">
          <a href="/IronDome-Bunker/" style="font-family:var(--mono);font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);text-decoration:none;">Home</a>
          <a href="/IronDome-Bunker/features" style="font-family:var(--mono);font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--gold);text-decoration:none;border-bottom:1px solid var(--gold);padding-bottom:2px;">Features</a>
          <a href="https://github.com/kinghippo/IronDome" target="_blank" rel="noopener" style="font-family:var(--mono);font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);text-decoration:none;">GitHub</a>
        </div>
      </div>
    </nav>

    <!-- ═══════════════════════════════════════════ PAGE HEADER ═══ -->
    <header style="padding:5rem 0 4rem;background:radial-gradient(ellipse 120% 80% at 50% -20%,rgba(255,215,0,0.06) 0%,transparent 70%);">
      <div class="content-wrap" style="text-align:center;">

        <!-- Classification badge -->
        <div style="display:inline-flex;align-items:center;gap:0.5rem;margin-bottom:2rem;padding:0.4rem 1.25rem;border:1px solid var(--gold);background:rgba(255,215,0,0.06);">
          <span style="display:inline-block;width:6px;height:6px;background:var(--gold);border-radius:50%;animation:pulse 2s ease-in-out infinite;"></span>
          <span class="label-gold">CLASSIFICATION: TACTICAL CAPABILITIES</span>
          <span style="display:inline-block;width:6px;height:6px;background:var(--gold);border-radius:50%;animation:pulse 2s ease-in-out infinite 1s;"></span>
        </div>

        <h1 style="font-size:clamp(2.5rem,6vw,4rem);font-weight:900;letter-spacing:-0.03em;margin:0 0 1rem;color:var(--text);">
          Features
        </h1>

        <p style="font-size:1.15rem;color:var(--muted);max-width:520px;margin:0 auto 2.5rem;">
          Every layer of defense, explained.
        </p>

        <!-- Tactical metrics strip -->
        <div style="display:flex;justify-content:center;gap:0;flex-wrap:wrap;margin-top:2rem;border:1px solid #1A2610;max-width:640px;margin-left:auto;margin-right:auto;">
          <div style="flex:1;min-width:120px;padding:1rem;border-right:1px solid #1A2610;text-align:center;">
            <div style="font-family:var(--mono);font-size:1.5rem;font-weight:900;color:var(--gold);">256</div>
            <div class="label-muted" style="margin-top:0.25rem;">bit AES</div>
          </div>
          <div style="flex:1;min-width:120px;padding:1rem;border-right:1px solid #1A2610;text-align:center;">
            <div style="font-family:var(--mono);font-size:1.5rem;font-weight:900;color:var(--gold);">600K</div>
            <div class="label-muted" style="margin-top:0.25rem;">iterations</div>
          </div>
          <div style="flex:1;min-width:120px;padding:1rem;border-right:1px solid #1A2610;text-align:center;">
            <div style="font-family:var(--mono);font-size:1.5rem;font-weight:900;color:var(--gold);">0</div>
            <div class="label-muted" style="margin-top:0.25rem;">cloud deps</div>
          </div>
          <div style="flex:1;min-width:120px;padding:1rem;text-align:center;">
            <div style="font-family:var(--mono);font-size:1.5rem;font-weight:900;color:var(--gold);">24</div>
            <div class="label-muted" style="margin-top:0.25rem;">word recovery</div>
          </div>
        </div>

      </div>
    </header>

    <div class="sep"></div>

    <!-- ═══════════════════════════════════════════ SECURITY FEATURES ═══ -->
    <section style="padding:5rem 0;">
      <div class="content-wrap">

        <div style="margin-bottom:3rem;">
          <span class="label-gold">SECTION 01</span>
          <h2 class="section-title" style="margin-top:0.5rem;">Security Architecture</h2>
          <p style="color:var(--muted);max-width:520px;margin:0;">
            Eight independent defense layers. Each one would stop an attacker on its own. Together, they are impenetrable.
          </p>
        </div>

        <!-- ── CARD 1: AES-256 Encryption ── -->
        <div class="feat-card" style="margin-bottom:2px;">
          <div class="corner-mark tl"></div>
          <div class="corner-mark tr"></div>
          <div class="corner-mark bl"></div>
          <div class="corner-mark br"></div>

          <div class="feat-num">CAPABILITY-01 / AES-256 ENCRYPTION</div>

          <div style="display:grid;grid-template-columns:1fr;gap:2rem;" class="feat-layout-split-md">
            <div>
              <div style="display:flex;align-items:flex-start;gap:1.5rem;margin-bottom:1.5rem;">
                <img src="/IronDome-Bunker/shield-aes.svg" alt="AES-256" width="64" height="64" style="flex-shrink:0;margin-top:0.25rem;" />
                <div>
                  <h3 style="font-size:1.4rem;font-weight:800;margin:0 0 0.75rem;color:var(--text);">AES-256 Encryption</h3>
                  <p style="color:#94a3b8;margin:0;line-height:1.7;">
                    Military-grade symmetric encryption. Every password entry is encrypted with a unique Fernet key derived from your master password via PBKDF2-HMAC-SHA256 with <strong style="color:var(--gold);">600,000 iterations</strong> — the OWASP 2023 recommended standard. This is not configurable because the right answer is already hardcoded.
                  </p>
                </div>
              </div>

              <div style="margin-top:1.5rem;">
                <div class="label-muted" style="margin-bottom:0.75rem;">ENCRYPTION FLOW</div>
                <div class="terminal-block"><span class="comment"># Step 1: Key derivation (CPU-intensive by design)</span>
<span class="prompt">Master Password</span>  ──→  PBKDF2-HMAC-SHA256
                       └─ <span class="highlight">iterations: 600,000</span>
                       └─ salt: 16-byte random
                       └─ output: 32-byte derived key

<span class="comment"># Step 2: Vault encryption</span>
<span class="prompt">Derived Key</span>  ──→  Fernet(AES-256-CBC + HMAC-SHA256)
               └─ IV: unique per encryption
               └─ authentication tag included
               └─ output: <span class="highlight">Encrypted Vault</span>

<span class="comment"># Final pipeline</span>
Master Password → PBKDF2(600k) → Key → Fernet(AES-256-CBC) → Vault</div>
              </div>
            </div>

            <div style="margin-top:1.5rem;">
              <div class="label-muted" style="margin-bottom:0.75rem;">TECHNICAL SPEC</div>
              <div style="display:grid;gap:0;">
                {[
                  ['Algorithm', 'AES-256-CBC'],
                  ['Mode', 'Fernet (authenticated encryption)'],
                  ['KDF', 'PBKDF2-HMAC-SHA256'],
                  ['Iterations', '600,000 (OWASP 2023)'],
                  ['Salt', '16 bytes, cryptographically random'],
                  ['IV', 'Unique per encryption operation'],
                  ['Authentication', 'HMAC-SHA256 tag on every write'],
                ].map(([k, v]) => (
                  <div style="display:flex;justify-content:space-between;align-items:center;padding:0.625rem 0.875rem;border-bottom:1px solid #1A2610;font-size:0.85rem;">
                    <span style="font-family:var(--mono);color:var(--muted);font-size:0.78rem;">{k}</span>
                    <span style="color:var(--text);text-align:right;font-size:0.82rem;">{v}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- ── CARD 2: Zero Knowledge ── -->
        <div class="feat-card" style="margin-bottom:2px;">
          <div class="corner-mark tl"></div>
          <div class="corner-mark tr"></div>
          <div class="corner-mark bl"></div>
          <div class="corner-mark br"></div>

          <div class="feat-num">CAPABILITY-02 / ZERO KNOWLEDGE ARCHITECTURE</div>

          <div style="display:flex;align-items:flex-start;gap:1.5rem;margin-bottom:1.75rem;">
            <img src="/IronDome-Bunker/shield-zero.svg" alt="Zero Knowledge" width="64" height="64" style="flex-shrink:0;margin-top:0.25rem;" />
            <div>
              <h3 style="font-size:1.4rem;font-weight:800;margin:0 0 0.75rem;color:var(--text);">Zero Knowledge Architecture</h3>
              <p style="color:#94a3b8;margin:0 0 1rem;line-height:1.7;">
                Your master password is <strong style="color:var(--red);">NEVER stored</strong>. Not encrypted. Not hashed for long-term storage. It simply does not exist on disk after your session ends. Only a salted PBKDF2 hash is kept for verification — mathematically sufficient to confirm correctness, impossible to reverse into the original password.
              </p>
              <p style="color:#94a3b8;margin:0;line-height:1.7;">
                If someone steals your vault files — even with the encrypted database, the salt file, and the hardware key — they get nothing usable without your master password, which exists only in your head.
              </p>
            </div>
          </div>

          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1px;background:#1A2610;border:1px solid #1A2610;margin-top:0.5rem;">
            {[
              { label: 'STORED ON DISK', items: ['Encrypted vault entries', 'PBKDF2 verification hash', 'Salt (random, per-vault)', 'Hardware binding artifacts'], bad: false },
              { label: 'NEVER STORED', items: ['Master password (plaintext)', 'Master password (encrypted)', 'Master password (hashed)', 'Derived encryption key'], bad: true },
            ].map(({ label, items, bad }) => (
              <div style={`background:var(--card);padding:1.5rem;${bad ? 'border-left:3px solid var(--red);' : 'border-left:3px solid var(--green);'}`}>
                <div class="label-muted" style={`margin-bottom:0.875rem;color:${bad ? 'var(--red)' : 'var(--green)'};`}>{label}</div>
                {items.map(item => (
                  <div style="display:flex;align-items:center;gap:0.625rem;margin-bottom:0.5rem;font-size:0.875rem;color:#94a3b8;">
                    <span style={`color:${bad ? 'var(--red)' : 'var(--green)'};font-size:1rem;`}>{bad ? '✕' : '✓'}</span>
                    {item}
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>

        <!-- ── CARD 3: Hardware-Bound Keys ── -->
        <div class="feat-card" style="margin-bottom:2px;">
          <div class="corner-mark tl"></div>
          <div class="corner-mark tr"></div>
          <div class="corner-mark bl"></div>
          <div class="corner-mark br"></div>

          <div class="feat-num">CAPABILITY-03 / HARDWARE-BOUND KEYS</div>

          <div style="display:flex;align-items:flex-start;gap:1.5rem;margin-bottom:1.75rem;">
            <img src="/IronDome-Bunker/shield-hardware.svg" alt="Hardware Binding" width="64" height="64" style="flex-shrink:0;margin-top:0.25rem;" />
            <div>
              <h3 style="font-size:1.4rem;font-weight:800;margin:0 0 0.75rem;color:var(--text);">Hardware-Bound Keys</h3>
              <p style="color:#94a3b8;margin:0;line-height:1.7;">
                A system-specific encryption key is derived from your machine's unique identifiers. Even if your encrypted vault file is copied byte-for-byte to another machine, it <strong style="color:var(--gold);">cannot be decrypted</strong>. Your hardware is part of the cryptographic key material. Physical theft of your device (without credentials) yields nothing.
              </p>
            </div>
          </div>

          <div class="terminal-block" style="margin-bottom:1.5rem;"><span class="comment"># Hardware fingerprint derivation</span>
<span class="prompt">Machine ID</span>     ──┐
<span class="prompt">Hostname</span>       ──┼──→  SHA-256 hash  ──→  Base hardware key
<span class="prompt">Device UUID</span>    ──┘      (deterministic,    │
                         no network calls)    │
                                              ↓
                              <span class="highlight">Hardware-Bound Encryption Key</span>
                              (stored in ~/.irondome/hw_key)

<span class="comment"># If vault copied to another machine:</span>
<span class="prompt">Machine ID (different)</span> ──→  different SHA-256  ──→  wrong key  ──→  <span style="color:var(--red);">DECRYPT FAIL</span></div>

          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:0.75rem;">
            {[
              { src: 'linux', label: 'Linux', detail: '/etc/machine-id', icon: '🐧' },
              { src: 'mac', label: 'macOS', detail: 'IOPlatformUUID', icon: '' },
              { src: 'win', label: 'Windows', detail: 'MachineGuid (registry)', icon: '' },
            ].map(({ label, detail }) => (
