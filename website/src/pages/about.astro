---
import Layout from '../layouts/Layout.astro';

const principles = [
  {
    number: '01',
    title: 'Local First',
    icon: 'shield-local',
    body: 'No servers, no sync, no accounts. Your vault lives on your machine and nowhere else. If we get hacked, your passwords are safe — because we don\'t have them.',
  },
  {
    number: '02',
    title: 'Open Source',
    icon: 'shield-zero',
    body: 'Every line of code is auditable. GPL-3.0 licensed. We don\'t hide behind "proprietary encryption" or "trust us" claims. Read the code. Verify the math.',
  },
  {
    number: '03',
    title: 'Standards-Based',
    icon: 'shield-aes',
    body: 'We don\'t invent crypto. We use OWASP-recommended PBKDF2 iteration counts, industry-standard AES-128-CBC via Fernet, and OS-native biometric APIs. No homegrown algorithms.',
  },
  {
    number: '04',
    title: 'Developer-First',
    icon: 'shield-session',
    body: 'IronDome is a CLI tool because developers deserve better than browser extensions. Terminal-native, scriptable, pipe-friendly. Your workflow, your way.',
  },
];

const specs = [
  { label: 'Version',         value: '2.2.1' },
  { label: 'License',         value: 'GPL-3.0' },
  { label: 'Python',          value: '3.8 – 3.13' },
  { label: 'Encryption',      value: 'AES-128-CBC (Fernet)' },
  { label: 'Key Derivation',  value: 'PBKDF2 × 600,000' },
  { label: 'Platforms',       value: 'macOS · Windows · Linux' },
  { label: 'Dependencies',    value: 'cryptography + keyring' },
  { label: 'Network Calls',   value: 'Zero. Ever.' },
];

const links = [
  {
    label: 'GitHub Repository',
    href: 'https://github.com/TheKingHippopotamus/IronDome-Bunker',
    icon: 'github',
    badge: 'Source',
  },
  {
    label: 'PyPI Package',
    href: 'https://pypi.org/project/IronDome/',
    icon: 'pypi',
    badge: 'Install',
  },
  {
    label: 'Security Policy',
    href: 'https://github.com/TheKingHippopotamus/IronDome-Bunker/blob/main/SECURITY.md',
    icon: 'security',
    badge: 'SECURITY.md',
  },
  {
    label: 'Live Demo (Google Colab)',
    href: 'https://colab.research.google.com/github/TheKingHippopotamus/IronDome-Bunker/blob/main/demo.ipynb',
    icon: 'colab',
    badge: 'Interactive',
  },
];

const steps = [
  { n: '01', action: 'Fork the repo', detail: 'github.com/TheKingHippopotamus/IronDome-Bunker' },
  { n: '02', action: 'Create feature branch', detail: 'git checkout -b feat/your-feature' },
  { n: '03', action: 'Follow conventional commits', detail: 'feat: · fix: · docs: · refactor:' },
  { n: '04', action: 'Submit PR', detail: 'Target the main branch with clear description' },
];
---

<Layout
  title="About"
  description="The story behind IronDome — a zero-knowledge CLI password vault built on math, not trust."
>

  <!-- ============================================================
       PAGE HEADER
       ============================================================ -->
  <section class="page-header" aria-labelledby="about-heading">
    <div class="container">
      <div class="page-header-inner">
        <div class="header-meta">
          <span class="classification-badge classification-badge--red">CLASSIFIED</span>
          <span class="classification-badge">PERSONNEL FILE</span>
          <span class="classification-badge classification-badge--green">CLEARANCE GRANTED</span>
        </div>
        <h1 id="about-heading" class="page-title">
          About <span class="title-accent">IronDome</span>
        </h1>
        <p class="page-subtitle">The story behind the vault.</p>
        <div class="page-header-divider" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       MISSION STATEMENT
       ============================================================ -->
  <section class="section" aria-labelledby="mission-heading">
    <div class="container">
      <div class="section-label-row">
        <span class="section-title" id="mission-heading">// MISSION STATEMENT</span>
        <div class="section-line" aria-hidden="true"></div>
      </div>
      <blockquote class="mission-block tactical-corners">
        <div class="mission-gold-bar" aria-hidden="true"></div>
        <div class="mission-content">
          <p class="mission-text">
            IronDome exists because your passwords shouldn't live on someone else's server.
            Every cloud-based password manager asks you to trust their infrastructure,
            their employees, their security practices.
            <strong>IronDome asks you to trust math.</strong>
            AES-128-CBC (Fernet). PBKDF2. Your own machine. That's it.
          </p>
          <div class="mission-sig">
            <span class="mission-sig-text">— Design Principle #1</span>
            <span class="classification-badge">VERIFIED</span>
          </div>
        </div>
      </blockquote>
    </div>
  </section>

  <!-- ============================================================
       PHILOSOPHY — 4 PRINCIPLES
       ============================================================ -->
  <section class="section" aria-labelledby="philosophy-heading">
    <div class="container">
      <div class="section-label-row">
        <span class="section-title" id="philosophy-heading">// OPERATIONAL DOCTRINE</span>
        <div class="section-line" aria-hidden="true"></div>
      </div>
      <h2 class="section-heading">The Philosophy</h2>
      <div class="principles-grid">
        {principles.map((p) => (
          <article class="principle-card tactical-card" aria-labelledby={`principle-${p.number}`}>
            <div class="principle-header">
              <span class="principle-number">{p.number}</span>
              <h3 id={`principle-${p.number}`} class="principle-title">{p.title}</h3>
            </div>
            <p class="principle-body">{p.body}</p>
            <div class="principle-footer" aria-hidden="true">
              <div class="principle-footer-line"></div>
              <span class="principle-status">ACTIVE</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       TECHNICAL STATS — SPEC SHEET
       ============================================================ -->
  <section class="section" aria-labelledby="specs-heading">
    <div class="container">
      <div class="section-label-row">
        <span class="section-title" id="specs-heading">// TECHNICAL SPECIFICATIONS</span>
        <div class="section-line" aria-hidden="true"></div>
      </div>
      <h2 class="section-heading">Spec Sheet</h2>
      <div class="spec-sheet tactical-corners">
        <div class="spec-sheet-header">
          <div class="spec-sheet-title-row">
            <img src="/IronDome-Bunker/irondome-favicon.svg" alt="" width="16" height="16" aria-hidden="true" />
            <span class="spec-sheet-title-text">IRONDOME TECHNICAL DOSSIER — v2.2.1</span>
            <span class="classification-badge">UNCLASSIFIED</span>
          </div>
          <div class="spec-sheet-scan" aria-hidden="true"></div>
        </div>
        <div class="spec-grid" role="list">
          {specs.map((s, i) => (
            <div class="spec-row" role="listitem">
              <span class="spec-index" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <span class="spec-label">{s.label}</span>
              <div class="spec-dots" aria-hidden="true"></div>
              <span class="spec-value">{s.value}</span>
            </div>
          ))}
        </div>
        <div class="spec-sheet-footer">
          <span class="spec-footer-text">DOCUMENT INTEGRITY: VERIFIED · LAST UPDATED: 2025</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       THE CREATOR
       ============================================================ -->
  <section class="section" aria-labelledby="creator-heading">
    <div class="container">
      <div class="section-label-row">
        <span class="section-title" id="creator-heading">// OPERATOR PROFILE</span>
        <div class="section-line" aria-hidden="true"></div>
      </div>
      <h2 class="section-heading">The Creator</h2>
      <div class="creator-card tactical-card tactical-corners">
        <div class="creator-avatar-col">
          <div class="creator-avatar-wrap">
            <img
              src="/IronDome-Bunker/king-hippo.svg"
              alt="King Hippopotamus — Creator of IronDome"
              width="96"
              height="96"
              class="creator-avatar"
            />
            <div class="creator-avatar-ring" aria-hidden="true"></div>
          </div>
          <div class="creator-status-row" aria-label="Status: Active">
            <span class="status-dot-sm" aria-hidden="true"></span>
            <span class="creator-status-text">ACTIVE</span>
          </div>
        </div>
        <div class="creator-info-col">
          <div class="creator-name-row">
            <h3 class="creator-name">King Hippopotamus</h3>
            <span class="classification-badge">CREATOR</span>
          </div>
          <p class="creator-bio">
            Security-focused developer. Built IronDome because every cloud password manager
            is a liability waiting to happen. The vault stays on your machine because that's the
            only machine you can actually trust.
          </p>
          <div class="creator-links">
            <a
              href="https://github.com/TheKingHippopotamus"
              target="_blank"
              rel="noopener noreferrer"
              class="creator-link"
              aria-label="GitHub profile: TheKingHippopotamus"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
              @TheKingHippopotamus
            </a>
            <a
              href="https://pypi.org/user/king.hippo/"
              target="_blank"
              rel="noopener noreferrer"
              class="creator-link"
              aria-label="PyPI profile: king.hippo"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M11.535 0C8.55 0 7.027.984 7.027 2.61v1.696h4.508v.565H4.63C2.982 4.871 1.5 5.937 1.5 9.13c0 3.195 1.767 3.88 3.13 3.88h1.98V11.2c0-1.595 1.38-3.002 3.012-3.002h4.5c1.302 0 2.379-1.071 2.379-2.38V2.61C16.5.986 14.997 0 11.535 0zm-2.49 1.5c.497 0 .9.407.9.91a.906.906 0 0 1-.9.91.906.906 0 0 1-.9-.91c0-.503.403-.91.9-.91zM7.027 5.437h9.473v1.38c0 1.595-1.38 3.002-3.012 3.002h-4.5C7.686 9.819 6.609 10.89 6.609 12.2v2.377c0 1.633 1.5 2.61 3.012 2.61 1.511 0 3.012-.977 3.012-2.61v-1.696H8.125v-.565h7.365c1.648 0 3.012-1.066 3.012-4.26 0-3.192-1.364-3.879-3.012-3.879h-8.46l-.003-.74zM14.966 13.81c.497 0 .9.407.9.91a.906.906 0 0 1-.9.91.906.906 0 0 1-.9-.91c0-.503.403-.91.9-.91z"/>
              </svg>
              king.hippo
            </a>
            <a
              href="https://x.com/LmlyhNyr"
              target="_blank"
              rel="noopener noreferrer"
              class="creator-link"
              aria-label="X (Twitter) profile: LmlyhNyr"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.737l7.73-8.835L1.254 2.25H8.08l4.261 5.633zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
              @LmlyhNyr
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CONTRIBUTING
       ============================================================ -->
  <section class="section" aria-labelledby="contributing-heading">
    <div class="container">
      <div class="section-label-row">
        <span class="section-title" id="contributing-heading">// RECRUITMENT PROTOCOL</span>
        <div class="section-line" aria-hidden="true"></div>
      </div>
      <h2 class="section-heading">Join the Defense Force</h2>
      <div class="contribute-layout">

        <!-- Steps -->
        <div class="contribute-steps">
          <p class="contribute-intro">
            IronDome is open source and welcomes contributors. Here's how to join:
          </p>
          <ol class="steps-list" aria-label="Contribution steps">
            {steps.map((s) => (
              <li class="step-item">
                <span class="step-number" aria-hidden="true">{s.n}</span>
                <div class="step-content">
                  <span class="step-action">{s.action}</span>
                  <code class="step-detail">{s.detail}</code>
                </div>
              </li>
            ))}
          </ol>
          <a
            href="https://github.com/TheKingHippopotamus/IronDome-Bunker/blob/main/CONTRIBUTING.md"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary contribute-cta"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            Read CONTRIBUTING.md
          </a>
        </div>

        <!-- Code guidelines -->
        <div class="code-guidelines tactical-card">
          <div class="code-guidelines-header">
            <span class="section-title">CODE STANDARDS</span>
          </div>
          <ul class="guidelines-list" role="list">
            <li class="guideline-item">
              <span class="guideline-icon" aria-hidden="true">&gt;</span>
              <span>Follow <strong>PEP 8</strong> style conventions</span>
            </li>
            <li class="guideline-item">
              <span class="guideline-icon" aria-hidden="true">&gt;</span>
              <span>Add <strong>type hints</strong> to all function signatures</span>
            </li>
            <li class="guideline-item">
              <span class="guideline-icon" aria-hidden="true">&gt;</span>
              <span>Maintain <strong>Python 3.8+</strong> compatibility</span>
            </li>
            <li class="guideline-item">
              <span class="guideline-icon" aria-hidden="true">&gt;</span>
              <span><strong>Never log</strong> passwords, keys, or sensitive data</span>
            </li>
            <li class="guideline-item">
              <span class="guideline-icon" aria-hidden="true">&gt;</span>
              <span>Write tests for new functionality</span>
            </li>
            <li class="guideline-item">
              <span class="guideline-icon" aria-hidden="true">&gt;</span>
              <span>Keep pull requests focused and atomic</span>
            </li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       LINKS & RESOURCES
       ============================================================ -->
  <section class="section" aria-labelledby="links-heading">
    <div class="container">
      <div class="section-label-row">
        <span class="section-title" id="links-heading">// EXTERNAL RESOURCES</span>
        <div class="section-line" aria-hidden="true"></div>
      </div>
      <h2 class="section-heading">Links</h2>
      <div class="links-grid">
        {links.map((l) => (
          <a
            href={l.href}
            target="_blank"
            rel="noopener noreferrer"
            class="resource-link tactical-card"
            aria-label={`${l.label} — opens in new tab`}
          >
            <div class="resource-link-inner">
              <div class="resource-link-text">
                <span class="resource-link-label">{l.label}</span>
                <span class="resource-link-url">{l.href.replace('https://', '')}</span>
              </div>
              <div class="resource-link-meta">
                <span class="classification-badge classification-badge--green resource-badge">{l.badge}</span>
                <svg class="resource-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       BOTTOM CTA
       ============================================================ -->
  <section class="section section--cta" aria-labelledby="cta-heading">
    <div class="container">
      <div class="cta-block tactical-corners">
        <div class="cta-scan" aria-hidden="true"></div>
        <div class="cta-content">
          <span class="classification-badge classification-badge--green cta-badge">DEPLOYMENT READY</span>
          <h2 id="cta-heading" class="cta-heading">Ready to deploy?</h2>
          <p class="cta-subtext">Install from PyPI. Zero configuration required.</p>
          <div class="code-block cta-code-block" role="region" aria-label="Installation command">
            <span class="terminal-prompt">pip install IronDome</span>
          </div>
          <div class="cta-actions">
            <a
              href="https://pypi.org/project/IronDome/"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary"
              aria-label="Install IronDome from PyPI"
            >
              Install from PyPI
            </a>
            <a
              href="https://github.com/TheKingHippopotamus/IronDome-Bunker"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-secondary"
              aria-label="View IronDome source on GitHub"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
              View on GitHub
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ============================================================
     ABOUT PAGE — SECTION SCAFFOLDING
     ============================================================ */

  .section {
    padding-block: 4rem 3rem;
  }

  .section--cta {
    padding-block: 3rem 5rem;
  }

  .section-label-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .section-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(255, 215, 0, 0.2) 0%,
      transparent 100%
    );
  }

  .section-heading {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: #e8ecf0;
    margin-bottom: 2rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  /* ============================================================
     PAGE HEADER
     ============================================================ */

  .page-header {
    padding-block: 5rem 3rem;
    position: relative;
    overflow: hidden;
  }

  .page-header::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 80% 60% at 50% 100%,
      rgba(255, 215, 0, 0.04) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .page-header-inner {
    max-width: 680px;
  }

  .header-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .page-title {
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #e8ecf0;
    line-height: 1.1;
    margin-bottom: 0.875rem;
  }

  .title-accent {
    color: #FFD700;
    text-shadow: 0 0 20px rgba(255, 215, 0, 0.3);
  }

  .page-subtitle {
    font-size: 1.125rem;
    color: #78909C;
    margin-bottom: 2rem;
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
  }

  .page-header-divider {
    height: 1px;
    max-width: 280px;
    background: linear-gradient(
      90deg,
      rgba(255, 215, 0, 0.5) 0%,
      rgba(255, 215, 0, 0.1) 60%,
      transparent 100%
    );
  }

  /* ============================================================
     MISSION BLOCK
     ============================================================ */

  .mission-block {
    position: relative;
    background-color: rgba(255, 215, 0, 0.03);
    border: 1px solid rgba(255, 215, 0, 0.1);
    border-radius: 2px;
    overflow: hidden;
    margin: 0;
    padding: 2rem 2rem 2rem 2.75rem;
    max-width: 900px;
  }

  .mission-block::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(
      180deg,
      #FFD700 0%,
      rgba(255, 215, 0, 0.4) 100%
    );
  }

  /* Tactical corners on mission block — tighter opacity since it has a gold left bar */
  .mission-block::after {
    content: "";
    position: absolute;
    bottom: 0;
    right: 0;
