            <h2 style="font-size: clamp(1.5rem,3vw,2.25rem);margin-bottom:0.75rem;">Encryption Deep Dive</h2>
            <p style="max-width:560px;">
              Every algorithm chosen for a documented reason. No obscure crypto. No roll-your-own primitives.
            </p>
          </div>

          <div style="display:grid;gap:1.5rem;">

            <!-- PBKDF2 -->
            <div
              class="tactical-card tactical-corners"
              style="padding:2rem 2rem 2rem 1.75rem;border-left:3px solid var(--color-gold);"
            >
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:1.25rem;">
