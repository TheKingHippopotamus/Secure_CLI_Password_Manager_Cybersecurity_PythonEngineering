        <div class="step-card" role="article" aria-label="Step 1: Create Your Bunker">
          <div class="step-num">STEP 01</div>
          <h3 class="step-title">Create Your Bunker</h3>
          <div class="step-terminal" aria-label="Command: irondome create bunker">
            irondome create bunker
          </div>
          <p class="step-desc">
            Bootstraps your encrypted vault. Generates AES-256 key, binds to hardware ID,
            initialises biometric gate. One command, fully armed.
          </p>
        </div>

        <!-- Connector -->
        <div class="step-connector" aria-hidden="true">
          <div style="position:relative;width:100%;height:2px;">
