  <!-- ══ WHY IRONDOME ══════════════════════════════════════════════ -->
  <section class="section" id="why" aria-labelledby="why-title">
    <div class="container">
      <div style="text-align:center;margin-bottom:3.5rem;">
        <div class="section-label">SECURITY DOCTRINE</div>
        <h2 class="section-title" id="why-title">Why IronDome</h2>
        <p class="section-sub" style="margin:0 auto;">
          Built on three unbreakable principles. Every design decision traces back to them.
        </p>
      </div>

      <div class="why-grid">
        <!-- Zero Knowledge -->
        <div class="why-card" role="article" aria-label="Zero Knowledge security">
          <div class="why-icon">
            <img src="/IronDome-Bunker/shield-zero.svg" alt="" aria-hidden="true" width="72" height="72" />
          </div>
          <h3 class="why-title">Zero Knowledge</h3>
          <p class="why-desc">
            Your master password never touches disk. Only a salted PBKDF2 hash — 600,000 rounds —
            is derived in memory and immediately discarded. Even if someone dumps your filesystem,
            there is nothing to find.
          </p>
        </div>

        <!-- Hardware Bound -->
        <div class="why-card" role="article" aria-label="Hardware Binding security">
          <div class="why-icon">
            <img src="/IronDome-Bunker/shield-hardware.svg" alt="" aria-hidden="true" width="72" height="72" />
          </div>
          <h3 class="why-title">Hardware Bound</h3>
          <p class="why-desc">
            Encryption keys are derived from your machine's hardware fingerprint. Steal the vault
            file, copy it anywhere — it's encrypted to hardware it will never be on.
            No hardware, no access. Full stop.
          </p>
        </div>

        <!-- Biometric Shield -->
        <div class="why-card" role="article" aria-label="Biometric Shield security">
          <div class="why-icon">
            <img src="/IronDome-Bunker/shield-brute.svg" alt="" aria-hidden="true" width="72" height="72" />
          </div>
          <h3 class="why-title">Biometric Shield</h3>
          <p class="why-desc">
            Touch ID on macOS. Windows Hello on Win11. Fingerprint auth on Linux via PAM.
            Your body IS the second factor. Three failed attempts
            locks the vault for 60 minutes.
          </p>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

