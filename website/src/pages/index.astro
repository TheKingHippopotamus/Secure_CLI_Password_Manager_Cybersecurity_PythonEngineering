---
import '../styles/global.css';

const GITHUB_URL = 'https://github.com/TheKingHippopotamus/IronDome-Bunker';
const COLAB_URL  = 'https://colab.research.google.com/github/TheKingHippopotamus/IronDome-Bunker/blob/main/demo.ipynb';
const PYPI_URL   = 'https://pypi.org/project/IronDome/';
const PROFILE_URL = 'https://github.com/TheKingHippopotamus';
const X_URL      = 'https://x.com/lmlyhnyr';
const LINKEDIN_URL = 'https://www.linkedin.com/in/kinghippo-a9b1a429b';
const DOCS_URL   = '/IronDome-Bunker/docs';
const FEATURES_URL = '/IronDome-Bunker/features';
const SECURITY_URL = '/IronDome-Bunker/security';
const ABOUT_URL  = '/IronDome-Bunker/about';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />

  <title>IronDome — Zero Knowledge CLI Vault</title>
  <meta name="description" content="Fortified CLI password vault with AES-256 encryption, biometric authentication, and hardware-bound keys. No servers. No cloud. No compromise." />

  <link rel="icon" type="image/svg+xml" href="/IronDome-Bunker/irondome-favicon.svg" />
  <link rel="icon" href="/IronDome-Bunker/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/IronDome-Bunker/apple-touch-icon.png" />
  <link rel="manifest" href="/IronDome-Bunker/site.webmanifest" />
  <meta name="theme-color" content="#0a0e1a" />

  <!-- Preconnect for Google Fonts (military stencil feel) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet" />

  <style>
    /* ─── Design tokens ─────────────────────────────────────── */
    :root {
      --bg:        #0a0e1a;
      --card-bg:   #0d1117;
      --gold:      #8B9A46;
      --gold-dim:  #6B7A36;
      --gold-glow: rgba(139,154,70,0.18);
      --text:      #e2e8f0;
      --muted:     #78909C;
      --muted-dim: #546E7A;
      --green:     #34d399;
      --red:       #f87171;
      --border:    rgba(139,154,70,0.18);
      --max-w:     1100px;
      --font-mono: 'Share Tech Mono', 'Courier New', monospace;
      --font-ui:   'Rajdhani', sans-serif;
      --font-hud:  'Orbitron', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background-color: var(--bg);
      color: var(--text);
      font-family: var(--font-ui);
      font-size: 16px;
      line-height: 1.65;
      overflow-x: hidden;
    }

    /* ─── Scrollbar ─────────────────────────────────────────── */
    ::-webkit-scrollbar              { width: 6px; }
    ::-webkit-scrollbar-track        { background: var(--bg); }
    ::-webkit-scrollbar-thumb        { background: var(--gold-dim); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover  { background: var(--gold); }

    /* ─── Utility ────────────────────────────────────────────── */
    .container {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    .section {
      padding: 6rem 0;
    }

    .section-label {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.25em;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-family: var(--font-hud);
      font-weight: 700;
      font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      color: var(--text);
      margin-bottom: 1rem;
    }

    .section-sub {
      color: var(--muted);
      font-size: 1.05rem;
      max-width: 560px;
    }

    /* ─── Radar animation ────────────────────────────────────── */
    @keyframes radar-sweep {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }

    @keyframes radar-ping {
      0%   { opacity: 0.7; transform: scale(0.95); }
      50%  { opacity: 1;   transform: scale(1.02); }
      100% { opacity: 0.7; transform: scale(0.95); }
    }

    .radar-bg {
      position: absolute;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
    }

    .radar-ring {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      border-radius: 50%;
      border: 1px solid rgba(139,154,70,0.06);
    }

    .radar-sweep-arm {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 50%;
      height: 2px;
      transform-origin: 0% 50%;
      background: linear-gradient(90deg, rgba(139,154,70,0.55), transparent);
      animation: radar-sweep 8s linear infinite;
    }

    .radar-sweep-arm::before {
      content: '';
      position: absolute;
      top: -30px;
      left: 0;
      right: 0;
      height: 60px;
      background: conic-gradient(from 0deg, rgba(139,154,70,0.12), transparent 60deg);
      transform-origin: 0% 50%;
    }

    /* ─── Animated typing (CSS-only) ─────────────────────────── */
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0; }
    }

    .cursor-blink {
      display: inline-block;
      width: 8px;
      height: 1em;
      background: var(--green);
      vertical-align: text-bottom;
      animation: blink 1s step-end infinite;
      margin-left: 2px;
    }

    /* ─── Terminal ────────────────────────────────────────────── */
    .terminal-window {
      background: #0d1117;
      border: 1px solid rgba(139,154,70,0.22);
      border-radius: 10px;
      overflow: hidden;
      position: relative;
    }

    .terminal-titlebar {
      background: #161b22;
      padding: 0.6rem 1rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      border-bottom: 1px solid rgba(139,154,70,0.12);
    }

    .terminal-dots {
      display: flex;
      gap: 6px;
    }

    .terminal-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
    }

    .dot-red    { background: #ff5f57; }
    .dot-yellow { background: #febc2e; }
    .dot-green  { background: #28c840; }

    .terminal-title {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      color: var(--gold);
      flex: 1;
      text-align: center;
    }

    .terminal-body {
      padding: 1.5rem;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      line-height: 1.9;
      color: #c9d1d9;
      overflow-x: auto;
    }

    .t-prompt  { color: var(--green); }
    .t-cmd     { color: #e2e8f0; }
    .t-comment { color: var(--muted); }
    .t-gold    { color: var(--gold); }
    .t-green   { color: var(--green); }
    .t-dim     { color: var(--muted-dim); }
    .t-red     { color: var(--red); }

    /* ─── Cards ──────────────────────────────────────────────── */
    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 2rem;
      transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.2s ease;
      position: relative;
    }

    .card:hover {
      border-color: rgba(139,154,70,0.45);
      box-shadow: 0 0 24px rgba(139,154,70,0.08), 0 4px 24px rgba(0,0,0,0.4);
      transform: translateY(-2px);
    }

    .card-gold-bar::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 3px;
      height: 100%;
      background: var(--gold);
      border-radius: 10px 0 0 10px;
      opacity: 0;
      transition: opacity 0.25s ease;
    }

    .card-gold-bar:hover::before { opacity: 1; }

    /* ─── Install box ─────────────────────────────────────────── */
    .install-box {
      display: inline-flex;
      align-items: center;
      gap: 1rem;
      background: rgba(13, 17, 23, 0.9);
      border: 1px solid rgba(139,154,70,0.3);
      border-radius: 8px;
      padding: 0.75rem 1.25rem;
      font-family: var(--font-mono);
      font-size: 1.05rem;
    }

    .install-box .prompt-symbol {
      color: var(--gold);
      user-select: none;
      font-size: 1.1rem;
    }

    .install-box code {
      color: var(--green);
      letter-spacing: 0.03em;
    }

    .copy-btn {
      background: none;
      border: 1px solid rgba(139,154,70,0.3);
      border-radius: 5px;
      padding: 0.25rem 0.55rem;
      cursor: pointer;
      color: var(--gold);
      font-size: 0.75rem;
      font-family: var(--font-mono);
      transition: background 0.2s, border-color 0.2s;
      white-space: nowrap;
    }

    .copy-btn:hover {
      background: rgba(139,154,70,0.12);
      border-color: var(--gold);
    }

    /* ─── CTAs ────────────────────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.75rem;
      border-radius: 7px;
      font-family: var(--font-hud);
      font-size: 0.9rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      transition: all 0.2s ease;
      cursor: pointer;
    }

    .btn-outline {
      border: 1.5px solid rgba(139,154,70,0.5);
      color: var(--gold);
      background: transparent;
    }

    .btn-outline:hover {
      background: rgba(139,154,70,0.1);
      border-color: var(--gold);
      box-shadow: 0 0 16px rgba(139,154,70,0.15);
    }

    .btn-gold {
      background: linear-gradient(135deg, #8B9A46, #5A6B2A);
      color: #0a0e1a;
      border: none;
      box-shadow: 0 4px 20px rgba(90,107,42,0.35);
    }

    .btn-gold:hover {
      background: linear-gradient(135deg, #A0B050, #6B7A36);
      box-shadow: 0 6px 28px rgba(90,107,42,0.55);
      transform: translateY(-1px);
    }

    /* ─── Why IronDome cards ──────────────────────────────────── */
    .why-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.75rem;
    }

    .why-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2.25rem 2rem;
      text-align: center;
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.2s;
    }

    .why-card:hover {
      border-color: rgba(139,154,70,0.5);
      box-shadow: 0 0 40px rgba(139,154,70,0.07), 0 8px 32px rgba(0,0,0,0.4);
      transform: translateY(-3px);
    }

    .why-icon {
      width: 72px;
      height: 72px;
      margin: 0 auto 1.25rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .why-icon img {
      width: 72px;
      height: 72px;
      object-fit: contain;
    }

    .why-title {
      font-family: var(--font-hud);
      font-weight: 700;
      font-size: 1.15rem;
      color: var(--gold);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 0.75rem;
    }

    .why-desc {
      color: var(--muted);
      font-size: 0.97rem;
      line-height: 1.7;
    }

    /* ─── How It Works ───────────────────────────────────────── */
    .steps-row {
      display: grid;
      grid-template-columns: 1fr 40px 1fr 40px 1fr;
      gap: 0;
      align-items: center;
    }

    @media (max-width: 768px) {
      .steps-row {
        grid-template-columns: 1fr;
        gap: 1rem;
      }
      .step-connector { display: none; }
    }

    .step-connector {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .step-connector-line {
      width: 100%;
      height: 2px;
      border-top: 2px dashed rgba(139,154,70,0.3);
      position: relative;
    }

    .step-connector-arrow {
      color: rgba(139,154,70,0.5);
      font-size: 1.2rem;
      position: absolute;
      right: -6px;
      top: -0.7rem;
    }

    .step-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.75rem;
      position: relative;
    }

    .step-card:hover {
      border-color: rgba(139,154,70,0.45);
      box-shadow: 0 0 28px rgba(139,154,70,0.07);
    }

    .step-num {
      font-family: var(--font-hud);
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      color: var(--gold);
      background: rgba(139,154,70,0.1);
      border: 1px solid rgba(139,154,70,0.25);
      border-radius: 4px;
      padding: 0.15rem 0.5rem;
      display: inline-block;
      margin-bottom: 0.85rem;
    }

    .step-title {
      font-family: var(--font-hud);
      font-weight: 700;
      font-size: 1rem;
      color: var(--text);
      margin-bottom: 0.6rem;
      letter-spacing: 0.04em;
    }

    .step-terminal {
      background: rgba(0,0,0,0.45);
      border: 1px solid rgba(139,154,70,0.1);
      border-radius: 5px;
      padding: 0.6rem 0.85rem;
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: var(--green);
      margin-bottom: 0.85rem;
    }

    .step-desc {
      font-size: 0.88rem;
      color: var(--muted);
      line-height: 1.6;
    }

    /* ─── Features grid ──────────────────────────────────────── */
    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    @media (max-width: 900px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 560px) { .features-grid { grid-template-columns: 1fr; } }

    .feat-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.75rem 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
      transition: all 0.25s ease;
      position: relative;
      overflow: hidden;
    }

    .feat-card::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
      background: var(--gold);
      transform: scaleY(0);
      transition: transform 0.25s ease;
      transform-origin: bottom;
    }

    .feat-card:hover {
      border-color: rgba(139,154,70,0.4);
      box-shadow: 0 0 32px rgba(139,154,70,0.07), 0 4px 20px rgba(0,0,0,0.35);
      transform: translateY(-2px);
    }

    .feat-card:hover::before { transform: scaleY(1); }

    .feat-icon {
      width: 44px;
      height: 44px;
    }

    .feat-icon img {
      width: 44px;
      height: 44px;
      object-fit: contain;
    }

    .feat-title {
      font-family: var(--font-hud);
      font-weight: 700;
      font-size: 0.88rem;
      color: var(--gold);
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .feat-desc {
      font-size: 0.88rem;
      color: var(--muted);
      line-height: 1.65;
    }

    /* ─── Stats bar ──────────────────────────────────────────── */
    .stats-bar {
      border-top: 1px solid rgba(139,154,70,0.15);
      border-bottom: 1px solid rgba(139,154,70,0.15);
      padding: 2rem 0;
      background: rgba(139,154,70,0.02);
    }

    .stats-inner {
      display: flex;
      justify-content: space-around;
      align-items: center;
      flex-wrap: wrap;
      gap: 2rem;
    }

    .stat-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.3rem;
      text-align: center;
    }

    .stat-value {
      font-family: var(--font-hud);
      font-weight: 900;
      font-size: clamp(1.1rem, 2.5vw, 1.4rem);
      color: var(--gold);
      letter-spacing: 0.06em;
    }

    .stat-label {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      color: var(--muted);
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .stat-divider {
      width: 1px;
      height: 40px;
      background: rgba(139,154,70,0.15);
    }

    @media (max-width: 640px) { .stat-divider { display: none; } }

    /* ─── Section divider ────────────────────────────────────── */
    .divider {
      border: none;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(139,154,70,0.2), transparent);
    }

    /* ─── Classified badge ───────────────────────────────────── */
    .classified-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid rgba(139,154,70,0.4);
      border-radius: 3px;
      padding: 0.3rem 0.8rem;
      background: rgba(139,154,70,0.06);
    }

    .classified-badge::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--gold);
      animation: blink 1.5s step-end infinite;
    }

    /* ─── Tagline ─────────────────────────────────────────────── */
    .tagline {
      font-family: var(--font-hud);
      font-weight: 900;
      font-size: clamp(2rem, 5.5vw, 4rem);
      color: var(--text);
      line-height: 1.1;
      letter-spacing: -0.01em;
    }

    .tagline .accent { color: var(--gold); }

    /* ─── Nav ─────────────────────────────────────────────────── */
    .nav-bar {
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 1px solid rgba(139,154,70,0.1);
      background: rgba(10,14,26,0.92);
      backdrop-filter: blur(12px);
    }

    .nav-inner {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 1.5rem;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      text-decoration: none;
    }

    .nav-logo img { height: 32px; }

    .nav-wordmark {
      font-family: var(--font-hud);
      font-weight: 900;
      font-size: 1.05rem;
      letter-spacing: 0.14em;
      color: var(--gold);
      text-transform: uppercase;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      letter-spacing: 0.15em;
      color: var(--muted);
      text-decoration: none;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--gold); }

    /* ─── Hamburger button ──────────────────────────────────────── */
    .mobile-nav-checkbox {
      position: absolute;
      width: 0;
      height: 0;
      opacity: 0;
      pointer-events: none;
    }

    .hamburger-btn {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 5px;
      width: 40px;
      height: 40px;
      cursor: pointer;
      border: 1px solid rgba(139,154,70,0.08);
      border-radius: 6px;
      background: rgba(13,17,23,0.8);
      transition: border-color 0.2s, background 0.2s;
    }

    .hamburger-btn:hover {
      border-color: rgba(139,154,70,0.3);
      background: rgba(139,154,70,0.04);
    }

    .hamburger-bar {
      display: block;
      width: 18px;
      height: 2px;
      background: var(--muted);
      border-radius: 1px;
      transition: transform 0.3s ease, opacity 0.3s ease, background 0.2s;
      transform-origin: center;
    }

    .hamburger-btn:hover .hamburger-bar { background: var(--gold); }

    /* X animation when open */
    .mobile-nav-checkbox:checked ~ nav .hamburger-bar:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
      background: var(--gold);
    }
    .mobile-nav-checkbox:checked ~ nav .hamburger-bar:nth-child(2) {
      opacity: 0;
    }
    .mobile-nav-checkbox:checked ~ nav .hamburger-bar:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
      background: var(--gold);
    }

    @media (min-width: 721px) {
      .hamburger-btn { display: none; }
    }

    @media (max-width: 720px) {
      .nav-links { display: none; }
    }

    /* ─── Mobile drawer ──────────────────────────────────────── */
    .mobile-drawer {
      position: fixed;
      top: 60px;
      right: -100%;
      width: min(260px, 75vw);
      bottom: 0;
      z-index: 99;
      background: rgba(10,14,26,0.98);
      backdrop-filter: blur(20px);
      border-left: 1px solid rgba(139,154,70,0.08);
      transition: right 0.35s cubic-bezier(0.16, 1, 0.3, 1);
      overflow-y: auto;
    }

    .mobile-nav-checkbox:checked ~ .mobile-drawer {
      right: 0;
    }

    .mobile-drawer-inner {
      padding: 0.75rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .mobile-drawer-section {
      display: flex;
      flex-direction: column;
      gap: 1px;
    }

    .mobile-drawer-label {
      font-family: var(--font-mono);
      font-size: 0.55rem;
      font-weight: 700;
      letter-spacing: 0.25em;
      color: var(--gold);
      text-transform: uppercase;
      padding: 0.3rem 0.5rem;
      margin-bottom: 0;
      opacity: 0.7;
    }

    .mobile-drawer-link {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      padding: 0.5rem 0.625rem;
      border-radius: 4px;
      font-family: var(--font-ui);
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--muted);
      text-decoration: none;
      transition: all 0.15s ease;
    }

    .mobile-drawer-link:hover {
      color: var(--gold);
      background: rgba(139,154,70,0.04);
    }

    .mobile-drawer-link svg {
      flex-shrink: 0;
      opacity: 0.6;
    }

    .mobile-drawer-link:hover svg {
      opacity: 1;
      color: var(--gold);
    }

    .mobile-drawer-footer {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 0.625rem;
      border-top: 1px solid rgba(139,154,70,0.06);
      margin-top: 0.25rem;
    }

    .mobile-drawer-badge {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      color: var(--gold);
      opacity: 0.5;
    }

    /* Overlay */
    .mobile-nav-overlay {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 98;
      background: rgba(0,0,0,0.6);
      cursor: pointer;
    }

    .mobile-nav-checkbox:checked ~ .mobile-nav-overlay {
      display: block;
    }

    @media (min-width: 721px) {
      .mobile-nav-checkbox:checked ~ .mobile-drawer { right: -100%; }
      .mobile-nav-checkbox:checked ~ .mobile-nav-overlay { display: none; }
    }

    /* ─── Social icons ───────────────────────────────────────── */
    .social-icons {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      justify-content: center;
    }

    .social-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1px solid rgba(139,154,70,0.12);
      color: var(--muted);
      text-decoration: none;
      transition: all 0.2s ease;
      background: rgba(139,154,70,0.03);
    }

    .social-icon:hover {
      color: var(--gold);
      border-color: rgba(139,154,70,0.5);
      background: rgba(139,154,70,0.08);
      box-shadow: 0 0 16px rgba(139,154,70,0.15);
      transform: translateY(-2px);
    }

    /* ─── Badges section ─────────────────────────────────────── */
    .badges-section {
      padding: 1.5rem 0 0.5rem;
    }

    .badges-row {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      justify-content: center;
      align-items: center;
      line-height: 1;
    }

    .badges-row a,
    .badges-row a img,
    .badges-row > img {
      display: inline-block;
      height: 18px !important;
      width: auto !important;
      max-width: none;
      vertical-align: middle;
    }

    /* ─── Mobile responsive ──────────────────────────────────── */
    @media (max-width: 640px) {
      .section { padding: 3rem 0; }
      .hero { padding: 3rem 1rem 2.5rem; min-height: auto; }
      .hero-content { gap: 1.25rem; }
      .hero-ctas { flex-direction: column; width: 100%; align-items: stretch; }
      .hero-ctas .btn { text-align: center; justify-content: center; }
      .install-box { flex-wrap: wrap; font-size: 0.9rem; padding: 0.6rem 0.875rem; gap: 0.5rem; width: 100%; justify-content: center; }
      .terminal-body { padding: 1rem; font-size: 0.72rem; line-height: 1.7; }
      .terminal-titlebar { padding: 0.5rem 0.75rem; }
      .card { padding: 1.25rem; }
      .why-card { padding: 1.5rem 1.25rem; }
      .step-card { padding: 1.25rem; }
      .feat-card { padding: 1.25rem 1rem; }
      .why-grid { grid-template-columns: 1fr; gap: 1rem; }
      .nav-inner { padding: 0 1rem; height: 52px; }
      .nav-wordmark { font-size: 0.9rem; }
      .stats-inner { gap: 1rem; justify-content: center; }
      .stat-item { min-width: 80px; }
      .container { padding: 0 1rem; }
      .mobile-drawer { top: 52px; }
      .social-icon { width: 36px; height: 36px; }
      .social-icon svg { width: 16px; height: 16px; }
    }

    @media (max-width: 400px) {
      .hero { padding: 2rem 0.75rem 2rem; }
      .section { padding: 2.5rem 0; }
      .terminal-body { font-size: 0.65rem; padding: 0.75rem; }
      .install-box { font-size: 0.8rem; }
      .container { padding: 0 0.75rem; }
    }

    /* ─── Hero ────────────────────────────────────────────────── */
    .hero {
      position: relative;
      min-height: calc(100vh - 60px);
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      overflow: hidden;
      padding: 5rem 1.5rem 4rem;
    }

    .hero-content {
      position: relative;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      max-width: 800px;
    }

    .hero-logo {
      width: clamp(120px, 20vw, 200px);
      height: auto;
      filter: drop-shadow(0 0 32px rgba(139,154,70,0.25));
      animation: radar-ping 4s ease-in-out infinite;
    }

    .hero-subtitle {
      font-size: clamp(1rem, 2vw, 1.15rem);
      color: var(--muted);
      max-width: 600px;
      line-height: 1.7;
    }

    .hero-ctas {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: center;
    }

    /* tactical corners on terminal overlay */
    .tac-corner-tl {
      position: absolute;
      top: 0;
      left: 0;
    }

    .tac-corner-tr {
      position: absolute;
      top: 0;
      right: 0;
      transform: scaleX(-1);
    }

    .tac-corner-bl {
      position: absolute;
      bottom: 0;
      left: 0;
      transform: scaleY(-1);
    }

    .tac-corner-br {
      position: absolute;
      bottom: 0;
      right: 0;
      transform: scale(-1,-1);
    }

    /* ─── Terminal demo typing animation ─────────────────────── */
    /*
      Each line animates in via width + opacity.
      We use a staggered approach: visibility at a given delay.
    */
    .t-line {
      white-space: pre;
      overflow: hidden;
    }

    .t-line-anim {
      opacity: 0;
      animation: fadeInLine 0.15s ease forwards;
    }

    @keyframes fadeInLine {
      from { opacity: 0; transform: translateX(-4px); }
      to   { opacity: 1; transform: translateX(0); }
    }

    /* Delays per line — we have ~20 lines */
    .l0  { animation-delay: 0.2s; }
    .l1  { animation-delay: 0.55s; }
    .l2  { animation-delay: 0.9s; }
    .l3  { animation-delay: 1.15s; }
    .l4  { animation-delay: 1.35s; }
    .l5  { animation-delay: 1.55s; }
    .l6  { animation-delay: 1.75s; }
    .l7  { animation-delay: 2.0s; }
    .l8  { animation-delay: 2.4s; }
    .l9  { animation-delay: 2.7s; }
    .l10 { animation-delay: 2.95s; }
    .l11 { animation-delay: 3.15s; }
    .l12 { animation-delay: 3.35s; }
    .l13 { animation-delay: 3.55s; }
    .l14 { animation-delay: 4.0s; }
    .l15 { animation-delay: 4.25s; }
    .l16 { animation-delay: 4.45s; }
    .l17 { animation-delay: 4.65s; }
    .l18 { animation-delay: 4.85s; }
    .l19 { animation-delay: 5.1s; }
    .l20 { animation-delay: 5.35s; }
    .l21 { animation-delay: 5.55s; }
    .l22 { animation-delay: 5.75s; }
    .l23 { animation-delay: 5.95s; }

    /* ─── Footer ─────────────────────────────────────────────── */
    .footer {
      background: #060a12;
      position: relative;
    }

    .footer-border-top {
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(139,154,70,0.3), transparent);
    }

    .footer-inner {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 3rem 1.5rem 2rem;
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 2rem;
    }

    .footer-brand-col { grid-column: 1; }

    .footer-logo {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 0.75rem;
    }

    .footer-logo img { height: 32px; }

    .footer-wordmark {
      font-family: var(--font-hud);
      font-weight: 900;
      font-size: 1rem;
      letter-spacing: 0.16em;
      color: var(--gold);
    }

    .footer-tagline {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--gold);
      opacity: 0.7;
      margin-bottom: 0.5rem;
    }

    .footer-desc {
      font-size: 0.8rem;
      color: var(--muted-dim);
      line-height: 1.6;
      max-width: 280px;
    }

    .footer-col-title {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 1rem;
      opacity: 0.8;
    }

    .footer-link-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .footer-link-list a {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: var(--muted-dim);
      text-decoration: none;
      transition: color 0.15s;
      letter-spacing: 0.04em;
    }

    .footer-link-list a:hover { color: var(--gold); }

    .footer-bottom {
      border-top: 1px solid rgba(139,154,70,0.06);
      background: rgba(0,0,0,0.3);
    }

    .footer-bottom-inner {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 1.25rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .footer-copy {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      color: var(--muted-dim);
      letter-spacing: 0.06em;
    }

    .footer-social {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .footer-social-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      border: 1px solid rgba(139,154,70,0.08);
      color: var(--muted-dim);
      text-decoration: none;
      transition: all 0.2s;
    }

    .footer-social-icon:hover {
      color: var(--gold);
      border-color: rgba(139,154,70,0.35);
      background: rgba(139,154,70,0.06);
    }

    .footer-author {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      color: var(--muted-dim);
    }

    .footer-author a {
      color: var(--gold);
      text-decoration: none;
      opacity: 0.8;
    }

    .footer-author a:hover { opacity: 1; }

    @media (max-width: 768px) {
      .footer-inner {
        grid-template-columns: 1fr 1fr;
        gap: 2rem 1.5rem;
      }
      .footer-brand-col { grid-column: 1 / -1; }
    }

    @media (max-width: 480px) {
      .footer-inner {
        grid-template-columns: 1fr;
        padding: 2rem 1rem 1.5rem;
      }
      .footer-bottom-inner {
        flex-direction: column;
        text-align: center;
        padding: 1rem;
      }
    }

    /* ─── Warning stripe (decorative) ───────────────────────── */
    .warning-stripe-bar {
      height: 6px;
      background: repeating-linear-gradient(
        -45deg,
        #8B9A46 0px,
        #8B9A46 10px,
        #0d1a08 10px,
        #0d1a08 20px
      );
      opacity: 0.55;
    }

    /* ─── Glow text ──────────────────────────────────────────── */
    .glow-gold {
      text-shadow: 0 0 20px rgba(139,154,70,0.35), 0 0 60px rgba(139,154,70,0.12);
    }
  </style>
</head>

