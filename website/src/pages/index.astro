          <div class="step-num">STEP 03</div>
          <h3 class="step-title">Manage Secrets</h3>
          <div class="step-terminal" aria-label="Commands: bunker create / bunker open">
            bunker create&nbsp;&nbsp;# add new secret<br />
            bunker open&nbsp;&nbsp;&nbsp;# list & retrieve
          </div>
          <p class="step-desc">
            Full CRUD on your passwords. Every read decrypts in memory only.
            Clipboard auto-clears after 30 seconds. Zero persistence.
          </p>
        </div>
