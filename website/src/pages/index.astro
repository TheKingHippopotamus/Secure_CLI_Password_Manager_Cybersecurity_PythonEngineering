  <section class="section" id="features" aria-labelledby="features-title">
    <div class="container">
      <div style="text-align:center;margin-bottom:3.5rem;">
        <div class="section-label">ARSENAL</div>
        <h2 class="section-title" id="features-title">Full Feature Set</h2>
        <p class="section-sub" style="margin:0 auto;">
          Every layer engineered for one mission: your secrets stay secret.
        </p>
      </div>

      <div class="features-grid">
        <!-- AES-256 -->
        <div class="feat-card card-gold-bar" role="article" aria-label="AES-256 Encryption feature">
          <div class="feat-icon">
            <img src="/IronDome-Bunker/shield-aes.svg" alt="" aria-hidden="true" width="44" height="44" />
          </div>
          <div class="feat-title">AES-256 Encryption</div>
          <p class="feat-desc">
            Military-grade symmetric encryption. Every password, every note, every field
            individually encrypted at rest. Fernet-wrapped with a hardware-derived key.
          </p>
        </div>

        <!-- Zero Knowledge -->
        <div class="feat-card card-gold-bar" role="article" aria-label="Zero Knowledge feature">
          <div class="feat-icon">
            <img src="/IronDome-Bunker/shield-zero.svg" alt="" aria-hidden="true" width="44" height="44" />
          </div>
          <div class="feat-title">Zero Knowledge</div>
          <p class="feat-desc">
            Master password never stored, never logged, never transmitted.
            PBKDF2 with SHA-256, 600,000 rounds, random 32-byte salt.
            You hold the only key.
          </p>
        </div>

        <!-- Hardware Binding -->
        <div class="feat-card card-gold-bar" role="article" aria-label="Hardware Binding feature">
          <div class="feat-icon">
            <img src="/IronDome-Bunker/shield-hardware.svg" alt="" aria-hidden="true" width="44" height="44" />
          </div>
          <div class="feat-title">Hardware Binding</div>
          <p class="feat-desc">
            CPU serial, motherboard UUID, MAC address — hashed together into a hardware
            fingerprint that seeds your encryption key. Vault is cryptographically
            chained to this machine.
          </p>
        </div>

        <!-- Session Management -->
        <div class="feat-card card-gold-bar" role="article" aria-label="Session Management feature">
          <div class="feat-icon">
            <img src="/IronDome-Bunker/shield-session.svg" alt="" aria-hidden="true" width="44" height="44" />
          </div>
          <div class="feat-title">Session Management</div>
          <p class="feat-desc">
            Authenticated sessions expire automatically. Inactivity timeout. Manual lockout.
            Session token held in memory, never in /tmp or any disk path.
            Clean shutdown wipes it.
          </p>
        </div>

        <!-- Brute Force Protection -->
        <div class="feat-card card-gold-bar" role="article" aria-label="Brute Force Protection feature">
          <div class="feat-icon">
            <img src="/IronDome-Bunker/shield-brute.svg" alt="" aria-hidden="true" width="44" height="44" />
          </div>
          <div class="feat-title">Brute Force Protection</div>
          <p class="feat-desc">
            3 failed attempts triggers a 60-minute lockout with exponential back-off.
            10 failures triggers permanent vault seal requiring hardware re-verification.
            Logged with timestamps.
          </p>
        </div>

        <!-- Local Only -->
        <div class="feat-card card-gold-bar" role="article" aria-label="Local Only feature">
          <div class="feat-icon">
            <img src="/IronDome-Bunker/shield-local.svg" alt="" aria-hidden="true" width="44" height="44" />
          </div>
          <div class="feat-title">Local Only</div>
          <p class="feat-desc">
            Fully air-gapped. Zero network calls. No telemetry, no update pings,
            no license servers. Works offline, in a Faraday cage, on a submarine.
            Your data never leaves your machine.
          </p>
        </div>
      </div>
    </div>
