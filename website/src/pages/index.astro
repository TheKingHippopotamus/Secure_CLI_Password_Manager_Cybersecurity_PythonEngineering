          </div>
        </div>

        <!-- Step 2 -->
        <div class="step-card" role="article" aria-label="Step 2: Open Airspace">
          <div class="step-num">STEP 02</div>
          <h3 class="step-title">Open Airspace</h3>
          <div class="step-terminal" aria-label="Command: irondome open airspace">
            irondome open airspace
          </div>
          <p class="step-desc">
            Authenticate with biometrics + master password. A temporary session token is issued.
            Expires in 30 minutes. Nothing written to disk.
          </p>
        </div>

        <!-- Connector -->
        <div class="step-connector" aria-hidden="true">
          <div style="position:relative;width:100%;height:2px;">
            <div class="step-connector-line"></div>
            <span class="step-connector-arrow" style="position:absolute;right:-4px;top:-11px;">&#9658;</span>
