---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import BadgesStats from '../components/sections/BadgesStats.astro';
import WhyIronDome from '../components/sections/WhyIronDome.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import FeaturesGrid from '../components/sections/FeaturesGrid.astro';
import TerminalDemo from '../components/sections/TerminalDemo.astro';
import SecurityArch from '../components/sections/SecurityArch.astro';
import CryptoPrimitives from '../components/sections/CryptoPrimitives.astro';
import ThreatModel from '../components/sections/ThreatModel.astro';
import FileSystem from '../components/sections/FileSystem.astro';
import Comparison from '../components/sections/Comparison.astro';
import Philosophy from '../components/sections/Philosophy.astro';
import QuickStart from '../components/sections/QuickStart.astro';
import About from '../components/sections/About.astro';
import Troubleshooting from '../components/sections/Troubleshooting.astro';
import Disclosure from '../components/sections/Disclosure.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
---

<Layout
  title="IronDome"
  description="Zero-knowledge CLI password vault with AES-256 encryption, biometric authentication, and hardware-bound keys. No servers. No cloud. No compromise."
>

  <!-- ═══════════════════════════════════════════════════════════════
       THE PSYCHOLOGICAL FUNNEL
       ═══════════════════════════════════════════════════════════════
       1. HOOK        — Hero creates intrigue, identity, and awe
       2. CREDIBILITY — Badges & stats build instant social proof
       3. TRUST       — Three unbreakable security pillars
       4. SIMPLICITY  — Just 3 steps to get started
       5. BREADTH     — 8 independent defense layers
       6. PROOF       — Live terminal demo shows it's real
       7. DEPTH       — Full security architecture diagram
       8. MATH        — Real crypto code and specifications
       9. DEFENSE     — Every attack vector addressed
       10. TRANSPARENCY — What's actually on disk
       11. DIFFERENTIATION — Why IronDome beats cloud managers
       12. VALUES     — Security principles create emotional alignment
       13. ACTION     — Quick start docs make it actionable
       14. HUMAN      — Creator profile builds personal connection
       15. SUPPORT    — Troubleshooting reduces adoption friction
       16. PROFESSIONAL — Vulnerability disclosure shows maturity
       17. CLOSE      — Confident CTA to audit and install
       ═══════════════════════════════════════════════════════════════ -->

  <!-- 1. HOOK -->
  <Hero />

  <!-- 2. CREDIBILITY -->
