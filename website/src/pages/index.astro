  <!-- ══ SCRIPTS ═════════════════════════════════════════════════ -->
  <script>
    // Copy install command
    const copyBtn = document.getElementById('copy-install') as HTMLButtonElement | null;
    const installCmd = document.getElementById('install-cmd') as HTMLElement | null;

    if (copyBtn && installCmd) {
      copyBtn.addEventListener('click', async () => {
        const text = installCmd.textContent ?? 'pip install IronDome';
        try {
          await navigator.clipboard.writeText(text);
          const original = copyBtn.textContent;
          copyBtn.textContent = 'COPIED!';
          copyBtn.style.color = 'var(--green)';
          copyBtn.style.borderColor = 'var(--green)';
          setTimeout(() => {
            copyBtn.textContent = original;
            copyBtn.style.color = '';
            copyBtn.style.borderColor = '';
          }, 2000);
        } catch {
          // Fallback for browsers without clipboard API
          const range = document.createRange();
          range.selectNodeContents(installCmd);
          const sel = window.getSelection();
          if (sel) {
            sel.removeAllRanges();
            sel.addRange(range);
          }
        }
      });
    }

    // Replay terminal animation when it scrolls into view
    const terminalBody = document.querySelector('.terminal-body') as HTMLElement | null;
    if (terminalBody) {
      const lines = terminalBody.querySelectorAll<HTMLElement>('.t-line-anim');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            // Reset and replay
            lines.forEach(line => {
              line.style.animationName = 'none';
            });
            // Force reflow
            void terminalBody.offsetHeight;
            lines.forEach(line => {
              line.style.animationName = '';
            });
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });
      observer.observe(terminalBody);
    }
  </script>

<script>if('serviceWorker' in navigator){navigator.serviceWorker.register('/IronDome-Bunker/sw.js').catch(()=>{})}</script>
