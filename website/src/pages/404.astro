---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 — Sector Not Found"
  description="The coordinates you entered don't match any known bunker. Return to base and try again."
>
  <section class="error-shell" aria-labelledby="error-heading">

    <!-- Topographic grid background -->
    <div class="topo-grid" aria-hidden="true"></div>

    <!-- Scan line overlay -->
    <div class="scanlines" aria-hidden="true"></div>

    <!-- Static flicker overlay -->
    <div class="static-flicker" aria-hidden="true"></div>

    <!-- Radar animation background -->
    <div class="radar-wrap" aria-hidden="true">
      <div class="radar-ring radar-ring--1"></div>
      <div class="radar-ring radar-ring--2"></div>
      <div class="radar-ring radar-ring--3"></div>
      <div class="radar-ring radar-ring--4"></div>
      <div class="radar-sweep"></div>
      <div class="radar-crosshair radar-crosshair--h"></div>
      <div class="radar-crosshair radar-crosshair--v"></div>
      <!-- Blip dots -->
      <div class="radar-blip radar-blip--1"></div>
      <div class="radar-blip radar-blip--2"></div>
      <div class="radar-blip radar-blip--3"></div>
    </div>

    <!-- Crosshair overlay -->
    <div class="crosshair-overlay" aria-hidden="true">
      <div class="crosshair-h"></div>
      <div class="crosshair-v"></div>
      <div class="crosshair-center"></div>
    </div>

    <!-- Corner brackets (tactical dressing) -->
    <div class="corner corner--tl" aria-hidden="true"></div>
    <div class="corner corner--tr" aria-hidden="true"></div>
    <div class="corner corner--bl" aria-hidden="true"></div>
    <div class="corner corner--br" aria-hidden="true"></div>

    <!-- Main content -->
    <div class="error-content">

      <!-- Classification badge -->
      <div class="badge-row">
        <span class="class-badge" aria-label="Classification level">
          &#9608; UNCLASSIFIED &#9608;
        </span>
      </div>

      <!-- Signal lost indicator -->
      <div class="signal-lost" aria-hidden="true">
        <span class="signal-icon">&#9632;</span>
        <span class="signal-text">SIGNAL LOST</span>
        <span class="signal-icon">&#9632;</span>
      </div>

      <!-- Big 404 -->
      <div class="four-oh-four" aria-hidden="true">
        <span class="four-char">4</span><span class="zero-char">0</span><span class="four-char">4</span>
      </div>

      <!-- Heading -->
      <h1 class="error-heading" id="error-heading">SECTOR NOT FOUND</h1>

      <!-- Description -->
      <p class="error-description">
        The coordinates you entered don't match any known bunker.<br />
        Return to base for reassignment.
      </p>

      <!-- Diagnostic readout -->
      <div class="diagnostic" aria-label="Status readout">
        <div class="diagnostic-header">
          <span class="diag-header-text">&#9654; FIELD INTELLIGENCE REPORT</span>
          <span class="diag-header-line"></span>
        </div>
        <div class="diagnostic-row">
          <span class="diag-label">SIGNAL</span>
          <span class="diag-dots"></span>
          <span class="diag-value diag-value--red">LOST</span>
        </div>
        <div class="diagnostic-row">
          <span class="diag-label">COORDINATES</span>
          <span class="diag-dots"></span>
          <span class="diag-value diag-value--red">INVALID</span>
        </div>
        <div class="diagnostic-row">
          <span class="diag-label">SECTOR STATUS</span>
          <span class="diag-dots"></span>
          <span class="diag-value diag-value--muted">UNCHARTED</span>
        </div>
        <div class="diagnostic-row">
          <span class="diag-label">THREAT LEVEL</span>
          <span class="diag-dots"></span>
          <span class="diag-value diag-value--olive">UNKNOWN</span>
        </div>
        <div class="diagnostic-row">
          <span class="diag-label">RECOMMENDATION</span>
          <span class="diag-dots"></span>
          <span class="diag-value diag-value--green">RETURN TO BASE</span>
        </div>
      </div>

      <!-- CTA -->
      <div class="cta-row">
        <a href="/IronDome-Bunker/" class="return-btn" aria-label="Return to IronDome home">
          <span class="btn-bracket">[</span>
          <svg class="btn-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          RETURN TO BASE
          <span class="btn-bracket">]</span>
        </a>
      </div>

      <!-- Footer classification line -->
      <p class="footer-class" aria-hidden="true">
        IRONDOME DEFENSE SYSTEMS &mdash; TACTICAL NETWORK &mdash; SECTOR 404
      </p>

    </div>
  </section>
</Layout>

<style>
  /* ============================================================
     404 PAGE — MILITARY COMMUNICATIONS FAILURE
     Army Olive / Night Vision Green Theme
     ============================================================ */

  .error-shell {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 128px);
    background-color: #0A0D06;
    overflow: hidden;
    padding: clamp(2rem, 6vw, 4rem) clamp(1rem, 4vw, 2rem);
  }

  /* ── Topographic grid background ───────────────────────── */
  .topo-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(74, 93, 35, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(74, 93, 35, 0.06) 1px, transparent 1px),
      linear-gradient(rgba(74, 93, 35, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(74, 93, 35, 0.03) 1px, transparent 1px);
    background-size:
      100px 100px,
      100px 100px,
      20px 20px,
      20px 20px;
    pointer-events: none;
  }

  /* ── Scan lines ────────────────────────────────────────── */
  .scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 255, 65, 0.015) 2px,
      rgba(0, 255, 65, 0.015) 4px
    );
    pointer-events: none;
    z-index: 3;
  }

  /* ── Static flicker ────────────────────────────────────── */
  .static-flicker {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 4;
    opacity: 0;
    background: rgba(0, 255, 65, 0.03);
    animation: static-flash 8s ease-in-out infinite;
  }

  @keyframes static-flash {
    0%, 100% { opacity: 0; }
    47% { opacity: 0; }
    47.5% { opacity: 1; }
    48% { opacity: 0; }
    48.5% { opacity: 0.5; }
    49% { opacity: 0; }
    92% { opacity: 0; }
    92.3% { opacity: 0.7; }
    92.6% { opacity: 0; }
  }

  /* ── Radar background ──────────────────────────────────── */
  .radar-wrap {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0.22;
  }

  .radar-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(92, 122, 41, 0.5);
  }

  .radar-ring--1 {
    width: min(600px, 90vw);
    height: min(600px, 90vw);
    border-color: rgba(92, 122, 41, 0.3);
  }

  .radar-ring--2 {
    width: min(440px, 68vw);
    height: min(440px, 68vw);
  }

  .radar-ring--3 {
    width: min(280px, 44vw);
    height: min(280px, 44vw);
  }

  .radar-ring--4 {
    width: min(120px, 20vw);
    height: min(120px, 20vw);
    border-color: rgba(92, 122, 41, 0.7);
  }

  .radar-sweep {
    position: absolute;
    width: min(600px, 90vw);
    height: min(600px, 90vw);
    border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      transparent 0deg,
      transparent 310deg,
      rgba(74, 93, 35, 0.05) 330deg,
      rgba(0, 255, 65, 0.12) 350deg,
      rgba(92, 122, 41, 0.2) 358deg,
      rgba(0, 255, 65, 0.03) 360deg
    );
    animation: radar-sweep 4s linear infinite;
    transform-origin: center center;
  }

  @keyframes radar-sweep {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  .radar-crosshair--h,
  .radar-crosshair--v {
    position: absolute;
    background-color: rgba(92, 122, 41, 0.35);
  }

  .radar-crosshair--h {
    width: min(620px, 94vw);
    height: 1px;
  }

  .radar-crosshair--v {
    width: 1px;
    height: min(620px, 94vw);
  }

  /* Blip dots */
  .radar-blip {
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: #00FF41;
    box-shadow: 0 0 6px rgba(0, 255, 65, 0.8), 0 0 12px rgba(0, 255, 65, 0.4);
    animation: blip-flash 4s ease-in-out infinite;
  }

  .radar-blip--1 {
    --tx: 70px;
    --ty: -90px;
    transform: translate(70px, -90px);
    animation-delay: 0.8s;
  }

  .radar-blip--2 {
    --tx: -110px;
    --ty: 50px;
    transform: translate(-110px, 50px);
    animation-delay: 2.2s;
  }

  .radar-blip--3 {
    --tx: 40px;
    --ty: 120px;
    transform: translate(40px, 120px);
    animation-delay: 3.5s;
  }

  @keyframes blip-flash {
    0%   { opacity: 0; transform: translate(var(--tx), var(--ty)) scale(0.3); }
    10%  { opacity: 1; transform: translate(var(--tx), var(--ty)) scale(1.2); }
    20%  { opacity: 1; transform: translate(var(--tx), var(--ty)) scale(1); }
    60%  { opacity: 0.6; }
    100% { opacity: 0; }
  }

  /* ── Crosshair overlay ─────────────────────────────────── */
  .crosshair-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
    opacity: 0.12;
  }

  .crosshair-h {
    position: absolute;
    width: 100%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(0, 255, 65, 0.4) 30%,
      rgba(0, 255, 65, 0.8) 48%,
      transparent 50%,
      rgba(0, 255, 65, 0.8) 52%,
      rgba(0, 255, 65, 0.4) 70%,
      transparent 100%
    );
  }

  .crosshair-v {
    position: absolute;
    width: 1px;
    height: 100%;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(0, 255, 65, 0.4) 30%,
      rgba(0, 255, 65, 0.8) 48%,
      transparent 50%,
      rgba(0, 255, 65, 0.8) 52%,
      rgba(0, 255, 65, 0.4) 70%,
      transparent 100%
    );
  }

  .crosshair-center {
    position: absolute;
    width: 8px;
    height: 8px;
    border: 1px solid rgba(0, 255, 65, 0.6);
    border-radius: 50%;
  }

  /* ── Corner brackets ───────────────────────────────────── */
  .corner {
    position: absolute;
    width: 32px;
    height: 32px;
    pointer-events: none;
    z-index: 2;
  }

  .corner--tl {
    top: 1.5rem;
    left: 1.5rem;
    border-top: 2px solid rgba(92, 122, 41, 0.5);
    border-left: 2px solid rgba(92, 122, 41, 0.5);
  }

  .corner--tr {
    top: 1.5rem;
    right: 1.5rem;
    border-top: 2px solid rgba(92, 122, 41, 0.5);
    border-right: 2px solid rgba(92, 122, 41, 0.5);
  }

  .corner--bl {
    bottom: 1.5rem;
    left: 1.5rem;
    border-bottom: 2px solid rgba(92, 122, 41, 0.5);
    border-left: 2px solid rgba(92, 122, 41, 0.5);
  }

  .corner--br {
    bottom: 1.5rem;
    right: 1.5rem;
    border-bottom: 2px solid rgba(92, 122, 41, 0.5);
    border-right: 2px solid rgba(92, 122, 41, 0.5);
  }

  /* ── Content ───────────────────────────────────────────── */
  .error-content {
    position: relative;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
    max-width: 680px;
    width: 100%;
  }

  /* Classification badge */
  .badge-row {
    display: flex;
    justify-content: center;
  }

  .class-badge {
    display: inline-block;
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #8B9A46;
    border: 1px solid rgba(74, 93, 35, 0.4);
    padding: 0.35rem 1rem;
    border-radius: 1px;
    background-color: rgba(74, 93, 35, 0.08);
  }

  /* Signal lost indicator */
  .signal-lost {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #8B2500;
    text-shadow: 0 0 10px rgba(139, 37, 0, 0.6);
    animation: signal-pulse 1.5s ease-in-out infinite;
  }

  .signal-icon {
    font-size: 0.4rem;
    animation: signal-blink 0.8s step-end infinite;
  }

  @keyframes signal-pulse {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.4; }
  }

  @keyframes signal-blink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0; }
  }

  /* Big 404 number */
  .four-oh-four {
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: clamp(5.5rem, 20vw, 11rem);
    font-weight: 900;
    letter-spacing: 0.08em;
    line-height: 1;
    color: #00FF41;
    text-shadow:
      0 0 20px rgba(0, 255, 65, 0.6),
      0 0 40px rgba(0, 255, 65, 0.3),
      0 0 80px rgba(0, 255, 65, 0.15),
      0 0 120px rgba(0, 255, 65, 0.05);
    animation: number-glow 3s ease-in-out infinite;
    user-select: none;
    position: relative;
  }

  .four-char,
  .zero-char {
    display: inline-block;
    position: relative;
  }

  .zero-char {
    animation: zero-glitch 6s ease-in-out infinite;
  }

  @keyframes zero-glitch {
    0%, 100% { opacity: 1; transform: none; }
    45% { opacity: 1; transform: none; }
    46% { opacity: 0.3; transform: translateX(-2px) skewX(-5deg); }
    47% { opacity: 1; transform: translateX(1px); }
    48% { opacity: 0.7; transform: none; }
    49% { opacity: 1; transform: none; }
  }

  @keyframes number-glow {
    0%, 100% {
      text-shadow:
        0 0 20px rgba(0, 255, 65, 0.6),
        0 0 40px rgba(0, 255, 65, 0.3),
        0 0 80px rgba(0, 255, 65, 0.15),
        0 0 120px rgba(0, 255, 65, 0.05);
    }
    50% {
      text-shadow:
        0 0 30px rgba(0, 255, 65, 0.8),
        0 0 60px rgba(0, 255, 65, 0.45),
        0 0 100px rgba(0, 255, 65, 0.2),
        0 0 160px rgba(0, 255, 65, 0.08);
    }
  }

  /* Main heading */
  .error-heading {
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: clamp(1.25rem, 4vw, 2rem);
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #C8D4B0;
    margin: 0;
    text-shadow: 0 0 20px rgba(139, 154, 70, 0.3);
  }

  /* Description text */
  .error-description {
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: clamp(0.8rem, 1.8vw, 0.9375rem);
    color: #7A8B6A;
    line-height: 1.7;
    max-width: 44ch;
    margin: 0;
    letter-spacing: 0.02em;
  }

  /* ── Diagnostic readout ────────────────────────────────── */
  .diagnostic {
    width: 100%;
    max-width: 460px;
    background-color: rgba(13, 18, 8, 0.9);
    border: 1px solid rgba(74, 93, 35, 0.25);
    border-radius: 2px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: left;
    position: relative;
    overflow: hidden;
  }

  /* Scanning line on diagnostic box */
  .diagnostic::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(0, 255, 65, 0.5),
      transparent
    );
    animation: diag-scan 3s linear infinite;
  }

  .diagnostic::after {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(0, 255, 65, 0.008) 3px,
      rgba(0, 255, 65, 0.008) 6px
    );
    pointer-events: none;
  }

  @keyframes diag-scan {
    0%   { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  .diagnostic-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.375rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(74, 93, 35, 0.2);
  }

  .diag-header-text {
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #5C7A29;
    white-space: nowrap;
  }

  .diag-header-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(74, 93, 35, 0.3), transparent);
  }

  .diagnostic-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: 0.6875rem;
    padding: 0.25rem 0;
  }

  .diag-label {
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #5A6B4A;
    min-width: 12ch;
    flex-shrink: 0;
  }

  .diag-dots {
    flex: 1;
    border-bottom: 1px dotted rgba(74, 93, 35, 0.2);
    min-width: 1rem;
    margin-bottom: 0.2em;
  }

  .diag-value {
    letter-spacing: 0.08em;
    color: #7A8B6A;
    font-weight: 600;
    text-align: right;
  }

  .diag-value--red {
    color: #8B2500;
    text-shadow: 0 0 8px rgba(139, 37, 0, 0.5);
    animation: val-blink 2s ease-in-out infinite;
  }

  @keyframes val-blink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.6; }
  }

  .diag-value--muted {
    color: #5A6B4A;
  }

  .diag-value--olive {
    color: #8B9A46;
    text-shadow: 0 0 6px rgba(139, 154, 70, 0.3);
  }

  .diag-value--green {
    color: #00FF41;
    text-shadow: 0 0 8px rgba(0, 255, 65, 0.4);
  }

  /* ── CTA ────────────────────────────────────────────────── */
  .cta-row {
    display: flex;
    justify-content: center;
    margin-top: 0.75rem;
  }

  .return-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 2rem;
    background-color: #4A5D23;
    color: #C8D4B0;
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: 0.8125rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    border: 2px solid #5C7A29;
    transition:
      background-color 200ms ease,
      color 200ms ease,
      border-color 200ms ease,
      box-shadow 200ms ease,
      transform 150ms ease;
    box-shadow:
      0 0 15px rgba(74, 93, 35, 0.4),
      inset 0 1px 0 rgba(139, 154, 70, 0.2),
      inset 0 -2px 0 rgba(0, 0, 0, 0.3);
    position: relative;
  }

  .btn-bracket {
    color: #5C7A29;
    font-weight: 400;
    font-size: 1em;
    transition: color 200ms ease;
  }

  .btn-icon {
    transition: transform 200ms ease;
  }

  .return-btn:hover {
    background-color: #5C7A29;
    color: #00FF41;
    border-color: #00FF41;
    box-shadow:
      0 0 25px rgba(0, 255, 65, 0.3),
      0 0 50px rgba(74, 93, 35, 0.3),
      inset 0 1px 0 rgba(0, 255, 65, 0.15);
    transform: translateY(-1px);
  }

  .return-btn:hover .btn-bracket {
    color: #00FF41;
  }

  .return-btn:hover .btn-icon {
    transform: translateX(-2px);
  }

  .return-btn:active {
    transform: translateY(1px);
    box-shadow:
      0 0 10px rgba(74, 93, 35, 0.3),
      inset 0 2px 4px rgba(0, 0, 0, 0.4);
  }

  /* Footer classification line */
  .footer-class {
    font-family: ui-monospace, "Cascadia Code", "Fira Code", Menlo, monospace;
    font-size: 0.5rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(90, 107, 74, 0.35);
    margin-top: 0.75rem;
  }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 480px) {
    .corner {
      width: 20px;
      height: 20px;
    }

    .diagnostic {
      padding: 1rem;
    }

    .diag-label {
      min-width: 9ch;
      font-size: 0.6rem;
    }

    .diag-value {
      font-size: 0.6rem;
    }

    .signal-lost {
      font-size: 0.6rem;
    }

    .return-btn {
      padding: 0.65rem 1.5rem;
      font-size: 0.75rem;
    }
  }
</style>
